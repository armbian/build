+#define IEEE80211_S1G_RPS_RAW_CHAN_MAX_TRAN_WIDTH_BITS	(2)
+#define IEEE80211_S1G_RPS_RAW_CHAN_MAX_TRAN_WIDTH	GENMASK(1, 0)
+
+/**
