+
+int morse_dot11ah_s1g_chan_bw_to_5g_chan(int chan_s1g, int bw_mhz)
+{
+	int ch;
+	int ch_bw;
+
+	for (ch = 0; ch < __mors_s1g_map->num_mapped_channels; ch++)
