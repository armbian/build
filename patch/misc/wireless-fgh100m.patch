+#define MORSE_MSG_NONE		LOGLEVEL_EMERG
+#define MORSE_MSG_ALERT		LOGLEVEL_ALERT
+#define MORSE_MSG_CRIT		LOGLEVEL_CRIT
+#define MORSE_MSG_ERR		LOGLEVEL_ERR
