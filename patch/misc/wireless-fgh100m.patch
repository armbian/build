+	req.mcs_index = cpu_to_le32(mcs_index);
+	req.nss_idx = nss_idx;
+	req.use_sgi = use_sgi;
+	req.tx_80211ah_format = cpu_to_le32(-1);
+	req.use_traveling_pilots = -1;
+	req.use_stbc = -1;
+	req.use_ldpc = -1;
