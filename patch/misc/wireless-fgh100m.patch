+static int morse_mac_driver_restart(struct morse *mors)
+{
+	schedule_work(&mors->driver_restart);
+	MORSE_INFO(mors, "Scheduled a driver reset ...\n");
+	set_bit(MORSE_STATE_FLAG_CHIP_UNRESPONSIVE, &mors->state_flags);
+
+	return 0;
+}
