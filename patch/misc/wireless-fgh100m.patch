+	int channel = 0;
+	enum morse_dot11ah_region region;
+
+	region = morse_reg_get_region(__mors_s1g_map->alpha);
+
+	switch (region) {
+	case MORSE_AU:
+	case MORSE_CA:
+	case MORSE_NZ:
+	case MORSE_US:
+		channel = (freq - 902000) /  500;
+		break;
+	case MORSE_EU:
+	case MORSE_GB:
+		if (freq > 901400)
+			channel = (freq - 901400) / 500;
+		else
+			channel = (freq - 863000) / 500;
+		break;
+	case MORSE_IN:
+		channel = (freq - 863000) / 500;
+		break;
+	case MORSE_JP:
+		if ((freq % 1000) == 500) {
+			/* We are on a 500kHz centre */
+			if (bw < 4)
+				channel = (freq - 922500) / 500;
+			else
+				channel = (freq - 906500) / 500;
+		} else {
+			channel = (freq - 916500) / 500;
+		}
+		break;
+	case MORSE_KR:
+		channel = (freq - 917500) / 500;
+		break;
+	case MORSE_SG:
+		if (freq > 902000)
+			channel = (freq - 902000) / 500;
+		else
+			channel = (freq - 863000) / 500;
+		break;
+	case REGION_UNSET:
+	default:
+		break;
+	}
+	return channel;
