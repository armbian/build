+/* Convert a regional ISO alpha-2 string to a morse_region */
+static enum morse_dot11ah_region morse_reg_get_region(const char *alpha)
+{
+	if (!alpha)
+		return REGION_UNSET;
+
+	if (!strcmp(alpha, "AU"))
+		return MORSE_AU;
+
+	if (!strcmp(alpha, "CA"))
+		return MORSE_CA;
+
+	if (!strcmp(alpha, "EU"))
+		return MORSE_EU;
+
+	if (!strcmp(alpha, "GB"))
+		return MORSE_GB;
+
+	if (!strcmp(alpha, "IN"))
+		return MORSE_IN;
+
+	if (!strcmp(alpha, "JP"))
+		return MORSE_JP;
+
+	if (!strcmp(alpha, "KR"))
+		return MORSE_KR;
+
+	if (!strcmp(alpha, "NZ"))
+		return MORSE_NZ;
+
+	if (!strcmp(alpha, "SG"))
+		return MORSE_SG;
+
+	if (!strcmp(alpha, "US"))
+		return MORSE_US;
+
+	return REGION_UNSET;
+}
