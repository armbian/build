+#define IEEE80211_S1G_RPS_RAW_GROUP_START_AID_SHIFT	(2)
+#define IEEE80211_S1G_RPS_RAW_GROUP_START_AID		GENMASK(AID_BITS + 1, 2)
+
+#define IEEE80211_S1G_RPS_RAW_GROUP_END_AID_SHIFT	(13)
