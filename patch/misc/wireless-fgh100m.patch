+u16 crc16xmodem_bit(u16 crc, void const *mem, size_t len)
+{
+	unsigned char const *data = mem;
+	size_t i;
+	unsigned int k;
+
+	if (!data)
+		return 0;
+	for (i = 0; i < len; i++) {
+		crc ^= (u16)data[i] << 8;
+		for (k = 0; k < 8; k++)
+			crc = crc & 0x8000 ? (crc << 1) ^ 0x1021 : crc << 1;
+	}
+	return crc;
+}
+
+u16 crc16xmodem_rem(u16 crc, unsigned int val, unsigned int bits)
+{
+	unsigned int i;
+
+	val &= 0x100 - (0x100 >> bits);
+	crc ^= (u16)val << 8;
+	for (i = 0; i < bits; i++)
+		crc = crc & 0x8000 ? (crc << 1) ^ 0x1021 : crc << 1;
+	return crc;
+}
+
+u16 crc16xmodem_byte(u16 crc, void const *mem, size_t len)
+{
+	unsigned char const *data = mem;
+	size_t i;
+
+	if (!data)
+		return 0;
+	for (i = 0; i < len; i++)
+		crc = (crc << 8) ^ table_byte[((crc >> 8) ^ data[i]) & 0xff];
+
+	return crc;
+}
+
+static inline u16 swaplow(u16 crc)
+{
+	return ((crc & 0xff) << 8) + ((crc & 0xff00) >> 8);
+}
+
+/* This code assumes that integers are stored little-endian. */
+u16 crc16xmodem_word(__le16 crc, void const *mem, size_t len)
+{
+	unsigned char const *data = mem;
+	size_t n;
+	size_t i;
+	u64 word;
+	u16 crc_host = le16_to_cpu(crc);
+
+	if (!data)
+		return 0;
+	while (len && ((ptrdiff_t)data & 0x7)) {
+		len--;
+		crc_host = (crc_host << 8) ^ table_byte[((crc_host >> 8) ^ *data++) & 0xff];
+	}
+	crc_host = swaplow(crc_host);
+	n = len >> 3;
+	for (i = 0; i < n; i++) {
+		u64 data_word = le64_to_cpu(((__le64 const *)data)[i]);
+
+		word = crc_host ^ data_word;
+		crc_host = table_word[7][word & 0xff] ^
+		    table_word[6][(word >> 8) & 0xff] ^
+		    table_word[5][(word >> 16) & 0xff] ^
+		    table_word[4][(word >> 24) & 0xff] ^
+		    table_word[3][(word >> 32) & 0xff] ^
+		    table_word[2][(word >> 40) & 0xff] ^
+		    table_word[1][(word >> 48) & 0xff] ^ table_word[0][word >> 56];
+	}
+	data += n << 3;
+	len &= 7;
+	crc_host = swaplow(crc_host);
+	while (len) {
+		len--;
+		crc_host = (crc_host << 8) ^ table_byte[((crc_host >> 8) ^ *data++) & 0xff];
+	}
+	return crc_host;
+}
+
+static u16 multmodp(u16 a, u16 b)
+{
+	u16 prod = 0;
+
+	for (;;) {
+		if (a & 1) {
+			prod ^= b;
+			if (a == 1)
+				break;
+		}
+		a >>= 1;
+		b = b & 0x8000 ? (b << 1) ^ 0x1021 : b << 1;
+	}
+	return prod;
+}
+
+static const u16 table_comb[] = {
+	0x0002, 0x0004, 0x0010, 0x0100, 0x1021, 0x3730, 0xb861, 0xaefc, 0x8e29, 0x13fc,
+	0x36c4, 0xfd50, 0xaa9e, 0x881c, 0x4458
+};
+
+static u16 x8nmodp(u64 n)
+{
+	u16 xp = 1;
+	int k = 3;
+
+	for (;;) {
+		if (n & 1)
+			xp = multmodp(table_comb[k], xp);
+		n >>= 1;
+		if (n == 0)
+			break;
+		if (++k == 15)
+			k = 0;
+	}
+	return xp;
+}
+
+u16 crc16xmodem_comb(u16 crc1, u16 crc2, u64 len2)
+{
+	return multmodp(x8nmodp(len2), crc1) ^ crc2;
+}
diff --git a/drivers/net/wireless/fgh100m/crc16_xmodem.h b/drivers/net/wireless/fgh100m/crc16_xmodem.h
