+static void free_eid_ies_list(struct ie_element *list_head)
+{
+	struct ie_element *next, *cur;
+
+	for (cur = list_head; cur; cur = next) {
+		next = cur->next;
+		if (cur->needs_free)
+			kfree(cur->ptr);
+		kfree(cur);
+	}
+}
