From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Werner <werner@armbian.com>
Date: Sun, 11 May 2026 00:00:00 +0000
Subject: [PATCH] Fix building on 7.1+ kernel

Starting with kernel 7.1, the pppoe_hdr->tag and pppoe_tag->tag_data
members are no longer exposed to kernel code. Define local versions of
these structures to maintain compatibility.

Also starting with kernel 7.1, cfg80211 API functions changed their
signatures to take struct wireless_dev * instead of struct net_device *
for various operations. Add version guards to support both APIs.

Signed-off-by: Werner <werner@armbian.com>
---
 drivers/net/wireless/rtl8189fs/core/rtw_br_ext.c     | 32 ++++++++++
 .../rtl8189fs/os_dep/linux/ioctl_cfg80211.c          | 96 +++++++++++++++------
 2 files changed, 109 insertions(+), 19 deletions(-)


diff --git a/drivers/net/wireless/rtl8189fs/core/rtw_br_ext.c b/drivers/net/wireless/rtl8189fs/core/rtw_br_ext.c
index 1111111..2222222 100644
--- a/drivers/net/wireless/rtl8189fs/core/rtw_br_ext.c
+++ b/drivers/net/wireless/rtl8189fs/core/rtw_br_ext.c
@@ -24,6 +24,38 @@
 	#include <linux/atalk.h>
 	#include <linux/udp.h>
 	#include <linux/if_pppox.h>
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(7, 1, 0)
+/*
+ * Starting with kernel 7.1, the pppoe_hdr->tag and pppoe_tag->tag_data members
+ * are no longer exposed to kernel code. Define local versions to maintain compatibility.
+ */
+#define pppoe_hdr	rtw_pppoe_hdr
+#define pppoe_tag	rtw_pppoe_tag
+
+struct rtw_pppoe_tag {
+	__be16 tag_type;
+	__be16 tag_len;
+	char tag_data[];
+} __attribute__((packed));
+
+struct rtw_pppoe_hdr {
+#if defined(__LITTLE_ENDIAN_BITFIELD)
+	__u8 type : 4;
+	__u8 ver : 4;
+#elif defined(__BIG_ENDIAN_BITFIELD)
+	__u8 ver : 4;
+	__u8 type : 4;
+#else
+	#error	"Please fix <asm/byteorder.h>"
+#endif
+	__u8 code;
+	__be16 sid;
+	__be16 length;
+	struct rtw_pppoe_tag tag[];
+} __packed;
+#endif /* LINUX_VERSION_CODE >= KERNEL_VERSION(7, 1, 0) */
+
 #endif
 
 #if 1	/* rtw_wifi_driver */

