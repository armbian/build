+	wlan {
+		compatible    = "allwinner,sunxi-wlan";
+		wlan_power    = "axp8191-dcdc1", "axp8191-bldo5", "axp8191-cldo1";
+		wlan_power_vol= <3300000>, <1800000>, <1800000>;
+		wlan_busnum   = <0x1>;
