From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: James Shkolnik <jshkolnik@gmail.com>
Date: Wed, 24 Jun 2026 00:00:00 +0000
Subject: [PATCH] cubie-a7z: add Radxa Cubie A7Z device tree

Adds the Radxa Cubie A7Z (Allwinner A733 / sun60iw2p1) device tree to the
vendor BSP kernel tree and registers it in the allwinner dtb Makefile.

Device tree adapted from dok2d/cubie-a7z-debian (config/dts/), which builds
Debian on the Cubie A7Z from the same Allwinner vendor sources. Validated on
real hardware (Radxa Cubie A7Z v1.11, sun60iw2): boots from microSD with a
working UART0 console, HDMI, USB, and live NPU/GPU device nodes. (WiFi6/BT5.4
via the FCU760K USB module is brought up in the board config, not this DT.)

Signed-off-by: James Shkolnik <jshkolnik@gmail.com>
---
diff --git a/arch/arm64/boot/dts/allwinner/Makefile b/arch/arm64/boot/dts/allwinner/Makefile
index 4929a47..9e8c883 100644
--- a/arch/arm64/boot/dts/allwinner/Makefile
+++ b/arch/arm64/boot/dts/allwinner/Makefile
@@ -43,5 +43,6 @@
 dtb-$(CONFIG_ARCH_SUNXI) += sun50i-h618-orangepi-zero3.dtb
 dtb-$(CONFIG_ARCH_SUNXI) += sun60i-a733-orangepi-4-pro.dtb
 dtb-$(CONFIG_ARCH_SUNXI) += sun60i-a733-orangepi-zero3w.dtb
+dtb-$(CONFIG_ARCH_SUNXI) += sun60i-a733-cubie-a7z.dtb

 subdir-y := $(dts-dirs) overlay
diff --git a/arch/arm64/boot/dts/allwinner/sun60i-a733-cubie-a7z.dts b/arch/arm64/boot/dts/allwinner/sun60i-a733-cubie-a7z.dts
new file mode 100644
index 0000000..0000002
--- /dev/null
+++ b/arch/arm64/boot/dts/allwinner/sun60i-a733-cubie-a7z.dts
@@ -0,0 +1,2169 @@
+// SPDX-License-Identifier: (GPL-2.0+ or MIT)
+
+/dts-v1/;
+
+#include "sun60iw2p1.dtsi"
+#include <dt-bindings/input/linux-event-codes.h>
+#include <dt-bindings/power/sun60iw2-power.h>
+
+/{
+	board = "A733", "A733-PRO3";
+	model = "Radxa Cubie A7Z";
+	compatible = "allwinner,a733", "arm,sun60iw2p1";
+	aliases {
+		standby_param = &standby_param;
+		arisc-config = &arisc_config;
+		pmu0 = &pmu0;
+	};
+
+	/* PWM fan on J6 — disabled: vendor pwm1_9 node lacks #pwm-cells,
+	   incompatible with standard pwm-fan DT binding. Needs vendor PWM API
+	   or use pwm0 channel mapped to PK5 (if possible). */
+
+	/* USB-C host VBUS — SGM2576 load switch, EN = PL2 (USB0-DRVVBUS per schematic p.12) */
+	reg_usbc2_vbus: usbc2-vbus {
+		compatible = "regulator-fixed";
+		regulator-name = "usbc2-vbus";
+		regulator-min-microvolt = <5000000>;
+		regulator-max-microvolt = <5000000>;
+		gpio = <&r_pio 0 2 GPIO_ACTIVE_HIGH>;  /* PL2 */
+		enable-active-high;
+	};
+
+	/* FCU760K WiFi/BT (AIC8800D80 over USB1): drive the enable GPIOs high at boot
+	 * via always-on fixed regulators (vendor board.dts idiom). &rfkill is disabled
+	 * so PM0/PM1 have a single GPIO claim — a double-claim breaks r_pio probe, which
+	 * also carries the s_twi1 RSB to the AXP8191 PMIC -> hard hang (notes/41 §22). */
+	wifi_power_en: wifi-power-en {
+		compatible = "regulator-fixed";
+		regulator-name = "wifi-power-en";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-enable-ramp-delay = <1000>;
+		gpio = <&r_pio PM 0 GPIO_ACTIVE_HIGH>;  /* PM0 = USB_WIFI_PWR */
+		enable-active-high;
+		regulator-always-on;
+		regulator-boot-on;
+	};
+
+	wifi_chip_en: wifi-chip-en {
+		compatible = "regulator-fixed";
+		regulator-name = "wifi-chip-en";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-enable-ramp-delay = <1000>;
+		gpio = <&r_pio PM 1 GPIO_ACTIVE_HIGH>;  /* PM1 = WL-REG-ON */
+		enable-active-high;
+		regulator-always-on;
+		regulator-boot-on;
+	};
+
+	standby_param: standby_param {
+		vcc-io  = <0x00000000400>;
+		vcc-efuse = <0x0000e000000>;
+		vdd-cpub = <0x00000004>;
+		vdd-cpu = <0x000000010>;
+		vdd-sys = <0x00000002>;
+		vcc-pll = <0x00001000000>;
+		osc24m-on = <0>;
+	};
+
+	arisc_config: arisc_config {
+		s_uart_config{
+			pins = "PL2", "PL3";
+			function = <3>, <3>;
+			status = "disabled";
+		};
+	};
+
+	/* backlight0: removed — no DSI display on SBC */
+	/* sunxi-keyboard: removed — no VOL+/VOL- buttons on SBC */
+
+	gpio-leds {
+		compatible = "gpio-leds";
+		user-led {
+			label = "cubie:green:user";
+			gpios = <&r_pio PM 2 GPIO_ACTIVE_HIGH>;
+			linux,default-trigger = "heartbeat";
+		};
+	};
+};
+
+&ccu {
+	clk-init-gate = <1>;
+};
+
+&pio {
+	uart0_pins_active: uart0_pins@0 {
+		pins = "", "";
+		function = "uart0";
+		drive-strength = <10>;
+	};
+
+	uart0_pins_sleep: uart0_pins@1 {
+		pins = "", "";
+		function = "gpio_in";
+		drive-strength = <10>;
+	};
+
+	uart1_pins_active: uart1_pins@0 {
+		pins = "PG6", "PG7", "PG8", "PG9";
+		function = "uart1";
+		drive-strength = <10>;
+	};
+
+	uart1_pins_sleep: uart1_pins@1 {
+		pins = "PG6", "PG7", "PG8", "PG9";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	uart2_pins_active: uart2_pins@0 {
+		pins = "PB0", "PB1", "PB2", "PB3";
+		function = "uart2";
+		drive-strength = <10>;
+	};
+
+	uart2_pins_sleep: uart2_pins@1 {
+		pins = "PB0", "PB1", "PB2", "PB3";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	uart3_pins_active: uart3_pins@0 {
+		pins = "PH4", "PH5", "PH6", "PH7";
+		function = "uart3";
+		drive-strength = <10>;
+	};
+
+	uart3_pins_sleep: uart3_pins@1 {
+		pins = "PH4", "PH5", "PH6", "PH7";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	uart4_pins_active: uart4_pins@0 {
+		pins = "PJ24", "PJ25", "PJ26", "PJ27";
+		function = "uart4";
+		drive-strength = <10>;
+	};
+
+	uart4_pins_sleep: uart4_pins@1 {
+		pins = "PJ24", "PJ25", "PJ26", "PJ27";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	uart5_pins_active: uart5_pins@0 {
+		pins = "PH13", "PH14", "PH15", "PH16";
+		function = "uart5";
+		drive-strength = <10>;
+	};
+
+	uart5_pins_sleep: uart5_pins@1 {
+		pins = "PH13", "PH14", "PH15", "PH16";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	uart6_pins_active: uart6_pins@0 {
+		pins = "PK0", "PK1", "PK2", "PK3";
+		function = "uart6";
+		drive-strength = <10>;
+	};
+
+	uart6_pins_sleep: uart6_pins@1 {
+		pins = "PK0", "PK1", "PK2", "PK3";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	uart7_pins_active: uart7_pins@0 {
+		pins = "PL10", "PL11";
+		function = "uart7";
+		drive-strength = <10>;
+	};
+
+	uart7_pins_sleep: uart7_pins@1 {
+		pins = "PL10", "PL11";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	uart8_pins_active: uart8_pins@0 {
+		pins = "PL2", "PL3";
+		function = "uart8";
+		drive-strength = <10>;
+	};
+
+	uart8_pins_sleep: uart8_pins@1 {
+		pins = "PL2", "PL3";
+		function = "io_disabled";
+		drive-strength = <10>;
+	};
+
+	twi0_pins_default: twi0@0 {
+		pins = "PH0", "PH1";
+		function = "twi0";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi0_pins_sleep: twi0@1 {
+		pins = "PH0", "PH1";
+		function = "gpio_in";
+	};
+
+	twi1_pins_default: twi1@0 {
+		pins = "PH2", "PH3";
+		function = "twi1";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi1_pins_sleep: twi1@1 {
+		pins = "PH2", "PH3";
+		function = "gpio_in";
+	};
+
+	twi2_pins_default: twi2@0 {
+		pins = "PD16", "PD17";
+		function = "twi2";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi2_pins_sleep: twi2@1 {
+		pins = "PD16", "PD17";
+		function = "gpio_in";
+	};
+
+	twi3_pins_default: twi3@0 {
+		pins = "PE3", "PE4";
+		function = "twi3";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi3_pins_sleep: twi3@1 {
+		pins = "PE3", "PE4";
+		function = "gpio_in";
+	};
+
+	twi4_pins_default: twi4@0 {
+		pins = "PE10", "PE11";
+		function = "twi4";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi4_pins_sleep: twi4@1 {
+		pins = "PE10", "PE11";
+		function = "gpio_in";
+	};
+
+	twi8_pins_default: twi8@0 {
+		pins = "PB9", "PB10";
+		function = "twi8";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi8_pins_sleep: twi8@1 {
+		pins = "PB9", "PB10";
+		function = "gpio_in";
+	};
+
+	pwm0_4_pins_active: pwm0@0 {
+		pins = "PD22";
+		function = "pwm0_4";
+	};
+
+	pwm0_4_pins_sleep: pwm0@1 {
+		pins = "PD22";
+		function = "gpio_in";
+		bias-pull-down;
+	};
+
+	/* i2s0 pins */
+	i2s0_pins_a: i2s0@0 {
+		pins = "PB4";
+		function = "i2s0_mclk";
+		drive-strength = <10>;
+		bias-disable;
+	};
+
+	i2s0_pins_b: i2s0@1 {
+		pins = "PB5";
+		function = "i2s0_bclk";
+		drive-strength = <10>;
+		bias-disable;
+	};
+
+	i2s0_pins_c: i2s0@2 {
+		pins = "PB6";
+		function = "i2s0_lrck";
+		drive-strength = <10>;
+		bias-disable;
+	};
+
+	i2s0_pins_d: i2s0@3 {
+		pins = "PB7";
+		function = "i2s0_dout0";
+		drive-strength = <10>;
+		bias-disable;
+	};
+
+	i2s0_pins_e: i2s0@4 {
+		pins = "PB8";
+		function = "i2s0_din0";
+		drive-strength = <10>;
+		bias-disable;
+	};
+
+	i2s0_pins_f: i2s0@5 {
+		pins = "PB4", "PB5", "PB6", "PB7", "PB8";
+		function = "io_disabled";
+		drive-strength = <10>;
+		bias-disable;
+	};
+
+	/* i2s1 pins */
+	i2s1_pins_a: i2s1@1 {
+		pins = "PG11";
+		function = "i2s1_bclk";
+		drive-strength = <20>;
+		bias-disable;
+	};
+
+	i2s1_pins_b: i2s1@2 {
+		pins = "PG12";
+		function = "i2s1_lrck";
+		drive-strength = <20>;
+		bias-disable;
+	};
+
+	i2s1_pins_c: i2s1@3 {
+		pins = "PG13";
+		function = "i2s1_dout0";
+		drive-strength = <20>;
+		bias-disable;
+	};
+
+	i2s1_pins_d: i2s1@4 {
+		pins = "PG14";
+		function = "i2s1_din0";
+		drive-strength = <20>;
+		bias-disable;
+	};
+
+	i2s1_pins_e: i2s1@5 {
+		pins = "PG11", "PG12", "PG13", "PG14";
+		function = "io_disabled";
+		drive-strength = <20>;
+		bias-disable;
+	};
+
+	/* SPI1 — 40-pin header (pin 19=MOSI, 21=MISO, 23=CLK, 24=CS0) */
+	spi1_pins: spi1-pins {
+		pins = "PD10", "PD11", "PD12", "PD13";
+		function = "spi1";
+		drive-strength = <10>;
+	};
+
+	/* Fan PWM */
+	pwm1_9_pins_active: pwm1@0 {
+		pins = "PK5";
+		function = "pwm1_9";
+		drive-strength = <10>;
+	};
+
+	pwm1_9_pins_sleep: pwm1@1 {
+		pins = "PK5";
+		function = "gpio_in";
+		bias-pull-down;
+	};
+
+	/* TWI7 — 40-pin header I2C (pin 1 SDA, pin 3 SCK) */
+	twi7_pins_default: twi7@0 {
+		pins = "PJ22", "PJ23";
+		function = "twi7";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi7_pins_sleep: twi7@1 {
+		pins = "PJ22", "PJ23";
+		function = "gpio_in";
+	};
+};
+
+&r_pio {
+	twi13_pins_default: twi13@0 {
+		pins = "PL0", "PL1";
+		function = "s_twi0";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+
+	twi13_pins_sleep: twi13@1 {
+		pins = "PL0", "PL1";
+		function = "gpio_in";
+	};
+
+	s_twi1_pins_default: s_twi1@0 {
+		pins = "PL12", "PL13";
+		function = "s_twi1";
+		drive-strength = <30>;
+	};
+
+	s_twi1_pins_sleep: s_twi1@1 {
+		pins = "PL12", "PL13";
+		function = "gpio_in";
+	};
+
+	et7304_int: et7304-int@0 {
+		pins = "PL9";
+		function = "gpio_in";
+		drive-strength = <10>;
+		bias-pull-up;
+	};
+};
+
+&soc {
+	auto_print@54321 {
+		reg = <0x0 0x54321 0x0 0x0>;
+		device_type = "auto_print";
+		status = "okay";
+	};
+
+	/* hall_para: removed — no lid sensor on SBC */
+
+	motor_para {
+		compatible = "allwinner,sunxi-vibrator";
+		motor_used = <1>;
+		motor_shake = <0>;
+		status = "disabled";
+		motor-supply = <&reg_dldo5>;
+		motor_ldo_voltage = <3300>;
+	};
+};
+
+&msgbox {
+	status = "okay";
+};
+
+&hwspinlock {
+	status = "okay";
+};
+
+&uart0 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart0_pins_active>;
+	pinctrl-1 = <&uart0_pins_sleep>;
+	status = "okay";
+};
+
+&uart1 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart1_pins_active>;
+	pinctrl-1 = <&uart1_pins_sleep>;
+	status = "okay";
+};
+
+&uart2 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart2_pins_active>;
+	pinctrl-1 = <&uart2_pins_sleep>;
+	status = "disabled";
+};
+
+&uart3 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart3_pins_active>;
+	pinctrl-1 = <&uart3_pins_sleep>;
+	status = "disabled";
+};
+
+&uart4 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart4_pins_active>;
+	pinctrl-1 = <&uart4_pins_sleep>;
+	status = "disabled";
+};
+
+&uart5 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart5_pins_active>;
+	pinctrl-1 = <&uart5_pins_sleep>;
+	status = "disabled";
+};
+
+&uart6 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart6_pins_active>;
+	pinctrl-1 = <&uart6_pins_sleep>;
+	status = "disabled";
+};
+
+&uart7 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart7_pins_active>;
+	pinctrl-1 = <&uart7_pins_sleep>;
+	status = "disabled";
+};
+
+&uart8 {
+	pinctrl-names = "default", "sleep";
+	pinctrl-0 = <&uart8_pins_active>;
+	pinctrl-1 = <&uart8_pins_sleep>;
+	status = "disabled";
+};
+
+&sdc2 {
+	non-removable;
+	bus-width = <8>;
+	mmc-ddr-1_8v;
+	mmc-hs200-1_8v;
+	mmc-hs400-1_8v;
+	no-sdio;
+	no-sd;
+	ctl-spec-caps = <0x328>;
+	cap-mmc-highspeed;
+	sunxi-power-save-mode;
+	sunxi-dis-signal-vol-sw;
+	mmc-bootpart-noacc;
+	/*cap-hsq;*/
+	cqe-on;
+	ctl-cmdq-md = <0x2>;
+	max-frequency = <200000000>;
+	/*vmmc-supply = <&reg_cldo3>;*/
+	/*emmc io vol 3.3v*/
+	/*vqmmc-supply = <&reg_aldo1>;*/
+	/*emmc io vol 1.8v*/
+	/*vqmmc-supply = <&reg_cldo1>;*/
+	status = "disabled";
+};
+
+&sdc0 {
+	bus-width = <4>;
+	cd-gpios = <&pio PF 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
+	/*non-removable;*/
+	/*broken-cd;*/
+	/*cd-inverted*/
+	/*data3-detect;*/
+	/*card-pwr-gpios = <&pio PH 14 1 1 2 0xffffffff>;*/
+	cd-used-24M;
+	cd-set-debounce = <0x1>;
+	cap-sd-highspeed;
+	sd-uhs-sdr50;
+	sd-uhs-ddr50;
+	sd-uhs-sdr104;
+	no-sdio;
+	no-mmc;
+	sunxi-power-save-mode;
+	/*sunxi-dis-signal-vol-sw;*/
+	max-frequency = <150000000>;
+	ctl-spec-caps = <0x428>;
+	/*vmmc-supply = <&reg_cldo3>;*/
+	/*vqmmc33sw-supply = <&reg_cldo3>;*/
+	/*vdmmc33sw-supply = <&reg_cldo3>;*/
+	/*vqmmc18sw-supply = <&reg_cldo1>;*/
+	/*vdmmc18sw-supply = <&reg_cldo1>;*/
+	status = "okay";
+};
+
+&sdc1 {
+	bus-width = <4>;
+	no-mmc;
+	no-sd;
+	cap-sd-highspeed;
+	/*sd-uhs-sdr12*/
+	sd-uhs-sdr25;
+	sd-uhs-sdr50;
+	sd-uhs-ddr50;
+	sd-uhs-sdr104;
+	/*sunxi-power-save-mode;*/
+	sunxi-dis-signal-vol-sw;
+	cap-sdio-irq;
+	keep-power-in-suspend;
+	ignore-pm-notify;
+	/*
+	 * For AIC Wi-Fi SDIO3.0,
+	 * when max-frequency = <208000000>, set sunxi-dly-208M = <0 0 0 0 0 0>
+	 * when max-frequency = <150000000>, set sunxi-dly-208M = <1 1 0 0 1 1>
+	 */
+	max-frequency = <208000000>;
+	sunxi-dly-208M  = <0 0 0 0 0 0>;
+	ctl-spec-caps = <0x428>;
+	status = "disabled";
+};
+
+/*
+ * usb_port_type: usb mode. 0-device, 1-host, 2-otg.
+ * usb_detect_type: usb hotplug detect mode. 0-none, 1-vbus/id detect, 2-pmu detect, 3-tcpm detect.
+ * usb_detect_mode: 0-thread scan, 1-id gpio interrupt, 2-pmu notify.
+ * usb_id_gpio: gpio for id detect.
+ * usb_det_vbus_gpio: gpio for id detect. gpio or "axp_ctrl".
+ * usb_wakeup_suspend：0-SUPER_STANDBY, 1-USB_STANDBY.
+ */
+&usbc0 {
+	device_type = "usbc0";
+	usb_port_type = <0x1>;        /* host mode — OTG broken (AXP515 probe fail) */
+	usb_detect_type = <0x0>;      /* no detection — fixed host */
+	usb_detect_mode = <0x0>;
+	usb_regulator_io = "nocare";
+	usb_wakeup_suspend = <0>;
+	status = "okay";
+};
+
+&udc {
+	phy_range = <0x1df>;
+	status = "okay";
+};
+
+&ehci0 {
+	phy_range = <0x1df>;
