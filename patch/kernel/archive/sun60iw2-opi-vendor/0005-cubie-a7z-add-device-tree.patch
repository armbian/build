+	/* Disabled on A7Z: WiFi/BT is USB (FCU760K), not SDIO, so sunxi-rfkill never
+	 * asserts power for it. Power-on moved to the wifi_power_en/wifi_chip_en fixed
+	 * regulators (single PM0/PM1 claim — see the r_pio/PMIC note above). The wlan/bt
+	 * subnodes are kept for reference but inert while the node is disabled. */
+	status = "disabled";
