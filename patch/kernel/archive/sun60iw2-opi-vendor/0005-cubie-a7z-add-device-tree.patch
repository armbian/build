+	bt {
+		compatible    = "allwinner,sunxi-bt";
+		bt_power    = "axp8191-dcdc1", "axp8191-bldo5", "axp8191-cldo1";
+		bt_power_vol= <3300000>, <1800000>, <1800000>;
