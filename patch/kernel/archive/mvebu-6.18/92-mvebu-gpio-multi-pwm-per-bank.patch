 #define MVEBU_MAX_GPIO_PER_BANK		32
 
-struct mvebu_pwm {
+/*
+ * Armada-38x style SoCs provide exactly two PWM "blink" counters (A and B)
+ * shared by every GPIO bank. Each bank's "pwm" register resource maps only one
+ * of them (GPIO chip id 0 -> counter A, id 1 -> counter B), while a per-line
+ * bit in each bank's GPIO_BLINK_CNT_SELECT register routes that line to counter
+ * A (0) or counter B (1). Driving more than one PWM line on a single bank (for
+ * example the two fans wired to gpio1 on Helios4) therefore requires a line to
+ * borrow the counter mapped by the other bank, so on these SoCs each bank
+ * publishes its counter into a small global pool that lines claim from.
+ *
+ * Armada-8K instead keeps both counters inside a single bank's register block
+ * and replicates that block per CP110, so a SoC-global pool cannot describe it.
+ * There each bank only ever drives its own counter (no cross-bank borrowing).
+ */
+enum mvebu_pwm_counter_id {
+	MVEBU_PWM_COUNTER_A = 0,
+	MVEBU_PWM_COUNTER_B,
+	MVEBU_PWM_COUNTER_NUM,
+};
+
+struct mvebu_pwm_counter {
 	struct regmap		*regs;
 	u32			 offset;
 	unsigned long		 clk_rate;
+	enum mvebu_pwm_counter_id id;
+	bool			 in_use;
+
+	/* Used to preserve PWM registers across suspend/resume */
+	u32			 blink_on_duration;
+	u32			 blink_off_duration;
+};
+
+struct mvebu_pwm_line {
 	struct gpio_desc	*gpiod;
-	spinlock_t		 lock;
+	struct mvebu_pwm_counter *counter;	/* claimed counter, or NULL */
+};
+
+struct mvebu_pwm {
 	struct mvebu_gpio_chip	*mvchip;
+	struct mvebu_pwm_counter counter;	/* this bank's own blink counter */
+	bool			 shared;	/* counter joins the global pool */
 
-	/* Used to preserve GPIO/PWM registers across suspend/resume */
+	/* Used to preserve the GPIO blink select register across suspend/resume */
 	u32			 blink_select;
-	u32			 blink_on_duration;
-	u32			 blink_off_duration;
+
+	/*
+	 * Per-line "requested" bits. gpiochip_request_own_desc() may sleep and
