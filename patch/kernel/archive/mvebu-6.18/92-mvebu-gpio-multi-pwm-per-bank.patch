+
+	/* Route this line to the claimed counter (select bit: 0 -> A, 1 -> B). */
+	spin_lock_irqsave(&mvebu_pwm_lock, flags);
+	regmap_update_bits(mvchip->regs,
+			   GPIO_BLINK_CNT_SELECT_OFF + mvchip->offset,
+			   BIT(pwm->hwpwm),
