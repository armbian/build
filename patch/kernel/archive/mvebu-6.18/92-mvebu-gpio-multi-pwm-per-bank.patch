+	spin_lock_irqsave(&mvebu_pwm_lock, flags);
+	if (mvpwm->shared) {
+		/* Claim whichever shared counter is published and free. */
+		for (id = MVEBU_PWM_COUNTER_A; id < MVEBU_PWM_COUNTER_NUM; id++) {
+			if (!mvebu_pwm_pool[id]) {
