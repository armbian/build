From afc26d518c19cd0226303fae40a240f1e397814f Mon Sep 17 00:00:00 2001
From: Swamil Jain <s-jain1@ti.com>
Date: Thu, 19 Feb 2026 01:39:05 +0530
Subject: [PATCH 16/20] PENDING: arm64: dts: ti: k3-am62p-j722s-common-main:
 Add tidss clk-ctrl property

For AM62P and J722S SoCs, we need to use the newly created clk-ctrl
property to properly handle data edge sampling configuration. Add them
in the common-main device tree.

Signed-off-by: Swamil Jain <s-jain1@ti.com>
---
 arch/arm64/boot/dts/ti/k3-am62p-j722s-common-main.dtsi | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/arch/arm64/boot/dts/ti/k3-am62p-j722s-common-main.dtsi b/arch/arm64/boot/dts/ti/k3-am62p-j722s-common-main.dtsi
index a7f310ce..c70d09da 100644
--- a/arch/arm64/boot/dts/ti/k3-am62p-j722s-common-main.dtsi
+++ b/arch/arm64/boot/dts/ti/k3-am62p-j722s-common-main.dtsi
@@ -58,6 +58,11 @@ epwm_tbclk: clock-controller@4130 {
 			#clock-cells = <1>;
 		};
 
+		dss_clk_ctrl: dss_clk_ctrl@8300 {
+			compatible = "ti,am625-dss-clk-ctrl", "syscon";
+			reg = <0x8300 0x4>;
+		};
+
 		dss_oldi_io_ctrl: dss-oldi-io-ctrl@8600 {
 			compatible = "syscon";
 			reg = <0x8600 0x200>;
@@ -1125,6 +1130,7 @@ dss0: dss@30200000 {
 			 <&k3_clks 186 2>;
 		clock-names = "fck", "vp1", "vp2";
 		interrupts = <GIC_SPI 84 IRQ_TYPE_LEVEL_HIGH>;
+		ti,clk-ctrl = <&dss_clk_ctrl>;
 		status = "disabled";
 
 		oldi-transmitters {
@@ -1176,6 +1182,7 @@ dss1: dss@30220000 {
 			 <&k3_clks 232 4>;
 		clock-names = "fck", "vp1", "vp2";
 		interrupts = <GIC_SPI 30 IRQ_TYPE_LEVEL_HIGH>;
+		ti,clk-ctrl = <&dss_clk_ctrl>;
 		status = "disabled";
 
 		oldi-transmitters {
