From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei1998@gmail.com>
Date: Sun, 5 Jul 2026 21:30:00 +0000
Subject: [PATCH] arm64: dts: ti: add BeagleY-AI EdgeAI apps overlay

Add the EdgeAI/TIOVX reserved-memory overlay used by the TI userspace
ISP stack on AM67A/J722S. The overlay disables the default remoteproc
carveouts, provides the Vision Apps carveouts expected by the firmware,
and points the R5F/C7x remoteproc nodes at those memory regions.

This is the source form of the equivalent overlay tested with tiovxisp
on BeagleY-AI.

Assisted-by: Codex <codex@openai.com>
---
 arch/arm64/boot/dts/ti/Makefile                    |   1 +
 .../dts/ti/k3-am67a-beagley-ai-edgeai-apps.dtso    | 141 +++++++++++++++++++++
 2 files changed, 142 insertions(+)
 create mode 100644 arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-edgeai-apps.dtso

diff --git a/arch/arm64/boot/dts/ti/Makefile b/arch/arm64/boot/dts/ti/Makefile
index 222222222222..444444444444 100644
--- a/arch/arm64/boot/dts/ti/Makefile
+++ b/arch/arm64/boot/dts/ti/Makefile
@@ -139,6 +139,7 @@ dtb-$(CONFIG_ARCH_K3) += k3-j721s2-evm-usb0-type-a.dtbo
 # Boards with J722s SoC
 dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai.dtb
 dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai-csi0-imx219.dtbo
+dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai-edgeai-apps.dtbo
 dtb-$(CONFIG_ARCH_K3) += k3-j722s-evm.dtb
 dtb-$(CONFIG_ARCH_K3) += k3-j722s-evm-csi2-quad-rpi-cam-imx219.dtbo
 dtb-$(CONFIG_ARCH_K3) += k3-j722s-evm-csi2-quad-tevi-ov5640.dtbo
diff --git a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-edgeai-apps.dtso b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-edgeai-apps.dtso
new file mode 100644
index 000000000000..555555555555
--- /dev/null
+++ b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-edgeai-apps.dtso
@@ -0,0 +1,141 @@
+// SPDX-License-Identifier: GPL-2.0-only OR MIT
+/dts-v1/;
+/plugin/;
+
+&mcu_r5fss0_core0_memory_region {
+	status = "disabled";
+};
+
+&mcu_r5fss0_core0_dma_memory_region {
+	status = "disabled";
+};
+
+&main_r5fss0_core0_dma_memory_region {
+	status = "disabled";
+};
+
+&main_r5fss0_core0_memory_region {
+	status = "disabled";
+};
+
+&c7x_0_dma_memory_region {
+	status = "disabled";
+};
+
+&c7x_0_memory_region {
+	status = "disabled";
+};
+
+&c7x_1_dma_memory_region {
+	status = "disabled";
+};
+
+&c7x_1_memory_region {
+	status = "disabled";
+};
+
+&rtos_ipc_memory_region {
+	status = "disabled";
+};
+
+&reserved_memory {
+	#address-cells = <2>;
+	#size-cells = <2>;
+
+	vision_apps_r5f_dma_memory_lo: vision-apps-r5f-dma-memory@a1000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xa1000000 0x00 0x00100000>;
+		no-map;
+	};
+
+	vision_apps_r5f_memory_lo: vision-apps-r5f-memory@a1100000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xa1100000 0x00 0x00f00000>;
+		no-map;
+	};
+
+	vision_apps_main_r5f_dma_memory: vision-apps-r5f-dma-memory@a2000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xa2000000 0x00 0x00100000>;
+		no-map;
+	};
+
+	vision_apps_main_r5f_memory: vision-apps-r5f-memory@a2100000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xa2100000 0x00 0x01f00000>;
+		no-map;
+	};
+
+	vision_apps_rtos_ipc_memory: vision-apps-rtos-ipc-memory-region@a5000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xa5000000 0x00 0x02000000>;
+		no-map;
+	};
+
+	vision_apps_dma_memory: vision-apps-dma-memory@a7000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xa7000000 0x00 0x06000000>;
+		no-map;
+	};
+
+	vision_apps_c71_0_dma_memory: vision-apps-c71-dma-memory@ad000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xad000000 0x00 0x00100000>;
+		no-map;
+	};
+
+	vision_apps_c71_0_memory: vision-apps-c71_0-memory@ad100000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xad100000 0x00 0x03f00000>;
+		no-map;
+	};
+
+	vision_apps_c71_1_dma_memory: vision-apps-c71_1-dma-memory@b1000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xb1000000 0x00 0x00100000>;
+		no-map;
+	};
+
+	vision_apps_c71_1_memory: vision-apps-c71_1-memory@b1100000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xb1100000 0x00 0x03f00000>;
+		no-map;
+	};
+
+	vision_apps_core_heap_memory_lo: vision-apps-core-heap-memory-lo@b5000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x00 0xb5000000 0x00 0x02800000>;
+		no-map;
+	};
+
+	c7x_ddr_heaps_hi: c7x-ddr-heaps-hi@880000000 {
+		compatible = "shared-dma-pool";
+		reg = <0x08 0x80000000 0x00 0x20000000>;
+		no-map;
+	};
+
+	vision_apps_shared_memories: vision_apps_shared-memories {
+		compatible = "dma-heap-carveout";
+		reg = <0x08 0xa0000000 0x00 0x20000000>;
+	};
+};
+
+&mcu_r5fss0_core0 {
+	memory-region = <&vision_apps_r5f_dma_memory_lo>,
+			<&vision_apps_r5f_memory_lo>;
+};
+
+&main_r5fss0_core0 {
+	memory-region = <&vision_apps_main_r5f_dma_memory>,
+			<&vision_apps_main_r5f_memory>;
+};
+
+&c7x_0 {
+	memory-region = <&vision_apps_c71_0_dma_memory>,
+			<&vision_apps_c71_0_memory>;
+};
+
+&c7x_1 {
+	memory-region = <&vision_apps_c71_1_dma_memory>,
+			<&vision_apps_c71_1_memory>;
+};
--
2.43.0
