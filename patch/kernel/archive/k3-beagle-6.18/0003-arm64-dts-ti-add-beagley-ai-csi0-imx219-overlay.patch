From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei1998@gmail.com>
Date: Sun, 5 Jul 2026 20:10:00 +0000
Subject: [PATCH] arm64: dts: ti: add BeagleY-AI CSI0 IMX219 overlay

Add an overlay for a Raspberry Pi Camera V2.1 connected to the
BeagleY-AI CSI0 connector. The camera is an IMX219 on main_i2c2 with
two CSI-2 data lanes routed to CSI2RX0 and reset controlled by MCU
GPIO0_15.

The overlay enables the Cadence CSI2RX bridge, TI CSI2RX shim, and DPHY
nodes needed for raw capture on AM67A/J722S. Userspace ISP pipelines can
then consume the raw frames through the TI media graph.

Assisted-by: Codex <codex@openai.com>
---
 arch/arm64/boot/dts/ti/Makefile                    |  1 +
 .../dts/ti/k3-am67a-beagley-ai-csi0-imx219.dtso    | 128 +++++++++++++++++++++
 2 files changed, 129 insertions(+)
 create mode 100644 arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-csi0-imx219.dtso

diff --git a/arch/arm64/boot/dts/ti/Makefile b/arch/arm64/boot/dts/ti/Makefile
index 111111111111..222222222222 100644
--- a/arch/arm64/boot/dts/ti/Makefile
+++ b/arch/arm64/boot/dts/ti/Makefile
@@ -138,6 +138,7 @@ dtb-$(CONFIG_ARCH_K3) += k3-j721s2-evm-usb0-type-a.dtbo

 # Boards with J722s SoC
 dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai.dtb
+dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai-csi0-imx219.dtbo
 dtb-$(CONFIG_ARCH_K3) += k3-j722s-evm.dtb
 dtb-$(CONFIG_ARCH_K3) += k3-j722s-evm-csi2-quad-rpi-cam-imx219.dtbo
 dtb-$(CONFIG_ARCH_K3) += k3-j722s-evm-csi2-quad-tevi-ov5640.dtbo
diff --git a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-csi0-imx219.dtso b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-csi0-imx219.dtso
new file mode 100644
index 000000000000..333333333333
--- /dev/null
+++ b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai-csi0-imx219.dtso
@@ -0,0 +1,128 @@
+// SPDX-License-Identifier: GPL-2.0-only OR MIT
+/*
+ * DT Overlay for Raspberry Pi Camera V2.1 on BeagleY-AI CSI0.
+ *
+ * Schematics: https://datasheets.raspberrypi.com/camera/camera-v2-schematics.pdf
+ */
+
+/dts-v1/;
+/plugin/;
+
+#include <dt-bindings/gpio/gpio.h>
+#include "k3-pinctrl.h"
+
+&{/} {
+	bgyai_csi0_clk_imx219: clock-24000000 {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <24000000>;
+	};
+
+	bgyai_csi0_reg_2p8v: regulator-camera-2p8v {
+		compatible = "regulator-fixed";
+		regulator-name = "camera-2p8v";
+		regulator-min-microvolt = <2800000>;
+		regulator-max-microvolt = <2800000>;
+		vin-supply = <&vdd_3v3>;
+		regulator-always-on;
+	};
+
+	bgyai_csi0_reg_1p8v: regulator-camera-1p8v {
+		compatible = "regulator-fixed";
+		regulator-name = "camera-1p8v";
+		regulator-min-microvolt = <1800000>;
+		regulator-max-microvolt = <1800000>;
+		vin-supply = <&vdd_3v3>;
+		regulator-always-on;
+	};
+
+	bgyai_csi0_reg_1p2v: regulator-camera-1p2v {
+		compatible = "regulator-fixed";
+		regulator-name = "camera-1p2v";
+		regulator-min-microvolt = <1200000>;
+		regulator-max-microvolt = <1200000>;
+		vin-supply = <&vdd_3v3>;
+		regulator-always-on;
+	};
+};
+
+&mcu_pmx0 {
+	bgyai_csi0_reset_pins_default: bgyai-csi0-reset-default-pins {
+		pinctrl-single,pins = <
+			J722S_MCU_IOPAD(0x003c, PIN_OUTPUT, 7) /* MCU_MCAN1_TX.MCU_GPIO0_15 */
+		>;
+	};
+};
+
+&main_pmx0 {
+	bgyai_csi0_i2c2_pins_default: bgyai-csi0-i2c2-default-pins {
+		pinctrl-single,pins = <
+			J722S_IOPAD(0x00b0, PIN_INPUT_PULLUP, 1) /* GPMC0_CSn2.I2C2_SCL */
+			J722S_IOPAD(0x00b4, PIN_INPUT_PULLUP, 1) /* GPMC0_CSn3.I2C2_SDA */
+		>;
+	};
+};
+
+&mcu_gpio0 {
+	status = "okay";
+};
+
+&main_i2c2 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&bgyai_csi0_i2c2_pins_default>;
+	clock-frequency = <400000>;
+	#address-cells = <1>;
+	#size-cells = <0>;
+	status = "okay";
+
+	bgyai_csi0_imx219: sensor@10 {
+		compatible = "sony,imx219";
+		reg = <0x10>;
+
+		clocks = <&bgyai_csi0_clk_imx219>;
+
+		VANA-supply = <&bgyai_csi0_reg_2p8v>;
+		VDIG-supply = <&bgyai_csi0_reg_1p8v>;
+		VDDL-supply = <&bgyai_csi0_reg_1p2v>;
+
+		pinctrl-names = "default";
+		pinctrl-0 = <&bgyai_csi0_reset_pins_default>;
+		reset-gpios = <&mcu_gpio0 15 GPIO_ACTIVE_HIGH>;
+
+		port {
+			bgyai_csi0_cam: endpoint {
+				remote-endpoint = <&bgyai_csi0_rx>;
+				link-frequencies = /bits/ 64 <456000000>;
+				clock-lanes = <0>;
+				data-lanes = <1 2>;
+			};
+		};
+	};
+};
+
+&cdns_csi2rx0 {
+	ports {
+		#address-cells = <1>;
+		#size-cells = <0>;
+
+		port@0 {
+			reg = <0>;
+			status = "okay";
+
+			bgyai_csi0_rx: endpoint {
+				remote-endpoint = <&bgyai_csi0_cam>;
+				bus-type = <4>; /* CSI2 DPHY */
+				clock-lanes = <0>;
+				data-lanes = <1 2>;
+			};
+		};
+	};
+};
+
+&ti_csi2rx0 {
+	status = "okay";
+};
+
+&dphy0 {
+	status = "okay";
+};
-- 
2.43.0
