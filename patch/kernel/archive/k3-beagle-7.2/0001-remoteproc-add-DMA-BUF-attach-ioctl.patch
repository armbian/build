From 571a63d40cb021e7c2b58d28270ada44757a62aa Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei1998@gmail.com>
Date: Sun, 5 Jul 2026 18:45:00 +0000
Subject: [PATCH 01/20] remoteproc: add DMA-BUF attach ioctl

Add a remoteproc character-device ioctl that lets userspace attach a DMA-BUF to a remote processor and retrieve the mapped device address.\n\nThis is needed by TI EdgeAI/TIOVX userspace components that pass contiguous DMA heap buffers to remote processors.\n\nAssisted-by: Codex <codex@openai.com>
---
 drivers/remoteproc/remoteproc_cdev.c     | 107 +++++++++++++--
 drivers/remoteproc/remoteproc_core.c     | 157 +++++++++++++++++++++++
 drivers/remoteproc/remoteproc_internal.h |  26 ++++
 include/linux/remoteproc.h               |   8 ++
 include/uapi/linux/remoteproc_cdev.h     |  19 +++
 5 files changed, 308 insertions(+), 9 deletions(-)

diff --git a/drivers/remoteproc/remoteproc_cdev.c b/drivers/remoteproc/remoteproc_cdev.c
index 687f205f..0d691d09 100644
--- a/drivers/remoteproc/remoteproc_cdev.c
+++ b/drivers/remoteproc/remoteproc_cdev.c
@@ -7,9 +7,11 @@
 
 #include <linux/cdev.h>
 #include <linux/compat.h>
+#include <linux/dma-buf.h>
 #include <linux/fs.h>
 #include <linux/module.h>
 #include <linux/remoteproc.h>
+#include <linux/slab.h>
 #include <linux/uaccess.h>
 #include <uapi/linux/remoteproc_cdev.h>
 
@@ -18,9 +20,20 @@
 #define NUM_RPROC_DEVICES	64
 static dev_t rproc_major;
 
+struct rproc_cdev_file {
+	struct rproc *rproc;
+	struct list_head attachments;
+};
+
+struct rproc_cdev_attach {
+	struct dma_buf *dmabuf;
+	struct list_head node;
+};
+
 static ssize_t rproc_cdev_write(struct file *filp, const char __user *buf, size_t len, loff_t *pos)
 {
-	struct rproc *rproc = container_of(filp->f_inode->i_cdev, struct rproc, cdev);
+	struct rproc_cdev_file *rproc_file = filp->private_data;
+	struct rproc *rproc = rproc_file->rproc;
 	int ret = 0;
 	char cmd[10];
 
@@ -47,7 +60,8 @@ static ssize_t rproc_cdev_write(struct file *filp, const char __user *buf, size_
 
 static long rproc_device_ioctl(struct file *filp, unsigned int ioctl, unsigned long arg)
 {
-	struct rproc *rproc = container_of(filp->f_inode->i_cdev, struct rproc, cdev);
+	struct rproc_cdev_file *rproc_file = filp->private_data;
+	struct rproc *rproc = rproc_file->rproc;
 	void __user *argp = (void __user *)arg;
 	s32 param;
 
@@ -64,6 +78,54 @@ static long rproc_device_ioctl(struct file *filp, unsigned int ioctl, unsigned l
 			return -EFAULT;
 
 		break;
+	case RPROC_IOC_DMA_BUF_ATTACH: {
+		struct rproc_dma_buf_attach_data data;
+		struct rproc_cdev_attach *attach;
+		struct dma_buf *dmabuf;
+		dma_addr_t da;
+		int ret;
+
+		if (copy_from_user(&data, argp, sizeof(data)))
+			return -EFAULT;
+
+		dmabuf = dma_buf_get(data.fd);
+		if (IS_ERR(dmabuf))
+			return PTR_ERR(dmabuf);
+
+		ret = rproc_attach_dmabuf(rproc, dmabuf);
+		if (ret) {
+			dma_buf_put(dmabuf);
+			return ret;
+		}
+
+		ret = rproc_dmabuf_get_da(rproc, dmabuf, &da);
+		if (ret) {
+			rproc_detach_dmabuf(rproc, dmabuf);
+			dma_buf_put(dmabuf);
+			return ret;
+		}
+		data.da = da;
+
+		attach = kzalloc(sizeof(*attach), GFP_KERNEL);
+		if (!attach) {
+			rproc_detach_dmabuf(rproc, dmabuf);
+			dma_buf_put(dmabuf);
+			return -ENOMEM;
+		}
+
+		attach->dmabuf = dmabuf;
+		list_add_tail(&attach->node, &rproc_file->attachments);
+
+		if (copy_to_user(argp, &data, sizeof(data))) {
+			list_del(&attach->node);
+			kfree(attach);
+			rproc_detach_dmabuf(rproc, dmabuf);
+			dma_buf_put(dmabuf);
+			return -EFAULT;
+		}
+
+		break;
+	}
 	default:
 		dev_err(&rproc->dev, "Unsupported ioctl\n");
 		return -EINVAL;
@@ -72,18 +134,44 @@ static long rproc_device_ioctl(struct file *filp, unsigned int ioctl, unsigned l
 	return 0;
 }
 
-static int rproc_cdev_release(struct inode *inode, struct file *filp)
+static int rproc_cdev_open(struct inode *inode, struct file *filp)
 {
 	struct rproc *rproc = container_of(inode->i_cdev, struct rproc, cdev);
+	struct rproc_cdev_file *rproc_file;
+
+	rproc_file = kzalloc(sizeof(*rproc_file), GFP_KERNEL);
+	if (!rproc_file)
+		return -ENOMEM;
+
+	rproc_file->rproc = rproc;
+	INIT_LIST_HEAD(&rproc_file->attachments);
+	filp->private_data = rproc_file;
+
+	return 0;
+}
+
+static int rproc_cdev_release(struct inode *inode, struct file *filp)
+{
+	struct rproc_cdev_file *rproc_file = filp->private_data;
+	struct rproc *rproc = rproc_file->rproc;
+	struct rproc_cdev_attach *attach, *tmp;
 	int ret = 0;
 
-	if (!rproc->cdev_put_on_release)
-		return 0;
+	list_for_each_entry_safe(attach, tmp, &rproc_file->attachments, node) {
+		rproc_detach_dmabuf(rproc, attach->dmabuf);
+		dma_buf_put(attach->dmabuf);
+		list_del(&attach->node);
+		kfree(attach);
+	}
 
-	if (rproc->state == RPROC_RUNNING)
-		rproc_shutdown(rproc);
-	else if (rproc->state == RPROC_ATTACHED)
-		ret = rproc_detach(rproc);
+	if (rproc->cdev_put_on_release) {
+		if (rproc->state == RPROC_RUNNING)
+			rproc_shutdown(rproc);
+		else if (rproc->state == RPROC_ATTACHED)
+			ret = rproc_detach(rproc);
+	}
+
+	kfree(rproc_file);
 
 	return ret;
 }
@@ -92,6 +180,7 @@ static const struct file_operations rproc_fops = {
 	.write = rproc_cdev_write,
 	.unlocked_ioctl = rproc_device_ioctl,
 	.compat_ioctl = compat_ptr_ioctl,
+	.open = rproc_cdev_open,
 	.release = rproc_cdev_release,
 };
 
diff --git a/drivers/remoteproc/remoteproc_core.c b/drivers/remoteproc/remoteproc_core.c
index f003be00..690f361d 100644
--- a/drivers/remoteproc/remoteproc_core.c
+++ b/drivers/remoteproc/remoteproc_core.c
@@ -19,6 +19,7 @@
 #include <asm/byteorder.h>
 #include <linux/delay.h>
 #include <linux/device.h>
+#include <linux/dma-buf.h>
 #include <linux/dma-mapping.h>
 #include <linux/elf.h>
 #include <linux/firmware.h>
@@ -890,6 +891,145 @@ void rproc_add_carveout(struct rproc *rproc, struct rproc_mem_entry *mem)
 }
 EXPORT_SYMBOL(rproc_add_carveout);
 
+static struct rproc_dmabuf_entry *rproc_find_entry_for_dmabuf(struct rproc *rproc,
+							      struct dma_buf *dmabuf)
+{
+	struct rproc_dmabuf_entry *dmabuf_entry;
+
+	list_for_each_entry(dmabuf_entry, &rproc->dmabufs, node) {
+		if (dmabuf_entry->dmabuf == dmabuf)
+			return dmabuf_entry;
+	}
+
+	return NULL;
+}
+
+int rproc_dmabuf_get_da(struct rproc *rproc, struct dma_buf *dmabuf, dma_addr_t *dma)
+{
+	struct rproc_dmabuf_entry *dmabuf_entry;
+	int ret = 0;
+
+	mutex_lock(&rproc->lock);
+
+	dmabuf_entry = rproc_find_entry_for_dmabuf(rproc, dmabuf);
+	if (!dmabuf_entry) {
+		ret = -EINVAL;
+		goto out_unlock;
+	}
+
+	*dma = dmabuf_entry->dma;
+
+out_unlock:
+	mutex_unlock(&rproc->lock);
+	return ret;
+}
+EXPORT_SYMBOL(rproc_dmabuf_get_da);
+
+/**
+ * rproc_attach_dmabuf() - attach a DMA-BUF to rproc device
+ * @rproc: rproc handle
+ * @dmabuf: DMA-BUF to register
+ *
+ * This function attaches and maps the specified DMA-BUF to this rproc.
+ */
+int rproc_attach_dmabuf(struct rproc *rproc, struct dma_buf *dmabuf)
+{
+	struct rproc_dmabuf_entry *dmabuf_entry;
+	struct device *dev = &rproc->dev;
+	struct dma_buf_attachment *attachment;
+	struct sg_table *sgt;
+	int ret;
+
+	mutex_lock(&rproc->lock);
+
+	dmabuf_entry = rproc_find_entry_for_dmabuf(rproc, dmabuf);
+	if (dmabuf_entry) {
+		dmabuf_entry->refcount++;
+		mutex_unlock(&rproc->lock);
+		return 0;
+	}
+
+	attachment = dma_buf_attach(dmabuf, dev);
+	if (IS_ERR(attachment)) {
+		ret = PTR_ERR(attachment);
+		goto out_unlock;
+	}
+
+	sgt = dma_buf_map_attachment_unlocked(attachment, DMA_BIDIRECTIONAL);
+	if (IS_ERR(sgt)) {
+		ret = PTR_ERR(sgt);
+		goto fail_detach;
+	}
+
+	if (sgt->orig_nents != 1) {
+		dev_err(dev, "DMA-BUF not contiguous\n");
+		ret = -EINVAL;
+		goto fail_unmap;
+	}
+
+	dmabuf_entry = kzalloc(sizeof(*dmabuf_entry), GFP_KERNEL);
+	if (!dmabuf_entry) {
+		ret = -ENOMEM;
+		goto fail_unmap;
+	}
+
+	dmabuf_entry->len = sg_dma_len(sgt->sgl);
+	dmabuf_entry->dma = sg_dma_address(sgt->sgl);
+	dmabuf_entry->dmabuf = dmabuf;
+	dmabuf_entry->attachment = attachment;
+	dmabuf_entry->sgt = sgt;
+	dmabuf_entry->refcount = 1;
+
+	list_add_tail(&dmabuf_entry->node, &rproc->dmabufs);
+
+	mutex_unlock(&rproc->lock);
+	return 0;
+
+fail_unmap:
+	dma_buf_unmap_attachment_unlocked(attachment, sgt, DMA_BIDIRECTIONAL);
+fail_detach:
+	dma_buf_detach(dmabuf, attachment);
+out_unlock:
+	mutex_unlock(&rproc->lock);
+	return ret;
+}
+EXPORT_SYMBOL(rproc_attach_dmabuf);
+
+static void rproc_release_dmabuf(struct rproc *rproc,
+				 struct rproc_dmabuf_entry *dmabuf_entry)
+{
+	if (dmabuf_entry->attachment && dmabuf_entry->sgt)
+		dma_buf_unmap_attachment_unlocked(dmabuf_entry->attachment,
+						  dmabuf_entry->sgt, DMA_BIDIRECTIONAL);
+	if (dmabuf_entry->dmabuf && dmabuf_entry->attachment)
+		dma_buf_detach(dmabuf_entry->dmabuf, dmabuf_entry->attachment);
+	list_del(&dmabuf_entry->node);
+	kfree(dmabuf_entry);
+}
+
+int rproc_detach_dmabuf(struct rproc *rproc, struct dma_buf *dmabuf)
+{
+	struct rproc_dmabuf_entry *dmabuf_entry;
+	int ret = 0;
+
+	mutex_lock(&rproc->lock);
+
+	dmabuf_entry = rproc_find_entry_for_dmabuf(rproc, dmabuf);
+	if (!dmabuf_entry) {
+		ret = -EINVAL;
+		goto out_unlock;
+	}
+
+	dmabuf_entry->refcount--;
+	if (dmabuf_entry->refcount < 1)
+		rproc_release_dmabuf(rproc, dmabuf_entry);
+
+out_unlock:
+	mutex_unlock(&rproc->lock);
+	return ret;
+}
+EXPORT_SYMBOL(rproc_detach_dmabuf);
+
 /**
  * rproc_mem_entry_init() - allocate and initialize rproc_mem_entry struct
  * @dev: pointer on device struct
@@ -1211,6 +1351,7 @@ static int rproc_alloc_registered_carveouts(struct rproc *rproc)
 void rproc_resource_cleanup(struct rproc *rproc)
 {
 	struct rproc_mem_entry *entry, *tmp;
+	struct rproc_dmabuf_entry *dmabuf, *dtmp;
 	struct rproc_debug_trace *trace, *ttmp;
 	struct rproc_vdev *rvdev, *rvtmp;
 	struct device *dev = &rproc->dev;
@@ -1246,6 +1387,10 @@ void rproc_resource_cleanup(struct rproc *rproc)
 		kfree(entry);
 	}
 
+	/* clean up dmabufs */
+	list_for_each_entry_safe(dmabuf, dtmp, &rproc->dmabufs, node)
+		rproc_release_dmabuf(rproc, dmabuf);
+
 	/* clean up remote vdev entries */
 	list_for_each_entry_safe(rvdev, rvtmp, &rproc->rvdevs, node)
 		platform_device_unregister(rvdev->pdev);
@@ -2483,6 +2628,17 @@ struct rproc *rproc_alloc(struct device *dev, const char *name,
 		goto put_device;
 	}
 
+	/* Make device dma capable by inheriting from parent's capabilities */
+	if (dma_coerce_mask_and_coherent(&rproc->dev, dma_get_mask(rproc->dev.parent)))
+		dev_warn(&rproc->dev, "Failed to set DMA mask. Trying to continue...\n");
+	rproc->dev.dma_parms = &rproc->dma_parms;
+	/*
+	 * We could use dma_get_max_seg_size(rproc->dev.parent) here but the
+	 * parent is not usually setup correctly either, use full 32bit mask
+	 * for now.
+	 */
+	dma_set_max_seg_size(&rproc->dev, DMA_BIT_MASK(32));
+
 	rproc->name = kstrdup_const(name, GFP_KERNEL);
 	if (!rproc->name)
 		goto put_device;
@@ -2500,6 +2656,7 @@ struct rproc *rproc_alloc(struct device *dev, const char *name,
 	mutex_init(&rproc->lock);
 
 	INIT_LIST_HEAD(&rproc->carveouts);
+	INIT_LIST_HEAD(&rproc->dmabufs);
 	INIT_LIST_HEAD(&rproc->mappings);
 	INIT_LIST_HEAD(&rproc->traces);
 	INIT_LIST_HEAD(&rproc->rvdevs);
diff --git a/drivers/remoteproc/remoteproc_internal.h b/drivers/remoteproc/remoteproc_internal.h
index 0a5e1574..5a789774 100644
--- a/drivers/remoteproc/remoteproc_internal.h
+++ b/drivers/remoteproc/remoteproc_internal.h
@@ -14,8 +14,12 @@
 
 #include <linux/irqreturn.h>
 #include <linux/firmware.h>
+#include <linux/dma-mapping.h>
 
+struct dma_buf;
+struct dma_buf_attachment;
 struct rproc;
+struct sg_table;
 
 struct rproc_debug_trace {
 	struct rproc *rproc;
@@ -39,6 +43,28 @@ struct rproc_vdev_data {
 	struct fw_rsc_vdev *rsc;
 };
 
+/**
+ * struct rproc_dmabuf_entry - DMA-BUF attachment descriptor
+ * @len: length, in bytes
+ * @dma: DMA address
+ * @da: device address
+ * @dmabuf: attached DMA-BUF
+ * @attachment: DMA-BUF attachment
+ * @sgt: mapped scatterlist table
+ * @refcount: number of users of this attachment
+ * @node: list node
+ */
+struct rproc_dmabuf_entry {
+	size_t len;
+	dma_addr_t dma;
+	u32 da;
+	struct dma_buf *dmabuf;
+	struct dma_buf_attachment *attachment;
+	struct sg_table *sgt;
+	size_t refcount;
+	struct list_head node;
+};
+
 static inline bool rproc_has_feature(struct rproc *rproc, unsigned int feature)
 {
 	return test_bit(feature, rproc->features);
