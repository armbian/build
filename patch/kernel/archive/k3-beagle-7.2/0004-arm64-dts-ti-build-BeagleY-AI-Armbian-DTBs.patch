From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei1998@gmail.com>
Date: Thu, 23 Jul 2026 12:45:00 -0500
Subject: [PATCH] arm64: dts: ti: build BeagleY-AI Armbian DTBs

Build the directly managed BeagleY-AI camera and EdgeAI overlays, plus
complete composed DTBs for the K3 boot path that loads one DTB and does not
apply overlays at boot.

Signed-off-by: Andrei Aldea <andrei1998@gmail.com>
---
 arch/arm64/boot/dts/ti/Makefile | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/arch/arm64/boot/dts/ti/Makefile b/arch/arm64/boot/dts/ti/Makefile
--- a/arch/arm64/boot/dts/ti/Makefile
+++ b/arch/arm64/boot/dts/ti/Makefile
@@ -186,3 +186,13 @@
 # Boards with J722s SoC
 dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai.dtb
+dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai-csi0-imx219.dtbo
+dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai-edgeai-apps.dtbo
+k3-am67a-beagley-ai-edgeai-dtbs := k3-am67a-beagley-ai.dtb \
+	 k3-am67a-beagley-ai-edgeai-apps.dtbo
+dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai-edgeai.dtb
+k3-am67a-beagley-ai-edgeai-csi0-imx219-dtbs := \
+	 k3-am67a-beagley-ai.dtb \
+	 k3-am67a-beagley-ai-edgeai-apps.dtbo \
+	 k3-am67a-beagley-ai-csi0-imx219.dtbo
+dtb-$(CONFIG_ARCH_K3) += k3-am67a-beagley-ai-edgeai-csi0-imx219.dtb
 dtb-$(CONFIG_ARCH_K3) += k3-j722s-evm.dtb
