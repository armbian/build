From 9a330cbf17f27e86f2fdac82c870e46f10731ed3 Mon Sep 17 00:00:00 2001
From: Swamil Jain <s-jain1@ti.com>
Date: Wed, 8 Jul 2026 15:23:00 +0530
Subject: [PATCH 18/20] PENDING: drm/tidss: Fix DPI0_CLK_CTRL_DATA_CLK_INVDIS
 bitfield setting

DPI0_CLK_CTRL_DATA_CLK_INVDIS bitfield value should be set opposite to
the ipc bit for video ports with DPI output, which was being set wrongly.
Check for video port with DPI output and set the values correctly.

Fixes: 653460b9520d ("FROMLIST: drm/tidss: Fix sampling edge configuration")
Reviewed-by: Devarsh Thakkar <devarsht@ti.com>
Signed-off-by: Swamil Jain <s-jain1@ti.com>
---
 drivers/gpu/drm/tidss/tidss_dispc.c      | 11 +++++------
 drivers/gpu/drm/tidss/tidss_dispc_regs.h |  4 ++++
 2 files changed, 9 insertions(+), 6 deletions(-)

diff --git a/drivers/gpu/drm/tidss/tidss_dispc.c b/drivers/gpu/drm/tidss/tidss_dispc.c
index b398ba5f..0f00c757 100644
--- a/drivers/gpu/drm/tidss/tidss_dispc.c
+++ b/drivers/gpu/drm/tidss/tidss_dispc.c
@@ -1202,12 +1202,11 @@ void dispc_vp_prepare(struct dispc_device *dispc, u32 hw_videoport,
 		       FIELD_PREP(DISPC_VP_SIZE_SCREEN_VDISPLAY_MASK,
 				  mode->crtc_vdisplay - 1));
 
-	if (dispc->clk_ctrl) {
-		regmap_update_bits(dispc->clk_ctrl, 0, 0x100,
-				   ipc ? 0x100 : 0x000);
-		regmap_update_bits(dispc->clk_ctrl, 0, 0x200,
-				   rf ? 0x200 : 0x000);
-	}
+	if (dispc->clk_ctrl &&
+	    dispc->feat->vp_bus_type[hw_videoport] == DISPC_VP_DPI)
+		regmap_write(dispc->clk_ctrl, 0x0,
+			     (!ipc ? DPI0_CLK_CTRL_DATA_CLK_INVDIS : 0) |
+			     (rf ? DPI0_CLK_CTRL_SYNC_CLK_INVDIS : 0));
 }
 
 void dispc_vp_enable(struct dispc_device *dispc, u32 hw_videoport)
diff --git a/drivers/gpu/drm/tidss/tidss_dispc_regs.h b/drivers/gpu/drm/tidss/tidss_dispc_regs.h
index 382027dd..4cdde24d 100644
--- a/drivers/gpu/drm/tidss/tidss_dispc_regs.h
+++ b/drivers/gpu/drm/tidss/tidss_dispc_regs.h
@@ -333,4 +333,8 @@ enum oldi_mode_reg_val { SPWG_18 = 0, JEIDA_24 = 1, SPWG_24 = 2 };
 
 #define AM65X_OLDI_PWRDN_TX		BIT(8)
 
+/* Bits in the MAIN_CTRL_MMR_CFG0_DPI0_CLK_CTRL register */
+#define DPI0_CLK_CTRL_DATA_CLK_INVDIS BIT(8)
+#define DPI0_CLK_CTRL_SYNC_CLK_INVDIS BIT(9)
+
 #endif /* __TIDSS_DISPC_REGS_H */
-- 
2.53.0

