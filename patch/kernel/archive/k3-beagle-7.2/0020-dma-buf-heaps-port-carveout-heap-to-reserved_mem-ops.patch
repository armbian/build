From a00e2f248a354b4782203480f4bf56436fe2d6ca Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei1998@gmail.com>
Date: Wed, 22 Jul 2026 21:09:45 -0500
Subject: [PATCH 20/20] dma-buf: heaps: port carveout heap to reserved_mem ops

Linux 7.2 removed fdt_node from struct reserved_mem and passes the flat-tree node to the node_init callback instead. Record the no-map property during node initialization and register the carveout heap through struct reserved_mem_ops.
---
 drivers/dma-buf/heaps/carveout-heap.c | 18 ++++++++++++++----
 1 file changed, 14 insertions(+), 4 deletions(-)

diff --git a/drivers/dma-buf/heaps/carveout-heap.c b/drivers/dma-buf/heaps/carveout-heap.c
index 87f9a21e..fc3a8f90 100644
--- a/drivers/dma-buf/heaps/carveout-heap.c
+++ b/drivers/dma-buf/heaps/carveout-heap.c
@@ -361,6 +361,7 @@ static int carveout_dma_heap_export(phys_addr_t base, size_t size, const char *n
 
 #define MAX_HEAP_AREAS 7
 static struct reserved_mem heap_areas[MAX_HEAP_AREAS];
+static bool heap_area_cached[MAX_HEAP_AREAS];
 static size_t heap_area_count;
 
 static int __init carveout_dma_heap_init_areas(void)
@@ -369,8 +370,8 @@ static int __init carveout_dma_heap_init_areas(void)
 
 	for (i = 0; i < heap_area_count; i++) {
 		struct reserved_mem *rmem = &heap_areas[i];
-		bool cached = !of_get_flat_dt_prop(rmem->fdt_node, "no-map", NULL);
-		int ret = carveout_dma_heap_export(rmem->base, rmem->size, rmem->name, cached);
+		int ret = carveout_dma_heap_export(rmem->base, rmem->size,
+						   rmem->name, heap_area_cached[i]);
 		if (ret) {
 			pr_err("Carveout Heap: could not export as DMA-Heap\n");
 			return ret;
@@ -381,7 +382,8 @@ static int __init carveout_dma_heap_init_areas(void)
 }
 fs_initcall(carveout_dma_heap_init_areas);
 
-static int __init rmem_dma_heap_carveout_setup(struct reserved_mem *rmem)
+static int __init rmem_dma_heap_carveout_setup(unsigned long fdt_node,
+					       struct reserved_mem *rmem)
 {
 	phys_addr_t align = PAGE_SIZE;
 	phys_addr_t mask = align - 1;
@@ -402,10 +404,18 @@ static int __init rmem_dma_heap_carveout_setup(struct reserved_mem *rmem)
 	 * subsystems (like slab allocator) are available.
 	 */
 	heap_areas[heap_area_count] = *rmem;
+	heap_area_cached[heap_area_count] =
+		!of_get_flat_dt_prop(fdt_node, "no-map", NULL);
 	heap_area_count++;
 
 	return 0;
 }
-RESERVEDMEM_OF_DECLARE(dma_heap_carveout, "dma-heap-carveout", rmem_dma_heap_carveout_setup);
+
+static const struct reserved_mem_ops rmem_dma_heap_carveout_ops = {
+	.node_init = rmem_dma_heap_carveout_setup,
+};
+
+RESERVEDMEM_OF_DECLARE(dma_heap_carveout, "dma-heap-carveout",
+			       &rmem_dma_heap_carveout_ops);
 
 #endif
-- 
