From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: SuperKali <hello@superkali.me>
Date: Fri, 17 Jul 2026 12:00:00 +0000
Subject: arm64: dts: qcom: sc8280xp: add QUP pinctrl states for Dragon Q8B

The v7.1 SC8280XP dtsi ships only qup_uart18_default, so i2c12, i2c21,
uart17 and uart2 have no pin mux and the Q8B enables those buses with
nothing for pinctrl-0 to point at. Add the four tlmm states (qup12/qup21
for the I2C pairs, qup2/qup17 for the UART groups) and wire the uart17
and uart2 defaults in the dtsi, leaving the board i2c references in the
board dts. Only the buses the Q8B uses are added.

Signed-off-by: SuperKali <hello@superkali.me>
---
 arch/arm64/boot/dts/qcom/sc8280xp.dtsi | 74 ++++++++++
 1 file changed, 74 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/sc8280xp.dtsi b/arch/arm64/boot/dts/qcom/sc8280xp.dtsi
index 111111111111..222222222222 100644
--- a/arch/arm64/boot/dts/qcom/sc8280xp.dtsi
+++ b/arch/arm64/boot/dts/qcom/sc8280xp.dtsi
@@ -1058,6 +1058,10 @@ uart17: serial@884000 {
 				interconnects = <&clk_virt MASTER_QUP_CORE_2 0 &clk_virt SLAVE_QUP_CORE_2 0>,
 						<&gem_noc MASTER_APPSS_PROC 0 &config_noc SLAVE_QUP_2 0>;
 				interconnect-names = "qup-core", "qup-config";
+
+				pinctrl-0 = <&qup_uart17_default>;
+				pinctrl-names = "default";
+
 				status = "disabled";
 			};
 
@@ -1527,6 +1531,10 @@ uart2: serial@988000 {
 				interconnects = <&clk_virt MASTER_QUP_CORE_0 0 &clk_virt SLAVE_QUP_CORE_0 0>,
 						<&gem_noc MASTER_APPSS_PROC 0 &config_noc SLAVE_QUP_0 0>;
 				interconnect-names = "qup-core", "qup-config";
+
+				pinctrl-0 = <&qup_uart2_default>;
+				pinctrl-names = "default";
+
 				status = "disabled";
 			};
 
@@ -5600,6 +5608,72 @@ cci3_i2c1_sleep: cci3-i2c1-sleep-pins {
 				};
 			};
 
+			qup_i2c12_data_clk: qup-i2c12-data-clk-state {
+				pins = "gpio0", "gpio1";
+				function = "qup12";
+			};
+
+			qup_i2c21_data_clk: qup-i2c21-data-clk-state {
+				pins = "gpio81", "gpio82";
+				function = "qup21";
+			};
+
+			qup_uart2_default: qup-uart2-default-state {
+				cts-pins {
+					pins = "gpio121";
+					function = "qup2";
+					bias-bus-hold;
+				};
+
+				rts-pins {
+					pins = "gpio122";
+					function = "qup2";
+					drive-strength = <2>;
+					bias-disable;
+				};
+
+				tx-pins {
+					pins = "gpio123";
+					function = "qup2";
+					drive-strength = <2>;
+					bias-disable;
+				};
+
+				rx-pins {
+					pins = "gpio124";
+					function = "qup2";
+					bias-pull-up;
+				};
+			};
+
+			qup_uart17_default: qup-uart17-default-state {
+				cts-pins {
+					pins = "gpio61";
+					function = "qup17";
+					bias-bus-hold;
+				};
+
+				rts-pins {
+					pins = "gpio62";
+					function = "qup17";
+					drive-strength = <2>;
+					bias-disable;
+				};
+
+				tx-pins {
+					pins = "gpio63";
+					function = "qup17";
+					drive-strength = <2>;
+					bias-disable;
+				};
+
+				rx-pins {
+					pins = "gpio64";
+					function = "qup17";
+					bias-pull-up;
+				};
+			};
+
 			qup_uart18_default: qup-uart18-default-state {
 				cts-pins {
 					pins = "gpio66";
-- 
