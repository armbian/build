From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: SuperKali <hello@superkali.me>
Date: Fri, 17 Jul 2026 19:59:42 +0200
Subject: PCI/pwrctrl: tc9563: add AXI half-frequency support

The TC9563/QPS615 switch runs its internal AXI bus at 250 MHz by default,
a margin the Q8B does not meet reliably, so the board marks the pwrctrl
node toshiba,axi-bus-frequency-half to run at 125 MHz. Parse the property
at probe and program NBUSCTRL.FREQ_HALF over the pre-link I2C config
before the final reset deassertion. Boards without it keep the default
sequence.

Signed-off-by: SuperKali <hello@superkali.me>
---
 drivers/pci/pwrctrl/pci-pwrctrl-tc9563.c | 22 ++++++++++
 1 file changed, 22 insertions(+)

diff --git a/drivers/pci/pwrctrl/pci-pwrctrl-tc9563.c b/drivers/pci/pwrctrl/pci-pwrctrl-tc9563.c
index 111111111111..222222222222 100644
--- a/drivers/pci/pwrctrl/pci-pwrctrl-tc9563.c
+++ b/drivers/pci/pwrctrl/pci-pwrctrl-tc9563.c
@@ -24,6 +24,9 @@
 
 #include "../pci.h"
 
+#define TC9563_NBUSCTRL			0x801014
+#define TC9563_NBUSCTRL_FREQ_HALF	BIT(16)
+
 #define TC9563_GPIO_CONFIG		0x801208
 #define TC9563_RESET_GPIO		0x801210
 
@@ -112,6 +115,7 @@ struct tc9563_pwrctrl {
 	struct gpio_desc *reset_gpio;
 	struct i2c_adapter *adapter;
 	struct i2c_client *client;
+	bool axi_bus_frequency_half;
 };
 
 /*
@@ -416,6 +420,15 @@ static int tc9563_pwrctrl_assert_deassert_reset(struct tc9563_pwrctrl *tc9563,
 	return tc9563_pwrctrl_i2c_write(tc9563->client, TC9563_RESET_GPIO, val);
 }
 
+static int tc9563_pwrctrl_set_axi_bus_frequency(struct tc9563_pwrctrl *tc9563)
+{
+	if (!tc9563->axi_bus_frequency_half)
+		return 0;
+
+	return tc9563_pwrctrl_i2c_write(tc9563->client, TC9563_NBUSCTRL,
+					TC9563_NBUSCTRL_FREQ_HALF);
+}
+
 static int tc9563_pwrctrl_parse_device_dt(struct tc9563_pwrctrl *tc9563,
 					  struct device_node *node,
 					  enum tc9563_pwrctrl_ports port)
@@ -483,6 +496,12 @@ static int tc9563_pwrctrl_power_on(struct pci_pwrctrl *pwrctrl)
 	if (ret)
 		goto power_off;
 
+	ret = tc9563_pwrctrl_set_axi_bus_frequency(tc9563);
+	if (ret) {
+		dev_err(dev, "Setting AXI bus frequency failed\n");
+		goto power_off;
+	}
+
 	for (i = 0; i < TC9563_MAX; i++) {
 		cfg = &tc9563->cfg[i];
 		ret = tc9563_pwrctrl_disable_port(tc9563, i);
@@ -579,6 +598,9 @@ static int tc9563_pwrctrl_probe(struct platform_device *pdev)
 
 	pci_pwrctrl_init(&tc9563->pwrctrl, dev);
 
+	tc9563->axi_bus_frequency_half =
+		of_property_read_bool(node, "toshiba,axi-bus-frequency-half");
+
 	port = TC9563_USP;
 	ret = tc9563_pwrctrl_parse_device_dt(tc9563, node, port);
 	if (ret) {
-- 
