From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: SuperKali <hello@superkali.me>
Date: Fri, 17 Jul 2026 00:00:00 +0000
Subject: arm64: dts: qcom: sc8280xp: correct GPI DMA0 channel count

gpi_dma0 describes 13 GPII channels, but gpi_dma1, gpi_dma2 and the
Qualcomm reference device tree describe 12 over the same 0x60000 window.
Drop the surplus 13th channel, its GIC_SPI 256 interrupt and the extra
channel-mask bit.

Fixes: 71b12166a2be ("arm64: dts: qcom: sc8280xp: Describe GPI DMA controller nodes")
Signed-off-by: SuperKali <hello@superkali.me>
---
 arch/arm64/boot/dts/qcom/sc8280xp.dtsi | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/boot/dts/qcom/sc8280xp.dtsi b/arch/arm64/boot/dts/qcom/sc8280xp.dtsi
index 111111111111..222222222222 100644
--- a/arch/arm64/boot/dts/qcom/sc8280xp.dtsi
+++ b/arch/arm64/boot/dts/qcom/sc8280xp.dtsi
@@ -1359,11 +1359,10 @@ gpi_dma0: dma-controller@900000 {
 				     <GIC_SPI 252 IRQ_TYPE_LEVEL_HIGH>,
 				     <GIC_SPI 253 IRQ_TYPE_LEVEL_HIGH>,
 				     <GIC_SPI 254 IRQ_TYPE_LEVEL_HIGH>,
-				     <GIC_SPI 255 IRQ_TYPE_LEVEL_HIGH>,
-				     <GIC_SPI 256 IRQ_TYPE_LEVEL_HIGH>;
+				     <GIC_SPI 255 IRQ_TYPE_LEVEL_HIGH>;
 
-			dma-channels = <13>;
-			dma-channel-mask = <0x1fff>;
+			dma-channels = <12>;
+			dma-channel-mask = <0xfff>;
 			#dma-cells = <3>;
 
 			iommus = <&apps_smmu 0x576 0x0>;
-- 
Armbian

