From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: TheSnowfield <thesnowfield@sakurapi.org>
Date: Wed, 4 Mar 2026 18:21:14 +0800
Subject: Enable vop panel output for Sakura Pi RK3308B

Signed-off-by: TheSnowfield <thesnowfield@sakurapi.org>
---
 arch/arm64/boot/dts/rockchip/rk3308-sakurapi-rk3308b.dts | 44 ++++++++++
 1 file changed, 44 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk3308-sakurapi-rk3308b.dts b/arch/arm64/boot/dts/rockchip/rk3308-sakurapi-rk3308b.dts
index 111111111111..222222222222 100644
--- a/arch/arm64/boot/dts/rockchip/rk3308-sakurapi-rk3308b.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3308-sakurapi-rk3308b.dts
@@ -115,6 +115,32 @@ sdio_pwrseq: sdio-pwrseq {
 		 */
 		reset-gpios = <&gpio0 RK_PA2 GPIO_ACTIVE_LOW>;
 	};
+
+	backlight: backlight {
+		status = "okay";
+		compatible = "pwm-backlight";
+		pwms = <&pwm3 0 25000 0>;
+		brightness-levels = <0 255>;
+		default-brightness-level = <255>;
+	};
+
+	display: panel {
+		compatible = "edt,et070080dh6";
+		backlight = <&backlight>;
+		enable-gpios = <&gpio0 RK_PB0 GPIO_ACTIVE_HIGH>;
+		enable-delay-ms = <20>;
+		status = "okay";
+
+		panel_in: port {
+			#address-cells = <1>;
+			#size-cells = <0>;
+
+			panel_in_rgb: endpoint {
+				reg = <0>;
+				remote-endpoint = <&vop_out_rgb>;
+			};
+		};
+	};
 };
 
 &cpu0 {
@@ -183,6 +209,24 @@ &saradc {
 	status = "okay";
 };
 
+&vop {
+	status = "okay";
+
+	vop_out: port {
+		#address-cells = <1>;
+		#size-cells = <0>;
+
+		vop_out_rgb: endpoint@0 {
+			reg = <0>;
+			remote-endpoint = <&panel_in_rgb>;
+		};
+	};
+};
+
+&display_subsystem {
+	status = "okay";
+};
+
 &sdio {
 	#address-cells = <1>;
 	#size-cells = <0>;
-- 
Armbian

