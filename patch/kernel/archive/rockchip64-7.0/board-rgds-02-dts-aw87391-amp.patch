From: crackerjacques <jack@supremeoverlordjabs.co>
Subject: [PATCH] arm64: dts: rockchip: rk3568-anbernic-rg-ds: wire up aw87391 speaker amps

The mainline RG DS device tree leaves the two awinic aw87391 speaker
amplifiers (i2c2 0x58/0x5b) as comments because the driver is not in
mainline. Add the amp nodes, their vcc_amp enable regulator and pinmux,
and the simple-audio-card aux-devs so the internal speakers are driven.
Pairs with the in-tree aw87391 ASoC driver (board-rgds aw87391 patch).
Headphones already work via the rk817 codec; only the speaker amps were
missing.

Signed-off-by: crackerjacques <jack@supremeoverlordjabs.co>

--- a/arch/arm64/boot/dts/rockchip/rk3568-anbernic-rg-ds.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3568-anbernic-rg-ds.dts
@@ -348,6 +348,20 @@
 		pinctrl-names = "default";
 		post-power-on-delay-ms = <200>;
 		reset-gpios = <&gpio4 RK_PA2 GPIO_ACTIVE_LOW>;
+	};
+
+	vcc_amp: regulator-vcc-amp {
+		compatible = "regulator-fixed";
+		enable-active-high;
+		gpio = <&gpio4 RK_PC3 GPIO_ACTIVE_HIGH>;
+		pinctrl-0 = <&vcc_amp_h>;
+		pinctrl-names = "default";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-name = "vcc_amp";
+		regulator-state-mem {
+			regulator-off-in-suspend;
+		};
 	};
 
 	sound {
@@ -357,6 +371,7 @@
 		simple-audio-card,format = "i2s";
 		simple-audio-card,hp-det-gpios = <&gpio4 RK_PC2 GPIO_ACTIVE_HIGH>;
 		simple-audio-card,mclk-fs = <256>;
+		simple-audio-card,aux-devs = <&aw87391_pa_l>, <&aw87391_pa_r>;
 		simple-audio-card,name = "rk817_ext";
 		simple-audio-card,pin-switches = "Internal Speakers";
 		simple-audio-card,routing =
@@ -840,8 +855,19 @@
 	pinctrl-names = "default";
 	status = "okay";
 
-	/* awinic,aw87391 at 0x58 */
-	/* awinic,aw87391 at 0x5b */
+	aw87391_pa_l: audio-codec@58 {
+		compatible = "aw,aw87391-left";
+		reg = <0x58>;
+		sound-name-prefix = "Left AMP";
+		vcc-supply = <&vcc_amp>;
+	};
+
+	aw87391_pa_r: audio-codec@5b {
+		compatible = "aw,aw87391-right";
+		reg = <0x5b>;
+		sound-name-prefix = "Right AMP";
+		vcc-supply = <&vcc_amp>;
+	};
 	/* invensense,icm42607p at 0x68 */
 };
 
@@ -903,6 +929,13 @@
 };
 
 &pinctrl {
+	vcc-amp {
+		vcc_amp_h: vcc-amp-h {
+			rockchip,pins =
+				<4 RK_PC3 RK_FUNC_GPIO &pcfg_pull_none>;
+		};
+	};
+
 	gpio-keys {
 		vol_keys_l: vol-keys_l {
 			rockchip,pins =
