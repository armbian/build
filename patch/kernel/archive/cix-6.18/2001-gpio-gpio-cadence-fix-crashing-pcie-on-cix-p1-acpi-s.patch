From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Jianfeng Liu <Jianfeng.Liu@cixtech.com>
Date: Mon, 16 Mar 2026 19:04:34 +0800
Subject: gpio: gpio-cadence: fix crashing pcie on cix p1 acpi system

---
 drivers/gpio/gpio-cadence.c | 83 ++++++++--
 1 file changed, 67 insertions(+), 16 deletions(-)

diff --git a/drivers/gpio/gpio-cadence.c b/drivers/gpio/gpio-cadence.c
index 111111111111..222222222222 100644
--- a/drivers/gpio/gpio-cadence.c
+++ b/drivers/gpio/gpio-cadence.c
@@ -40,6 +40,15 @@
 #define SKY1_SIP_GPIO_PDC		0xC2000009
 #define SKY1_SIP_GPIO_PDC_SET_WAKE	0x02
 
+struct cdns_gpio_soc_data {
+	bool has_sky1_pdc;
+	/*
+	 * Preserve firmware configuration on platforms where GPIO pins/bypass
+	 * may already be configured for critical board functions.
+	 */
+	bool preserve_firmware_config;
+};
+
 struct cdns_gpio_saved_regs {
 	u32 bypass_mode;
 	u32 direction_mode;
@@ -59,6 +68,7 @@ struct cdns_gpio_chip {
 	struct reset_control *rst;
 	u32 wake_active;
 	u32 hw_irq;
+	bool preserve_firmware_config;
 	bool has_sky1_pdc;
 	struct cdns_gpio_saved_regs saved_regs;
 };
@@ -221,6 +231,7 @@ static void cdns_gpio_save_regs(struct cdns_gpio_chip *cgpio)
 
 static void cdns_gpio_restore_regs(struct cdns_gpio_chip *cgpio)
 {
+	u32 all;
 	/* Disable all IRQs before restore to prevent spurious firing */
 	iowrite32(GENMASK(cgpio->gen_gc.gc.ngpio - 1, 0),
 		  cgpio->regs + CDNS_GPIO_IRQ_DIS);
@@ -232,8 +243,13 @@ static void cdns_gpio_restore_regs(struct cdns_gpio_chip *cgpio)
 	iowrite32(cgpio->saved_regs.irq_type, cgpio->regs + CDNS_GPIO_IRQ_TYPE);
 	iowrite32(cgpio->saved_regs.irq_value, cgpio->regs + CDNS_GPIO_IRQ_VALUE);
 	iowrite32(cgpio->saved_regs.irq_any_edge, cgpio->regs + CDNS_GPIO_IRQ_ANY_EDGE);
-	/* IRQ_EN is write-to-set: re-enable only previously enabled IRQs */
-	iowrite32(~cgpio->saved_regs.irq_en, cgpio->regs + CDNS_GPIO_IRQ_EN);
+	/*
+	 * IRQ_EN is write-to-set.
+	 * saved_regs.irq_en stores IRQ_MASK (1 = masked). Re-enable only
+	 * previously unmasked IRQs, constrained to implemented GPIO width.
+	 */
+	all = GENMASK(cgpio->gen_gc.gc.ngpio - 1, 0);
+	iowrite32((~cgpio->saved_regs.irq_en) & all, cgpio->regs + CDNS_GPIO_IRQ_EN);
 }
 
 static void cdns_gpio_sky1_set_wake(struct cdns_gpio_chip *cgpio, bool suspend)
@@ -251,11 +267,12 @@ static void cdns_gpio_sky1_set_wake(struct cdns_gpio_chip *cgpio, bool suspend)
 static int cdns_gpio_suspend(struct device *dev)
 {
 	struct cdns_gpio_chip *cgpio = dev_get_drvdata(dev);
+	u32 all = GENMASK(cgpio->gen_gc.gc.ngpio - 1, 0);
 
 	cdns_gpio_save_regs(cgpio);
 
 	/* Mask non-wake interrupts */
-	iowrite32(~cgpio->wake_active, cgpio->regs + CDNS_GPIO_IRQ_DIS);
+	iowrite32(all & ~cgpio->wake_active, cgpio->regs + CDNS_GPIO_IRQ_DIS);
 
 	cdns_gpio_sky1_set_wake(cgpio, true);
 
@@ -289,9 +306,10 @@ static int cdns_gpio_resume(struct device *dev)
 static void cdns_gpio_shutdown(struct platform_device *pdev)
 {
 	struct cdns_gpio_chip *cgpio = platform_get_drvdata(pdev);
+	u32 all = GENMASK(cgpio->gen_gc.gc.ngpio - 1, 0);
 
 	/* Mask non-wake interrupts */
-	iowrite32(~cgpio->wake_active, cgpio->regs + CDNS_GPIO_IRQ_DIS);
+	iowrite32(all & ~cgpio->wake_active, cgpio->regs + CDNS_GPIO_IRQ_DIS);
 
 	cdns_gpio_sky1_set_wake(cgpio, true);
 
@@ -308,12 +326,14 @@ static const struct dev_pm_ops cdns_gpio_pm_ops = {
 
 static int cdns_gpio_probe(struct platform_device *pdev)
 {
+	const struct cdns_gpio_soc_data *soc;
 	struct gpio_generic_chip_config config = { };
 	struct cdns_gpio_chip *cgpio;
 	int ret, irq;
 	u32 dir_prev;
 	u32 num_gpios = 32;
 	u32 io_mask = 0;
+	bool wrote_dir = false;
 
 	cgpio = devm_kzalloc(&pdev->dev, sizeof(*cgpio), GFP_KERNEL);
 	if (!cgpio)
@@ -334,8 +354,14 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 	/* Optional mask of pins that should remain inputs (hardware safety) */
 	device_property_read_u32(&pdev->dev, "gpio-io-mask", &io_mask);
 
-	/* Detect Sky1 platform for PDC wake integration */
-	cgpio->has_sky1_pdc = !!device_get_match_data(&pdev->dev);
+	soc = device_get_match_data(&pdev->dev);
+	if (soc) {
+		cgpio->has_sky1_pdc = soc->has_sky1_pdc;
+		cgpio->preserve_firmware_config = soc->preserve_firmware_config;
+	} else {
+		cgpio->has_sky1_pdc = false;
+		cgpio->preserve_firmware_config = false;
+	}
 
 	/*
 	 * Set all pins as inputs by default, otherwise:
@@ -346,8 +372,16 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 	 * Apply io_mask to force certain pins as inputs (hardware safety).
 	 */
 	dir_prev = ioread32(cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
-	iowrite32(GENMASK(num_gpios - 1, 0) & ~io_mask,
-		  cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
+	if (!cgpio->preserve_firmware_config) {
+		iowrite32(GENMASK(num_gpios - 1, 0) & ~io_mask,
+			  cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
+		wrote_dir = true;
+	} else {
+		/*
+		 * Preserve firmware pin state (direction/bypass/output).
+		 * This avoids breaking platform-critical signals.
+		 */
+	}
 
 	config.dev = &pdev->dev;
 	config.sz = 4;
@@ -438,10 +472,12 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 
 	cgpio->bypass_orig = ioread32(cgpio->regs + CDNS_GPIO_BYPASS_MODE);
 
-	/* Enable gpio outputs, ignored for input direction */
-	iowrite32(GENMASK(num_gpios - 1, 0),
-		  cgpio->regs + CDNS_GPIO_OUTPUT_EN);
-	iowrite32(0, cgpio->regs + CDNS_GPIO_BYPASS_MODE);
+	if (!cgpio->preserve_firmware_config) {
+		/* Enable gpio outputs, ignored for input direction */
+		iowrite32(GENMASK(num_gpios - 1, 0),
+			  cgpio->regs + CDNS_GPIO_OUTPUT_EN);
+		iowrite32(0, cgpio->regs + CDNS_GPIO_BYPASS_MODE);
+	}
 
 	platform_set_drvdata(pdev, cgpio);
 	return 0;
@@ -450,7 +486,8 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 	if (cgpio->pclk)
 		clk_disable_unprepare(cgpio->pclk);
 err_revert_dir:
-	iowrite32(dir_prev, cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
+	if (wrote_dir)
+		iowrite32(dir_prev, cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
 
 	return ret;
 }
@@ -467,15 +504,29 @@ static void cdns_gpio_remove(struct platform_device *pdev)
 
 static const struct of_device_id cdns_of_ids[] = {
 	{ .compatible = "cdns,gpio-r1p02" },
-	{ .compatible = "cix,sky1-gpio", .data = (void *)1 },
+	/*
+	 * DT Sky1 platform: keep existing behavior by default (no preserve),
+	 * while still enabling Sky1 PDC integration.
+	 */
+	{ .compatible = "cix,sky1-gpio",
+		.data = (void *)&(const struct cdns_gpio_soc_data){
+			.has_sky1_pdc = true,
+			.preserve_firmware_config = false,
+		},
+	},
 	{ /* sentinel */ },
 };
 MODULE_DEVICE_TABLE(of, cdns_of_ids);
 
 #ifdef CONFIG_ACPI
+static const struct cdns_gpio_soc_data sky1_acpi_soc = {
+	.has_sky1_pdc = true,
+	.preserve_firmware_config = true,
+};
+
 static const struct acpi_device_id cdns_acpi_ids[] = {
-	{ "CIXH1002", 1 },
-	{ "CIXH1003", 1 },
+	{ "CIXH1002", (kernel_ulong_t)&sky1_acpi_soc },
+	{ "CIXH1003", (kernel_ulong_t)&sky1_acpi_soc },
 	{ /* sentinel */ },
 };
 MODULE_DEVICE_TABLE(acpi, cdns_acpi_ids);
-- 
Armbian

