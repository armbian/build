From: Jianfeng Liu <Jianfeng.Liu@cixtech.com>
Date: Tue, 17 Mar 2026 17:29:25 +0800
Subject: sound: hda: add cix ipbloq hda driver

---
 sound/hda/controllers/Kconfig          |   16 +
 sound/hda/controllers/Makefile         |    2 +
 sound/hda/controllers/hda_cix_ipbloq.c | 1025 ++++++++++
 3 files changed, 1043 insertions(+)

diff --git a/sound/hda/controllers/Kconfig b/sound/hda/controllers/Kconfig
index 111111111111..222222222222 100644
--- a/sound/hda/controllers/Kconfig
+++ b/sound/hda/controllers/Kconfig
@@ -40,3 +40,19 @@ config SND_HDA_ACPI
 
 	  To compile this driver as a module, choose M here: the module
 	  will be called snd-hda-acpi.
+
+config SND_HDA_CIX_IPBLOQ
+	tristate "CIX Sky1 IPBLOQ HD Audio"
+	depends on ARCH_CIX || COMPILE_TEST
+	select SND_HDA
+	select SND_HDA_ALIGNED_MMIO
+	help
+	  Say Y here to support the HDA controller present in CIX Sky1 SoCs
+	  (used in boards like the Radxa Orion O6).
+
+	  This enables support for the IPBLOQ HD Audio controller which
+	  interfaces with Realtek ALC256/ALC269 codecs for the 3.5mm audio
+	  jack.
+
+	  To compile this driver as a module, choose M here: the module
+	  will be called snd-hda-cix-ipbloq.
diff --git a/sound/hda/controllers/Makefile b/sound/hda/controllers/Makefile
index 111111111111..222222222222 100644
--- a/sound/hda/controllers/Makefile
+++ b/sound/hda/controllers/Makefile
@@ -2,6 +2,7 @@
 snd-hda-intel-y := intel.o
 snd-hda-tegra-y := tegra.o
 snd-hda-acpi-y := acpi.o
+snd-hda-cix-ipbloq-y := hda_cix_ipbloq.o
 
 subdir-ccflags-y += -I$(src)/../common
 
@@ -11,3 +12,4 @@ CFLAGS_intel.o := -I$(src)
 obj-$(CONFIG_SND_HDA_INTEL) += snd-hda-intel.o
 obj-$(CONFIG_SND_HDA_TEGRA) += snd-hda-tegra.o
 obj-$(CONFIG_SND_HDA_ACPI) += snd-hda-acpi.o
+obj-$(CONFIG_SND_HDA_CIX_IPBLOQ) += snd-hda-cix-ipbloq.o
