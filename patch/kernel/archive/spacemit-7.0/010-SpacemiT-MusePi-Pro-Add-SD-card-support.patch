From eedc54e1ac907748632bc8d4901a4e3f1314c61b Mon Sep 17 00:00:00 2001
From: Patrick Yavitz <pyavitz@gmail.com>
Date: Mon, 9 Mar 2026 11:40:23 -0400
Subject: [PATCH] SpacemiT MusePi Pro: Add SD card support

Signed-off-by: Patrick Yavitz <pyavitz@gmail.com>
---
 .../riscv/boot/dts/spacemit/k1-musepi-pro.dts | 27 +++++++++++++++++--
 1 file changed, 25 insertions(+), 2 deletions(-)

diff --git a/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts b/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts
index 561938f398f7..1acb59b4a539 100644
--- a/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts
+++ b/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts
@@ -19,6 +19,8 @@ aliases {
 		ethernet0 = &eth0;
 		i2c2 = &i2c2;
 		i2c8 = &i2c8;
+		mmc0 = &sdhci0;
+		mmc2 = &emmc;
 		serial0 = &uart0;
 	};
 
@@ -236,7 +238,7 @@ buck3_1v8: buck3 {
 				regulator-always-on;
 			};
 
-			buck4: buck4 {
+			sd_vmmc: buck4 {
 				regulator-min-microvolt = <500000>;
 				regulator-max-microvolt = <3300000>;
 				regulator-ramp-delay = <5000>;
@@ -257,10 +259,11 @@ buck6 {
 				regulator-always-on;
 			};
 
-			aldo1: aldo1 {
+			sd_vqmmc: aldo1 {
 				regulator-min-microvolt = <500000>;
 				regulator-max-microvolt = <3400000>;
 				regulator-boot-on;
+				regulator-always-on;
 			};
 
 			aldo2 {
@@ -349,6 +352,26 @@ &pcie2 {
 	status = "okay";
 };
 
+&sdhci0 {
+	pinctrl-names = "default", "state_uhs";
+	pinctrl-0 = <&mmc1_cfg>;
+	pinctrl-1 = <&mmc1_uhs_cfg>;
+	bus-width = <4>;
+	cd-gpios = <&gpio K1_GPIO(80) GPIO_ACTIVE_HIGH>;
+	cd-inverted;
+	broken-cd;
+	cap-sd-highspeed;
+	disable-wp;
+	no-mmc;
+	no-sdio;
+	sd-uhs-sdr25;
+	sd-uhs-sdr50;
+	sd-uhs-sdr104;
+	vmmc-supply = <&sd_vmmc>;
+	vqmmc-supply = <&sd_vqmmc>;
+	status = "okay";
+};
+
 &uart0 {
 	pinctrl-0 = <&uart0_2_cfg>;
 	pinctrl-names = "default";
-- 
2.53.0

