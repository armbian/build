From 12bb0a78865cf924a94aaf2f68e209707917c101 Mon Sep 17 00:00:00 2001
From: Patrick Yavitz <pyavitz@gmail.com>
Date: Mon, 16 Mar 2026 21:12:58 -0400
Subject: [PATCH] SpacemiT MusePi Pro: Add SD card support

Signed-off-by: Patrick Yavitz <pyavitz@gmail.com>
---
 .../riscv/boot/dts/spacemit/k1-musepi-pro.dts | 23 +++++++++++++++++++
 1 file changed, 23 insertions(+)

diff --git a/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts b/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts
index 561938f398f7..48dbea6b7433 100644
--- a/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts
+++ b/arch/riscv/boot/dts/spacemit/k1-musepi-pro.dts
@@ -19,6 +19,8 @@ aliases {
 		ethernet0 = &eth0;
 		i2c2 = &i2c2;
 		i2c8 = &i2c8;
+		mmc0 = &sdhci0;
+		mmc2 = &emmc;
 		serial0 = &uart0;
 	};
 
@@ -260,6 +262,7 @@ buck6 {
 			aldo1: aldo1 {
 				regulator-min-microvolt = <500000>;
 				regulator-max-microvolt = <3400000>;
+				regulator-always-on;
 				regulator-boot-on;
 			};
 
@@ -349,6 +352,26 @@ &pcie2 {
 	status = "okay";
 };
 
+&sdhci0 {
+	pinctrl-names = "default", "state_uhs";
+	pinctrl-0 = <&mmc1_cfg>;
+	pinctrl-1 = <&mmc1_uhs_cfg>;
+	bus-width = <4>;
+	cd-gpios = <&gpio K1_GPIO(80) GPIO_ACTIVE_HIGH>;
+	cd-inverted;
+	broken-cd;
+	cap-sd-highspeed;
+	disable-wp;
+	no-mmc;
+	no-sdio;
+	sd-uhs-sdr25;
+	sd-uhs-sdr50;
+	sd-uhs-sdr104;
+	vmmc-supply = <&buck4>;
+	vqmmc-supply = <&aldo1>;
+	status = "okay";
+};
+
 &uart0 {
 	pinctrl-0 = <&uart0_2_cfg>;
 	pinctrl-names = "default";
-- 
2.53.0

