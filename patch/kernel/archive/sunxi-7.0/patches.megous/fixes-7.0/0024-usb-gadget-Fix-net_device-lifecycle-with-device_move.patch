@@ -369,6 +367,10 @@ geth_bind(struct usb_configuration *c, struct usb_function *f)
 
 	DBG(cdev, "CDC Subset: IN/%s OUT/%s\n",
 			geth->port.in_ep->name, geth->port.out_ep->name);
+
+	gether_opts->bind_count++;
+	retain_and_null_ptr(net);
