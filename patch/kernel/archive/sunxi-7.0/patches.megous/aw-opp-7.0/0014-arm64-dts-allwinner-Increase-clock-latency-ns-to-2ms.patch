+++ b/arch/arm64/boot/dts/allwinner/sun50i-a64-cpu-opp.dtsi
@@ -11,49 +11,49 @@ cpu0_opp_table: opp-table-cpu {
 		opp-648000000 {
 			opp-hz = /bits/ 64 <648000000>;
 			opp-microvolt = <1040000>;
-			clock-latency-ns = <244144>; /* 8 32k periods */
