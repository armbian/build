From c701b1be12e6e2be03c2d917a07829be82d64ad2 Mon Sep 17 00:00:00 2001
From: Ondrej Jirman <megi@xff.cz>
Date: Tue, 10 Feb 2026 20:22:00 +0100
Subject: [PATCH 08/15] clk: sunxi-ng: Allow to run CPU clock change notifiers
 once

Allow to configure the notifiers to run only on first clock change and
then nop out forever.

Running them at least once on first rate change is necessary, because we
don't know the divider state the bootloader left behind.

Further rate changes can rely on kernel enforced NKMP divider rules.

This behavior is optional and needs to be enabled per SoC/clock.

Signed-off-by: Ondrej Jirman <megi@xff.cz>
---
 drivers/clk/sunxi-ng/ccu_common.c | 5 +++++
 drivers/clk/sunxi-ng/ccu_common.h | 2 ++
 drivers/clk/sunxi-ng/ccu_mux.c    | 5 +++++
 drivers/clk/sunxi-ng/ccu_mux.h    | 2 ++
 4 files changed, 14 insertions(+)

diff --git a/drivers/clk/sunxi-ng/ccu_common.c b/drivers/clk/sunxi-ng/ccu_common.c
index 1c083b4d0b7e..c6f032c431c7 100644
--- a/drivers/clk/sunxi-ng/ccu_common.c
+++ b/drivers/clk/sunxi-ng/ccu_common.c
@@ -85,8 +85,13 @@ static int ccu_pll_notifier_cb(struct notifier_block *nb,
 	struct ccu_pll_nb *pll = to_ccu_pll_nb(nb);
 	int ret = 0;
 
+	if (pll->once && pll->once_done)
+		return notifier_from_errno(0);
+
 	if (event != POST_RATE_CHANGE)
 		goto out;
+	
+	pll->once_done = 1;
 
 	ccu_gate_helper_disable(pll->common, pll->enable);
 
diff --git a/drivers/clk/sunxi-ng/ccu_common.h b/drivers/clk/sunxi-ng/ccu_common.h
index bbec283b9d99..e5e199b26e99 100644
--- a/drivers/clk/sunxi-ng/ccu_common.h
+++ b/drivers/clk/sunxi-ng/ccu_common.h
@@ -72,6 +72,8 @@ struct ccu_pll_nb {
 
 	u32	enable;
 	u32	lock;
+	u8	once;		/* Only run the notifier once */
+	u8	once_done;	/* This is set by the notifier callback */
 };
 
 #define to_ccu_pll_nb(_nb) container_of(_nb, struct ccu_pll_nb, clk_nb)
diff --git a/drivers/clk/sunxi-ng/ccu_mux.c b/drivers/clk/sunxi-ng/ccu_mux.c
index 766f27cff748..2ca6a65945d3 100644
--- a/drivers/clk/sunxi-ng/ccu_mux.c
+++ b/drivers/clk/sunxi-ng/ccu_mux.c
@@ -300,6 +300,9 @@ static int ccu_mux_notifier_cb(struct notifier_block *nb,
 	struct ccu_mux_nb *mux = to_ccu_mux_nb(nb);
 	int ret = 0;
 
+	if (mux->once && mux->once_done)
+		return notifier_from_errno(0);
+
 	if (event == PRE_RATE_CHANGE) {
 		mux->original_index = ccu_mux_helper_get_parent(mux->common,
 								mux->cm);
@@ -308,6 +311,8 @@ static int ccu_mux_notifier_cb(struct notifier_block *nb,
 	} else if (event == POST_RATE_CHANGE) {
 		ret = ccu_mux_helper_set_parent(mux->common, mux->cm,
 						mux->original_index);
+						
+		mux->once_done = 1;
 	}
 
 	udelay(mux->delay_us);
diff --git a/drivers/clk/sunxi-ng/ccu_mux.h b/drivers/clk/sunxi-ng/ccu_mux.h
index c94a4bde5d01..d543332784e7 100644
--- a/drivers/clk/sunxi-ng/ccu_mux.h
+++ b/drivers/clk/sunxi-ng/ccu_mux.h
@@ -155,6 +155,8 @@ struct ccu_mux_nb {
 	u32	delay_us;	/* How many us to wait after reparenting */
 	u8	bypass_index;	/* Which parent to temporarily use */
 	u8	original_index;	/* This is set by the notifier callback */
+	u8	once;		/* Only run the notifier once */
+	u8	once_done;	/* This is set by the notifier callback */
 };
 
 #define to_ccu_mux_nb(_nb) container_of(_nb, struct ccu_mux_nb, clk_nb)
-- 
