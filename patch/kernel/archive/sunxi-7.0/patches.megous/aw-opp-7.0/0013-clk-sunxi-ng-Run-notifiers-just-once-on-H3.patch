From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Ondrej Jirman <megi@xff.cz>
Date: Wed, 11 Feb 2026 20:40:31 +0100
Subject: clk: sunxi-ng: Run notifiers just once on H3

This avoids needing to patch U-Boot to select kernel compatible factors
(ones not using M/P divider).

Signed-off-by: Ondrej Jirman <megi@xff.cz>
---
 drivers/clk/sunxi-ng/ccu-sun8i-h3.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/clk/sunxi-ng/ccu-sun8i-h3.c b/drivers/clk/sunxi-ng/ccu-sun8i-h3.c
index 111111111111..222222222222 100644
--- a/drivers/clk/sunxi-ng/ccu-sun8i-h3.c
+++ b/drivers/clk/sunxi-ng/ccu-sun8i-h3.c
@@ -1034,6 +1034,7 @@ static struct ccu_pll_nb sun8i_h3_pll_cpu_nb = {
 	/* copy from pll_cpux_clk */
 	.enable	= BIT(31),
 	.lock	= BIT(28),
+	.once	= 1,
 };
 
 static struct ccu_mux_nb sun8i_h3_cpu_nb = {
@@ -1041,6 +1042,7 @@ static struct ccu_mux_nb sun8i_h3_cpu_nb = {
 	.cm		= &cpux_clk.mux,
 	.delay_us	= 1, /* > 8 clock cycles at 24 MHz */
 	.bypass_index	= 1, /* index of 24 MHz oscillator */
+	.once		= 1,
 };
 
 static int sun8i_h3_ccu_probe(struct platform_device *pdev)
-- 
Armbian

