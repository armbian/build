From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Juan Sanchez <juanesf91@gmail.com>
Date: Wed, 22 Jul 2026 23:00:00 +0000
Subject: [PATCH] clk: sunxi-ng: a523: fix MP clocks with only one divider

Some A523 clock definitions use the MP clock class but only have a single
divider (either M or P), leaving the other divider with zero width. This
produces invalid GENMASK() ranges at runtime and can corrupt adjacent
register fields.

Clocks with only an M divider (mbus, iommu, dram) now use struct ccu_div
with ccu_div_ops, retaining CCU_FEATURE_UPDATE_BIT where needed.
Clocks with only a power-of-two P divider (hstimer0-5) now use
SUNXI_CCU_P_DATA_WITH_MUX_GATE, which applies CLK_DIVIDER_POWER_OF_TWO.

Assisted-by: opencode:deepseek-v4-flash-free
Signed-off-by: Juan Sanchez <juanesf91@gmail.com>
---
 drivers/clk/sunxi-ng/ccu-sun55i-a523.c | 42 ++++++++++++++++---------
 1 file changed, 27 insertions(+), 15 deletions(-)

diff --git a/drivers/clk/sunxi-ng/ccu-sun55i-a523.c b/drivers/clk/sunxi-ng/ccu-sun55i-a523.c
index 20dad06b37ca..d469a6b22556 100644
--- a/drivers/clk/sunxi-ng/ccu-sun55i-a523.c
+++ b/drivers/clk/sunxi-ng/ccu-sun55i-a523.c
@@ -380,14 +380,18 @@ static const struct clk_parent_data mbus_parents[] = {
 	{ .hw = &pll_periph1_150M_clk.hw },
 	{ .fw_name = "hosc" },
 };
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE_FEAT(mbus_clk, "mbus", mbus_parents,
-					    0x540,
-					    0, 5,		/* M */
-					    0, 0,		/* no P */
-					    24, 3,	/* mux */
-					    BIT(31),	/* gate */
-					    CLK_IS_CRITICAL,
-					    CCU_FEATURE_UPDATE_BIT);
+static struct ccu_div mbus_clk = {
+	.enable		= BIT(31),
+	.div		= _SUNXI_CCU_DIV(0, 5),
+	.mux		= _SUNXI_CCU_MUX(24, 3),
+	.common		= {
+		.reg		= 0x540,
+		.features	= CCU_FEATURE_UPDATE_BIT,
+		.hw.init	= CLK_HW_INIT_PARENTS_DATA("mbus", mbus_parents,
+						   &ccu_div_ops,
+						   CLK_IS_CRITICAL),
+	},
+};
 
 static const struct clk_hw *mbus_hws[] = { &mbus_clk.common.hw };
 
@@ -513,54 +517,48 @@ static const struct clk_parent_data hstimer_parents[] = {
 	{ .fw_name = "losc" },
 	{ .hw = &pll_periph0_200M_clk.hw },
 };
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(hstimer0_clk, "hstimer0",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(hstimer0_clk, "hstimer0",
 				       hstimer_parents, 0x730,
-				       0, 0,	/* M */
 				       0, 3,	/* P */
 				       24, 3,	/* mux */
 				       BIT(31),	/* gate */
 				       0);
 
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(hstimer1_clk, "hstimer1",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(hstimer1_clk, "hstimer1",
 				       hstimer_parents,
 				       0x734,
-				       0, 0,	/* M */
 				       0, 3,	/* P */
 				       24, 3,	/* mux */
 				       BIT(31),	/* gate */
 				       0);
 
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(hstimer2_clk, "hstimer2",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(hstimer2_clk, "hstimer2",
 				       hstimer_parents,
 				       0x738,
-				       0, 0,	/* M */
 				       0, 3,	/* P */
 				       24, 3,	/* mux */
 				       BIT(31),	/* gate */
 				       0);
 
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(hstimer3_clk, "hstimer3",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(hstimer3_clk, "hstimer3",
 				       hstimer_parents,
 				       0x73c,
-				       0, 0,	/* M */
 				       0, 3,	/* P */
 				       24, 3,	/* mux */
 				       BIT(31),	/* gate */
 				       0);
 
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(hstimer4_clk, "hstimer4",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(hstimer4_clk, "hstimer4",
 				       hstimer_parents,
 				       0x740,
-				       0, 0,	/* M */
 				       0, 3,	/* P */
 				       24, 3,	/* mux */
 				       BIT(31),	/* gate */
 				       0);
 
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(hstimer5_clk, "hstimer5",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(hstimer5_clk, "hstimer5",
 				       hstimer_parents,
 				       0x744,
-				       0, 0,	/* M */
 				       0, 3,	/* P */
 				       24, 3,	/* mux */
 				       BIT(31),	/* gate */
@@ -584,14 +582,18 @@ static const struct clk_parent_data iommu_parents[] = {
 	{ .fw_name = "hosc" },
 };
 
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE_FEAT(iommu_clk, "iommu", iommu_parents,
-					    0x7b0,
-					    0, 5,	/* M */
-					    0, 0,	/* no P */
-					    24, 3,	/* mux */
-					    BIT(31),	/* gate */
-					    CLK_SET_RATE_PARENT,
-					    CCU_FEATURE_UPDATE_BIT);
+static struct ccu_div iommu_clk = {
+	.enable		= BIT(31),
+	.div		= _SUNXI_CCU_DIV(0, 5),
+	.mux		= _SUNXI_CCU_MUX(24, 3),
+	.common		= {
+		.reg		= 0x7b0,
+		.features	= CCU_FEATURE_UPDATE_BIT,
+		.hw.init	= CLK_HW_INIT_PARENTS_DATA("iommu", iommu_parents,
+						   &ccu_div_ops,
+						   CLK_SET_RATE_PARENT),
+	},
+};
 
 static SUNXI_CCU_GATE_HWS(bus_iommu_clk, "bus-iommu", apb0_hws, 0x7bc,
 			  BIT(0), 0);
@@ -603,14 +605,18 @@ static const struct clk_parent_data dram_parents[] = {
 	{ .hw = &pll_periph0_400M_clk.hw },
 	{ .hw = &pll_periph0_150M_clk.hw },
 };
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE_FEAT(dram_clk, "dram", dram_parents,
-					    0x800,
-					    0, 5,	/* M */
-					    0, 0,	/* no P */
-					    24, 3,	/* mux */
-					    BIT(31),	/* gate */
-					    CLK_IS_CRITICAL,
-					    CCU_FEATURE_UPDATE_BIT);
+static struct ccu_div dram_clk = {
+	.enable		= BIT(31),
+	.div		= _SUNXI_CCU_DIV(0, 5),
+	.mux		= _SUNXI_CCU_MUX(24, 3),
+	.common		= {
+		.reg		= 0x800,
+		.features	= CCU_FEATURE_UPDATE_BIT,
+		.hw.init	= CLK_HW_INIT_PARENTS_DATA("dram", dram_parents,
+						   &ccu_div_ops,
+						   CLK_IS_CRITICAL),
+	},
+};
 
 static SUNXI_CCU_GATE_HWS(mbus_dma_clk, "mbus-dma", mbus_hws,
 			  0x804, BIT(0), 0);
