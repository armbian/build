+
+static int isdigit(unsigned char c)
+{
+	return ((c >= '0') && (c <='9'));
+}
+
+static int isxdigit(unsigned char c)
+{
+	if ((c >= '0') && (c <='9'))
+		return 1;
+	if ((c >= 'a') && (c <='f'))
+		return 1;
+	if ((c >= 'A') && (c <='F'))
+		return 1;
+	return 0;
+}
+
+static int islower(unsigned char c)
+{
+	return ((c >= 'a') && (c <='z'));
+}
+
+static unsigned char toupper(unsigned char c)
+{
+	if (islower(c))
+		c -= 'a'-'A';
+	return c;
+}
+#endif
