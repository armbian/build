+        } else
+                AICWFDBG(LOGINFO, "custom wifi mac-addr: %02x:%02x:%02x:%02x:%02x:%02x\n",
+                        mac_addr_efuse[0], mac_addr_efuse[1], mac_addr_efuse[2],
+                        mac_addr_efuse[3], mac_addr_efuse[4], mac_addr_efuse[5]);
