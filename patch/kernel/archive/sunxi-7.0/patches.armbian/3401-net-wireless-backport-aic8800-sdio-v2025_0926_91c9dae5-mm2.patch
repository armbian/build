+ */
+void rwnx_txq_sta_deinit(struct rwnx_hw *rwnx_hw, struct rwnx_sta *rwnx_sta)
+{
+	struct rwnx_txq *txq;
+	int tid;
+
+	foreach_sta_txq(rwnx_sta, txq, tid, rwnx_hw) {
+		rwnx_txq_deinit(rwnx_hw, txq);
+	}
+}
