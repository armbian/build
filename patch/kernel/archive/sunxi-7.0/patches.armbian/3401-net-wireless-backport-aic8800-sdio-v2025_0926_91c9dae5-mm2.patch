+int sun8i_mixer_drm_format_to_hw(u32 format, u32 *hw_format)
+{
+	unsigned int i;
+
+	for (i = 0; i < ARRAY_SIZE(de2_formats); ++i)
+		if (de2_formats[i].drm_fmt == format) {
+			*hw_format = de2_formats[i].de2_fmt;
+			return 0;
+		}
+
+	return -EINVAL;
+}
