+            fc_reg = fc_reg & SDIOWIFI_FLOWCTRL_MASK_REG;
+        }
+
+        if (fc_reg > DATA_FLOW_CTRL_THRESH) {
+            ret = fc_reg;
+            //if(ret > tx_aggr_counter){
+			//	ret = tx_aggr_counter;
+			//}
