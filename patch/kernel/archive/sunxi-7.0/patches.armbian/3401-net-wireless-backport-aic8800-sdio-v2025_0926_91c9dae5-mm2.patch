+								 + MGMT_ACTION_OUI_SUBTYPE_OFFSET);
+				   ),
+	TP_printk("f=%d vif=%d sta=%d -> %s",
+			__entry->freq, __entry->vif_idx, __entry->sta_idx,
+			  __print_mgmt_info(__entry->frame_control, __entry->action_cat,
+								__entry->action_type, __entry->action_p2p))
+);
