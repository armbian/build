+
+#define B_STEER_BLOCK_ENTRY_EXPIRE          60
+#define B_STEER_ROAM_BLOCK_ENTRY_EXPIRE     5
+#define STEER_UPFATE_TIME                   2000
+
+struct rwnx_vif;
+
+struct b_steer_block_entry {
+	u8_l used;
+	u8_l mac[6];
+	u32_l entry_expire;
+};
+
+struct b_steer_priv {
