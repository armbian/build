+static void rwnx_restore_firmware(u32 **fw_buf)
+{
+#ifdef CONFIG_USE_FW_REQUEST
+	vfree(*fw_buf);
+#else
+	kfree(*fw_buf);
+#endif
+    *fw_buf = NULL;
+}
+
+
+void rwnx_release_firmware_common(u32** buffer)
+{
+    rwnx_restore_firmware(buffer);
+}
