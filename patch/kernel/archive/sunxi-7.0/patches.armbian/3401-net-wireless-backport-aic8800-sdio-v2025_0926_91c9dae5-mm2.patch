+struct rwnx_sta *rwnx_get_sta(struct rwnx_hw *rwnx_hw, const u8 *mac_addr)
+{
+	int i;
+
+	for (i = 0; i < NX_REMOTE_STA_MAX; i++) {
+		struct rwnx_sta *sta = &rwnx_hw->sta_table[i];
+		if (sta->valid && (memcmp(mac_addr, &sta->mac_addr, 6) == 0))
+			return sta;
+	}
+
+	return NULL;
+}
