+
+/// Structure containing the parameters of the @ref TDLS_PEER_TRAFFIC_IND_CFM message
+struct tdls_peer_traffic_ind_cfm {
+	/// Status of the operation
+	u8_l status;
+};
+
+
+#endif // LMAC_MSG_H_
