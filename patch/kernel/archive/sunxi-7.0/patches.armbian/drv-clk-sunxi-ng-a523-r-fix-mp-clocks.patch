From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Juan Sanchez <juanesf91@gmail.com>
Date: Wed, 22 Jul 2026 23:00:00 +0000
Subject: [PATCH] clk: sunxi-ng: a523-r: fix MP clocks with P divider only

The R CPU timer clocks (r-timer0/1/2) use the MP clock class but only
have a P divider, leaving the M divider with zero width. Switch them
to SUNXI_CCU_P_DATA_WITH_MUX_GATE, which applies CLK_DIVIDER_POWER_OF_TWO
and avoids the invalid GENMASK() from the zero-width M field.

Assisted-by: opencode:deepseek-v4-flash-free
Signed-off-by: Juan Sanchez <juanesf91@gmail.com>
---
 drivers/clk/sunxi-ng/ccu-sun55i-a523-r.c | 12 +++++-------
 1 file changed, 5 insertions(+), 7 deletions(-)

diff --git a/drivers/clk/sunxi-ng/ccu-sun55i-a523-r.c b/drivers/clk/sunxi-ng/ccu-sun55i-a523-r.c
index db0e36d8838e..452616e6f9e1 100644
--- a/drivers/clk/sunxi-ng/ccu-sun55i-a523-r.c
+++ b/drivers/clk/sunxi-ng/ccu-sun55i-a523-r.c
@@ -43,27 +43,24 @@ static SUNXI_CCU_M_DATA_WITH_MUX(r_apb1_clk, "r-apb1",
 				 24, 3,	/* mux */
 				 0);
 
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(r_cpu_timer0, "r-timer0",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(r_cpu_timer0, "r-timer0",
 				       r_ahb_apb_parents, 0x100,
-				       0, 0,	/* no M */
 				       1, 3,	/* P */
 				       4, 3,	/* mux */
 				       BIT(0),
 				      0);
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(r_cpu_timer1, "r-timer1",
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(r_cpu_timer1, "r-timer1",
 				       r_ahb_apb_parents, 0x104,
-				       0, 0,	/* no M */
 				       1, 3,	/* P */
 				       4, 3,	/* mux */
 				       BIT(0),
-				       0);
-static SUNXI_CCU_MP_DATA_WITH_MUX_GATE(r_cpu_timer2, "r-timer2",
+				      0);
+static SUNXI_CCU_P_DATA_WITH_MUX_GATE(r_cpu_timer2, "r-timer2",
 				       r_ahb_apb_parents, 0x108,
-				       0, 0,	/* no M */
 				       1, 3,	/* P */
 				       4, 3,	/* mux */
 				       BIT(0),
-				       0);
+				      0);
 
 static SUNXI_CCU_GATE_HW(bus_r_timer_clk, "bus-r-timer", &r_ahb_clk.common.hw,
 			 0x11c, BIT(0), 0);
