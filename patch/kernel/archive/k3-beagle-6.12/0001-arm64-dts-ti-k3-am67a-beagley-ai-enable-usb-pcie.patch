From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Andrei Aldea <andrei1998@gmail.com>
Date: Thu, 2 Jul 2026 12:30:00 -0500
Subject: [PATCH] arm64: dts: ti: k3-am67a-beagley-ai: enable USB and PCIe

The BeagleY-AI 6.12 vendor DTB contains USB0 and USB1 controller
nodes, but leaves both wrapper nodes disabled. As a result, no USB host
controller probes and the onboard USB hub never appears.

Enable the BeagleY-AI USB controller paths:

 - expose USB aliases
 - enable USB0 in OTG mode
 - enable the SERDES wrapper used by USB1
 - enable USB1 as a SuperSpeed host
 - add USB1 VBUS pinctrl
 - describe the onboard USB 2.0/3.0 hub pair and shared reset GPIO

Also enable the SERDES used by the PCIe0 root complex. Without that
child node enabled, PCIe devices behind the BeagleY-AI M.2 slot do not
enumerate even though pcie0_rc itself is enabled.

Model the M.2 3.3V enable GPIO as an always-on fixed regulator instead
of a non-binding PCIe host property.

This mirrors the missing pieces identified for BeagleY-AI 6.12 USB
support on the BeagleBoard forum.

Link: https://forum.beagleboard.org/t/beagley-ai-usb-on-kernel-6-12-x/43621
Signed-off-by: Andrei Aldea <andrei1998@gmail.com>
---
 arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts | 93 +++++++++++++++++-
 1 file changed, 91 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
index d5194627a124..21e6085c9dbd 100644
--- a/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
+++ b/arch/arm64/boot/dts/ti/k3-am67a-beagley-ai.dts
@@ -28,6 +28,8 @@ aliases {
 		mmc1 = &sdhci1;
 		mmc2 = &sdhci2;
 		rtc0 = &rtc;
+		usb0 = &usb0;
+		usb1 = &usb1;
 		i2c1 = &mcu_i2c0;
 	};
 
@@ -154,6 +156,20 @@ vdd_3v3: regulator-2 {
 		regulator-boot-on;
 	};
 
+	vdd_pcie0: regulator-pcie0 {
+		compatible = "regulator-fixed";
+		regulator-name = "vdd_pcie0";
+		pinctrl-names = "default";
+		pinctrl-0 = <&pcie0_3v3_pins_default>;
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		vin-supply = <&vdd_3v3>;
+		enable-active-high;
+		gpio = <&mcu_gpio0 8 GPIO_ACTIVE_HIGH>;
+		regulator-always-on;
+		regulator-boot-on;
+	};
+
 	vdd_mmc1: regulator-3 {
 		compatible = "regulator-fixed";
 		regulator-name = "vdd_mmc1";
@@ -379,6 +381,12 @@ vdd_3v3_sd_pins_default: vdd-3v3-sd-default-pins {
 		>;
 	};
 
+	main_usb1_pins_default: main-usb1-default-pins {
+		pinctrl-single,pins = <
+			J722S_IOPAD(0x0258, PIN_INPUT, 0) /* (B27) USB1_DRVVBUS */
+		>;
+	};
+
 	dss1_pins_default: dss1-default-pins {
 		pinctrl-single,pins = <
 			J722S_IOPAD(0x0100, PIN_OUTPUT, 0) /* (AB23) VOUT0_VSYNC */
@@ -429,6 +437,12 @@ main_mcasp1_pins_default: main-mcasp1-default-pins {
 		>;
 	};
 
+	usb_hub: usb-hub-default-pins {
+		pinctrl-single,pins = <
+			J722S_IOPAD(0x0084, PIN_OUTPUT, 7) /* (N21) GPMC0_ADVn_ALE.GPIO0_32 */
+		>;
+	};
+
 	wifi_pins_default: wifi-default-pins {
 		pinctrl-single,pins = <
 			J722S_IOPAD(0x0120, PIN_INPUT, 0) /* (F27) MMC2_CMD */
@@ -605,11 +633,16 @@ pcie_pins_default: pcie-default-pins {
 		pinctrl-single,pins = <
 			J722S_MCU_IOPAD(0x0018, PIN_OUTPUT, 7)	/* (B4) MCU_UART0_TXD.MCU_GPIO0_6 */
 			J722S_MCU_IOPAD(0x0014, PIN_INPUT, 7)	/* (B8) MCU_UART0_RXD.MCU_GPIO0_5 */ /* PCIE_DET_WAKE */
-			J722S_MCU_IOPAD(0x0020, PIN_OUTPUT, 7)	/* (C5) MCU_UART0_RTSn.MCU_GPIO0_8 */ /* PCIE_PWR_EN */
 		>;
 		bootph-all;
 	};
 
+	pcie0_3v3_pins_default: pcie0-3v3-default-pins {
+		pinctrl-single,pins = <
+			J722S_MCU_IOPAD(0x0020, PIN_OUTPUT, 7)	/* (C5) MCU_UART0_RTSn.MCU_GPIO0_8 */ /* PCIE_PWR_EN */
+		>;
+	};
+
 	mcu_i2c0_pins_default: mcu-i2c0-default-pins {
 		pinctrl-single,pins = <
 			J722S_MCU_IOPAD(0x0044, PIN_INPUT_PULLUP, 0) /* (B13) MCU_I2C0_SCL */
@@ -963,6 +996,10 @@ &serdes_ln_ctrl {
 		      <J722S_SERDES1_LANE0_PCIE0_LANE0>;
 };
 
+&serdes_wiz0 {
+	status = "okay";
+};
+
 &serdes0 {
 	status = "okay";
 	serdes0_usb_link: phy@0 {
@@ -974,6 +1011,11 @@ serdes0_usb_link: phy@0 {
 	};
 };
 
+&serdes_wiz1 {
+	status = "okay";
+};
+
 &serdes1 {
+	status = "okay";
 	serdes1_pcie_link: phy@0 {
 		reg = <0>;
@@ -998,5 +1040,52 @@ &pcie0_rc {
 	num-lanes = <1>;
 	max-link-speed = <3>;
 	reset-gpios = <&mcu_gpio0 6 GPIO_ACTIVE_HIGH>;
-	enable-gpios = <&mcu_gpio0 8 GPIO_ACTIVE_HIGH>; /* Extra GPIO for pwr_en for BeagleY AI */
 };
+
+&usbss0 {
+	ti,vbus-divider;
+	status = "okay";
+};
+
+&usb0 {
+	dr_mode = "otg";
+	usb-role-switch;
+};
+
+&usbss1 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&main_usb1_pins_default>;
+	ti,vbus-divider;
+	status = "okay";
+};
+
+&usb1 {
+	dr_mode = "host";
+	maximum-speed = "super-speed";
+	phys = <&serdes0_usb_link>;
+	phy-names = "cdns3,usb3-phy";
+
+	#address-cells = <1>;
+	#size-cells = <0>;
+	pinctrl-names = "default";
+	pinctrl-0 = <&usb_hub>;
+	status = "okay";
+
+	/* 2.0 hub on port 1 */
+	hub_2_0: hub@1 {
+		compatible = "usb451,8142";
+		reg = <1>;
+		peer-hub = <&hub_3_0>;
+		reset-gpios = <&main_gpio0 32 GPIO_ACTIVE_LOW>;
+		vdd-supply = <&vdd_3v3>;
+	};
+
+	/* 3.0 hub on port 2 */
+	hub_3_0: hub@2 {
+		compatible = "usb451,8140";
+		reg = <2>;
+		peer-hub = <&hub_2_0>;
+		reset-gpios = <&main_gpio0 32 GPIO_ACTIVE_LOW>;
+		vdd-supply = <&vdd_3v3>;
+	};
+};
-- 
Armbian
