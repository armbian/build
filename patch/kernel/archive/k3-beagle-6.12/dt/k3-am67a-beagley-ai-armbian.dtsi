/*
 * Armbian board supplement for BeagleY-AI.
 *
 * Keep board-local USB and PCIe wiring outside the upstream-maintained base
 * DTS so kernel updates can carry their normal device-tree fixes unchanged.
 */

#include <dt-bindings/phy/phy.h>
#include "k3-serdes.h"

&{/aliases} {
	usb0 = &usb0;
	usb1 = &usb1;
};

/ {
	vdd_pcie0: regulator-pcie0 {
		compatible = "regulator-fixed";
		regulator-name = "vdd_pcie0";
		pinctrl-names = "default";
		pinctrl-0 = <&pcie0_3v3_pins_default>;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vdd_3v3>;
		enable-active-high;
		gpio = <&mcu_gpio0 8 GPIO_ACTIVE_HIGH>;
		regulator-always-on;
		regulator-boot-on;
	};
};

&main_pmx0 {
	main_usb1_pins_default: main-usb1-default-pins {
		pinctrl-single,pins = <
			J722S_IOPAD(0x0258, PIN_INPUT, 0) /* (B27) USB1_DRVVBUS */
		>;
	};

	usb_hub: usb-hub-default-pins {
		pinctrl-single,pins = <
			J722S_IOPAD(0x0084, PIN_OUTPUT, 7) /* (N21) GPMC0_ADVn_ALE.GPIO0_32 */
		>;
	};
};

&mcu_pmx0 {
	pcie_pins_default: pcie-default-pins {
		pinctrl-single,pins = <
			J722S_MCU_IOPAD(0x0018, PIN_OUTPUT, 7) /* (B4) MCU_UART0_TXD.MCU_GPIO0_6 */
			J722S_MCU_IOPAD(0x0014, PIN_INPUT, 7) /* (B8) MCU_UART0_RXD.MCU_GPIO0_5 */
		>;
		bootph-all;
	};

	pcie0_3v3_pins_default: pcie0-3v3-default-pins {
		pinctrl-single,pins = <
			J722S_MCU_IOPAD(0x0020, PIN_OUTPUT, 7) /* (C5) MCU_UART0_RTSn.MCU_GPIO0_8 */
		>;
	};
};

&serdes_wiz0 {
	status = "okay";
};

&serdes_wiz1 {
	status = "okay";
};

&serdes1 {
	status = "okay";
};

&pcie0_rc {
	/delete-property/ enable-gpios;
};

&usbss0 {
	ti,vbus-divider;
	status = "okay";
};

&usb0 {
	dr_mode = "otg";
	usb-role-switch;
};

&usbss1 {
	pinctrl-names = "default";
	pinctrl-0 = <&main_usb1_pins_default>;
	ti,vbus-divider;
	status = "okay";
};

&usb1 {
	dr_mode = "host";
	maximum-speed = "super-speed";
	phys = <&serdes0_usb_link>;
	phy-names = "cdns3,usb3-phy";

	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&usb_hub>;
	status = "okay";

	/* USB 2.0 hub on port 1 */
	hub_2_0: hub@1 {
		compatible = "usb451,8142";
		reg = <1>;
		peer-hub = <&hub_3_0>;
		reset-gpios = <&main_gpio0 32 GPIO_ACTIVE_LOW>;
		vdd-supply = <&vdd_3v3>;
	};

	/* USB 3.0 hub on port 2 */
	hub_3_0: hub@2 {
		compatible = "usb451,8140";
		reg = <2>;
		peer-hub = <&hub_2_0>;
		reset-gpios = <&main_gpio0 32 GPIO_ACTIVE_LOW>;
		vdd-supply = <&vdd_3v3>;
	};
};
