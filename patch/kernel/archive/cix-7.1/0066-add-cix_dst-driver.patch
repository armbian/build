+		   name##_str,	sizeof(name##_str) / sizeof(char *) }
+
+#define DDR_SET_CHANNEL_INVALID(channel) ((channel) = 0xff)
+#define DDR_CHANNEL_IS_INVALID(channel) ((channel) == 0xff)
+
+static u32 ddr_ready_msg_send;
+
+typedef enum {
+	TIMEOUT = 0,
+	ECC,
+	LOW_POWER_CONTROL,
+	TRAINING = 5,
+	USER_INTERFACE,
