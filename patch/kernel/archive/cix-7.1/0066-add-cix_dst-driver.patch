+	ECC_MUL_UNCORRECTABLE,
+	ECC_WRITEBACK = 6,
+	ECC_SCRUB,
+	ECC_CORRECTABLE_SCRUB_READ,
+	ECC_WRITE_SINGLE_BIT_MRR_M43,
