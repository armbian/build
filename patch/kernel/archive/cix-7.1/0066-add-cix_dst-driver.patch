+u32 checksum32(u32 *addr, u32 count)
+{
+	u64 sum = 0;
+	u32 i;
+
+	while (count > sizeof(u32) - 1) {
+		/*  This is the inner loop */
+		sum += *(addr++);
+		count -= sizeof(u32);
+	}
+
+	if (count > 0) {
+		u32 left = 0;
+
+		i = 0;
+		while (i <= count) {
+			*((u8 *)&left + i) = *((u8 *)addr + i);
+			i++;
+		}
+
+		sum += left;
+	}
+
+	while (sum >> 32)
+		sum = (sum & 0xffffffff) + (sum >> 32);
+
+	return (~sum);
+}
