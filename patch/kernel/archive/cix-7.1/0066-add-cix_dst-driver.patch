+#define GET_ADDR_FROM_EHROOT(ehroot, addr) \
+	(((void *)ehroot) + ((addr) - (ehroot->mem.vaddr)))
+#ifndef MAX
+#define MAX(X, Y) ((X) > (Y) ? (X) : (Y))
