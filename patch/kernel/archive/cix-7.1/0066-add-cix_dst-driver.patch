+++ b/drivers/soc/cix/cix_dst/blackbox/rdr_field.h
@@ -0,0 +1,94 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * rdr_field.h
+ *
+ * blackbox header file (blackbox: kernel run data recorder.)
