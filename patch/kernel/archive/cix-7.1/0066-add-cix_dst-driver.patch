+				TP_PROTO(const void *pre_task,                 \
+					 void *next_task),                     \
+				TP_ARGS(pre_task, next_task), HK_TASK);        \
+		DECLARE_AP_HOOK(cpuidle_stat, TP_PROTO(u32 dir), TP_ARGS(dir), \
