From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Jianfeng Liu <Jianfeng.Liu@cixtech.com>
Date: Wed, 29 Apr 2026 12:56:40 +0800
Subject: acpi: add backward complibility to old firmware with SCMI channel
 _STA=0

---
 drivers/acpi/Makefile    |  2 +-
 drivers/acpi/bus.c       |  5 ++
 drivers/acpi/internal.h  |  2 +
 drivers/acpi/sta_quirk.c | 36 ++++++++++
 4 files changed, 44 insertions(+), 1 deletion(-)

diff --git a/drivers/acpi/Makefile b/drivers/acpi/Makefile
index 111111111111..222222222222 100644
--- a/drivers/acpi/Makefile
+++ b/drivers/acpi/Makefile
@@ -39,7 +39,7 @@ acpi-$(CONFIG_ACPI_SLEEP)	+= proc.o
 #
 # ACPI Bus and Device Drivers
 #
-acpi-y				+= bus.o glue.o
+acpi-y				+= bus.o glue.o sta_quirk.o
 acpi-y				+= scan.o mipi-disco-img.o
 acpi-y				+= resource.o
 acpi-y				+= acpi_processor.o
diff --git a/drivers/acpi/bus.c b/drivers/acpi/bus.c
index 111111111111..222222222222 100644
--- a/drivers/acpi/bus.c
+++ b/drivers/acpi/bus.c
@@ -102,6 +102,11 @@ int acpi_bus_get_status(struct acpi_device *device)
 		return 0;
 	}
 
+	if (acpi_sta_override_firmware_quirk(device, &sta)) {
+		acpi_set_device_status(device, sta);
+		return 0;
+	}
+
 	/* Battery devices must have their deps met before calling _STA */
 	if (acpi_device_is_battery(device) && device->dep_unmet) {
 		acpi_set_device_status(device, 0);
diff --git a/drivers/acpi/internal.h b/drivers/acpi/internal.h
index 111111111111..222222222222 100644
--- a/drivers/acpi/internal.h
+++ b/drivers/acpi/internal.h
@@ -128,6 +128,8 @@ bool acpi_device_is_battery(struct acpi_device *adev);
 bool acpi_device_is_first_physical_node(struct acpi_device *adev,
 					const struct device *dev);
 int acpi_bus_register_early_device(int type);
+bool acpi_sta_override_firmware_quirk(struct acpi_device *adev,
+				       unsigned long long *status);
 
 /* --------------------------------------------------------------------------
                      Device Matching and Notification
diff --git a/drivers/acpi/sta_quirk.c b/drivers/acpi/sta_quirk.c
new file mode 100644
index 000000000000..111111111111
--- /dev/null
+++ b/drivers/acpi/sta_quirk.c
@@ -0,0 +1,36 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * ACPI _STA overrides for firmware bugs (non-arch-specific).
+ *
+ * CIX: unhide SCMI protocol child devices (CIXHA008/CIXHA009) that old
+ * firmware leaves at _STA 0 under CIXHA006.
+ */
+
+#include <linux/acpi.h>
+#include <acpi/acpi_bus.h>
+
+#include "internal.h"
+
+/*
+ * Old CIX firmware leaves DVFS/CLKS SCMI protocol devices (children of
+ * CIXHA006) at _STA 0 so Linux skips them in acpi_bus_attach() and
+ * acpi_get_next_present_subnode(). Treat them as fully present/enabled.
+ */
+static const struct acpi_device_id cix_scmi_proto_sta_ids[] = {
+	{ "CIXHA008", 0 },
+	{ "CIXHA009", 0 },
+	{ }
+};
+
+bool acpi_sta_override_firmware_quirk(struct acpi_device *adev,
+				       unsigned long long *status)
+{
+	if (acpi_match_device_ids(adev, cix_scmi_proto_sta_ids))
+		return false;
+
+	if (!acpi_dev_uid_match(adev, 0))
+		return false;
+
+	*status = ACPI_STA_DEFAULT;
+	return true;
+}
