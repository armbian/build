 {
+#if LINUX_VERSION_CODE < KERNEL_VERSION(6, 16, 0)
 	struct linlondp_wb_timer_data *data = from_timer(data, t, timer);
+#else
+	struct linlondp_wb_timer_data *data = timer_container_of(data, t, timer);
+#endif
