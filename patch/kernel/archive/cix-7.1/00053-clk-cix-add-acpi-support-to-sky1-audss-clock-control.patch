---
 drivers/clk/cix/clk-sky1-audss.c | 227 +++++++++-
 1 file changed, 218 insertions(+), 9 deletions(-)

diff --git a/drivers/clk/cix/clk-sky1-audss.c b/drivers/clk/cix/clk-sky1-audss.c
index 111111111111..222222222222 100644
--- a/drivers/clk/cix/clk-sky1-audss.c
+++ b/drivers/clk/cix/clk-sky1-audss.c
@@ -1,15 +1,20 @@
 // SPDX-License-Identifier: GPL-2.0-only
 // Copyright 2026 Cix Technology Group Co., Ltd.
 
+#include <linux/acpi.h>
 #include <linux/auxiliary_bus.h>
 #include <linux/clk.h>
 #include <linux/clk-provider.h>
+#include <linux/clkdev.h>
 #include <linux/device.h>
+#include <linux/device/bus.h>
+#include <linux/fwnode.h>
 #include <linux/module.h>
 #include <linux/of.h>
 #include <linux/of_device.h>
 #include <linux/platform_device.h>
 #include <linux/pm_runtime.h>
+#include <linux/property.h>
 #include <linux/regmap.h>
 #include <linux/reset.h>
 
@@ -43,6 +48,18 @@ static const u32 sky1_clk_rate_default[SKY1_AUDSS_CLK_PARENTS_CNT] = {
 	48000000,
 };
 
+/*
+ * Under ACPI the parent clocks are published by the CLKT table (clk-sky1-acpi)
+ * using the SCMI clock names audio_clk0..audio_clk5 — the same names the
+ * composite clocks below reference as parents.  DT instead labels the same
+ * four SCMI clocks x8k/x11k/sys/48m via clock-names.  Map the 7.1 parents to
+ * the 7.0 names (x8k->audio_clk0, x11k->audio_clk2, sys->audio_clk4,
+ * 48m->audio_clk5); rates are identical (see dt-bindings/clock/sky1-audss.h).
+ */
+static const char * const sky1_audss_acpi_clk_names[SKY1_AUDSS_CLK_PARENTS_CNT] = {
+	"audio_clk0", "audio_clk2", "audio_clk4", "audio_clk5",
+};
+
 static const char * const dsp_clk_parent[] = {
 	"audio_clk4"
 };
@@ -557,6 +574,152 @@ static int sky1_audss_reset_controller_register(struct device *dev)
 
 #endif
 
+#ifdef CONFIG_ACPI
+/*
+ * Parse the CLKA ACPI table to create clkdev entries mapping audss internal
+ * clocks to their consumer devices. Under ACPI, DT phandle-based clock lookup
+ * is not available, so consumers (HDA, I2S, DMA, etc.) find their clocks via
+ * clkdev entries instead. The CLKA table is a package of {clk_id, con_id,
+ * consumer_device_ref} entries defined in the DSDT on this device's ACPI node.
+ */
+static int sky1_audss_parse_clka(struct device *dev,
+				 struct clk_hw_onecell_data *clk_data)
+{
+	acpi_handle handle = ACPI_HANDLE(dev);
+	struct acpi_buffer output = { ACPI_ALLOCATE_BUFFER, NULL };
+	union acpi_object *out_obj, *entry, *el;
+	acpi_status status;
+	int i, count, registered = 0;
+
+	status = acpi_evaluate_object_typed(handle, "CLKA", NULL, &output,
+					    ACPI_TYPE_PACKAGE);
+	if (ACPI_FAILURE(status))
+		return -ENODEV;
+
+	out_obj = output.pointer;
+	count = out_obj->package.count;
+
+	for (i = 0; i < count; i++) {
+		struct acpi_device *adev;
+		struct clk_hw *hw;
+		unsigned int clk_id;
+		const char *con_id;
+		int ret;
+
+		entry = &out_obj->package.elements[i];
+		if (entry->type != ACPI_TYPE_PACKAGE || entry->package.count < 3)
+			continue;
+
+		el = &entry->package.elements[0];
+		if (el->type != ACPI_TYPE_INTEGER)
+			continue;
+		clk_id = el->integer.value;
+
+		el = &entry->package.elements[1];
+		if (el->type != ACPI_TYPE_STRING)
+			continue;
+		con_id = el->string.pointer;
+		if (!con_id || !con_id[0])
+			con_id = NULL;
+
+		el = &entry->package.elements[2];
+		if (el->type == ACPI_TYPE_LOCAL_REFERENCE)
+			adev = acpi_fetch_acpi_dev(el->reference.handle);
+		else
+			adev = NULL;
+		if (!adev)
+			continue;
+
+		if (clk_id >= clk_data->num)
+			continue;
+		hw = clk_data->hws[clk_id];
+		if (!hw || IS_ERR(hw))
+			continue;
+
+		ret = devm_clk_hw_register_clkdev(dev, hw, con_id,
+						  dev_name(&adev->dev));
+		if (ret) {
+			dev_warn(dev, "CLKA: failed to register %s:%s (clk %u): %d\n",
+				 dev_name(&adev->dev), con_id ?: "", clk_id, ret);
+			continue;
+		}
+
+		dev_dbg(dev, "CLKA: clk %u -> %s:%s\n",
+			clk_id, dev_name(&adev->dev), con_id ?: "");
+		registered++;
+	}
+
+	kfree(output.pointer);
+	dev_info(dev, "CLKA: registered %d clkdev entries\n", registered);
+	return 0;
+}
+
+/*
+ * Under ACPI, transition the AUDSS device to D0 so the PPRS power-resource
+ * _ON method runs (enabling RCSU PD_CTRL power gates and DMRP memory repair)
+ * before any audio subsystem register access.
+ */
+static int sky1_audss_acpi_power_on(struct device *dev)
+{
+	return acpi_device_set_power(ACPI_COMPANION(dev), ACPI_STATE_D0);
+}
+
+/* Inform _DEP consumers (DMA, I2S, HDA, ...) that the clock controller is up. */
+static void sky1_audss_acpi_clear_dependencies(struct device *dev)
+{
+	acpi_dev_clear_dependencies(ACPI_COMPANION(dev));
+}
+
+/*
+ * Under ACPI the AUDSS CRU MMIO is owned by a syscon provider (HID CIXHA018,
+ * bound by drivers/mfd/syscon.c).  This device carries an "audss_cru" _DSD
+ * reference to that provider; borrow its regmap instead of mapping the
+ * registers ourselves (so we don't claim a region described on another device).
+ */
+static struct regmap *sky1_audss_get_acpi_regmap(struct device *dev)
+{
+	struct fwnode_handle *fw;
+	struct device *syscon_dev;
+	struct regmap *regmap;
+
+	fw = fwnode_find_reference(dev_fwnode(dev), "audss_cru", 0);
+	if (IS_ERR(fw))
+		return ERR_CAST(fw);
+
+	syscon_dev = bus_find_device_by_fwnode(&platform_bus_type, fw);
+	fwnode_handle_put(fw);
+	if (!syscon_dev)
+		return ERR_PTR(-EPROBE_DEFER);
+
+	regmap = dev_get_regmap(syscon_dev, NULL);
+	put_device(syscon_dev);
+	if (!regmap)
+		return ERR_PTR(-EPROBE_DEFER);
+
+	return regmap;
+}
+#else
+static inline int sky1_audss_parse_clka(struct device *dev,
+					struct clk_hw_onecell_data *clk_data)
+{
+	return 0;
+}
+
+static inline int sky1_audss_acpi_power_on(struct device *dev)
+{
+	return 0;
+}
+
+static inline void sky1_audss_acpi_clear_dependencies(struct device *dev)
+{
+}
+
+static inline struct regmap *sky1_audss_get_acpi_regmap(struct device *dev)
+{
+	return ERR_PTR(-ENODEV);
+}
+#endif
+
 /*
  * clk_ops for audss clock mux/divider/gate
  */
@@ -975,14 +1138,22 @@ static int sky1_audss_clk_probe(struct platform_device *pdev)
 	priv->clk_data->num = SKY1_AUDSS_NUM_CLKS;
 	clk_table = priv->clk_data->hws;
 
-	base = devm_platform_ioremap_resource(pdev, 0);
-	if (IS_ERR(base))
-		return PTR_ERR(base);
-
-	priv->regmap_cru = devm_regmap_init_mmio(dev, base, &sky1_audss_regmap_config);
-	if (IS_ERR(priv->regmap_cru))
-		return dev_err_probe(dev, PTR_ERR(priv->regmap_cru),
-				     "failed to initialize regmap\n");
+	if (has_acpi_companion(dev)) {
+		priv->regmap_cru = sky1_audss_get_acpi_regmap(dev);
+		if (IS_ERR(priv->regmap_cru))
+			return dev_err_probe(dev, PTR_ERR(priv->regmap_cru),
+					     "failed to get audss_cru regmap\n");
+	} else {
+		base = devm_platform_ioremap_resource(pdev, 0);
+		if (IS_ERR(base))
+			return PTR_ERR(base);
+
+		priv->regmap_cru = devm_regmap_init_mmio(dev, base,
+							 &sky1_audss_regmap_config);
+		if (IS_ERR(priv->regmap_cru))
+			return dev_err_probe(dev, PTR_ERR(priv->regmap_cru),
+					     "failed to initialize regmap\n");
+	}
 
 	priv->dev = dev;
 	priv->devtype_data = devtype_data;
@@ -1000,6 +1171,18 @@ static int sky1_audss_clk_probe(struct platform_device *pdev)
 	pm_runtime_set_active(dev);
 	pm_runtime_enable(dev);
 
+	/*
+	 * Under ACPI, explicitly transition to D0 to invoke the PPRS power
+	 * resource _ON method. PPRS enables the audio subsystem power gates
+	 * (RCSU PD_CTRL) and triggers memory repair via DMRP. This must happen
+	 * before any audio subsystem register access (CRU, reset, DMA, I2S...).
+	 */
+	if (has_acpi_companion(dev)) {
+		ret = sky1_audss_acpi_power_on(dev);
+		if (ret)
+			dev_warn(dev, "ACPI D0 transition failed: %d\n", ret);
+	}
+
 	platform_set_drvdata(pdev, priv);
 
 	ret = sky1_audss_clks_get(priv);
@@ -1077,7 +1260,11 @@ static int sky1_audss_clk_probe(struct platform_device *pdev)
 		}
 	}
 
-	ret = devm_of_clk_add_hw_provider(dev, of_clk_hw_onecell_get, priv->clk_data);
+	if (has_acpi_companion(dev))
+		ret = sky1_audss_parse_clka(dev, priv->clk_data);
+	else
+		ret = devm_of_clk_add_hw_provider(dev, of_clk_hw_onecell_get,
+						  priv->clk_data);
 	if (ret) {
 		dev_err(dev, "failed to add clock provider: %d\n", ret);
 		goto fail_register;
@@ -1087,6 +1274,10 @@ static int sky1_audss_clk_probe(struct platform_device *pdev)
 	if (ret)
 		goto fail_register;
 
+	/* Allow DLKL consumers (DMA, I2S, HDA, etc.) to enumerate now. */
+	if (has_acpi_companion(dev))
+		sky1_audss_acpi_clear_dependencies(dev);
+
 	pm_runtime_put_sync(dev);
 
 	return 0;
@@ -1180,12 +1371,29 @@ static const struct sky1_audss_clks_devtype_data sky1_devtype_data = {
 	.clk_cfg_size = ARRAY_SIZE(sky1_audss_clks),
 };
 
+/* Same as sky1_devtype_data but with ACPI (CLKT) parent clock names. */
+static const struct sky1_audss_clks_devtype_data sky1_acpi_devtype_data = {
+	.reg_save = sky1_reg_save,
+	.reg_save_size = ARRAY_SIZE(sky1_reg_save),
+	.clk_names = sky1_audss_acpi_clk_names,
+	.clk_num = ARRAY_SIZE(sky1_audss_acpi_clk_names),
+	.clk_rate_default = sky1_clk_rate_default,
+	.clk_cfg = sky1_audss_clks,
+	.clk_cfg_size = ARRAY_SIZE(sky1_audss_clks),
+};
+
 static const struct of_device_id sky1_audss_clk_of_match[] = {
 	{ .compatible = "cix,sky1-audss-cru", .data = &sky1_devtype_data, },
 	{ /* sentinel */ },
 };
 MODULE_DEVICE_TABLE(of, sky1_audss_clk_of_match);
 
+static const struct acpi_device_id sky1_audss_clk_acpi_match[] = {
+	{ "CIXH6061", .driver_data = (kernel_ulong_t)&sky1_acpi_devtype_data },
+	{ /* sentinel */ },
+};
+MODULE_DEVICE_TABLE(acpi, sky1_audss_clk_acpi_match);
+
 static struct platform_driver sky1_audss_clk_driver = {
 	.probe = sky1_audss_clk_probe,
 	.remove = sky1_audss_clk_remove,
@@ -1193,6 +1401,7 @@ static struct platform_driver sky1_audss_clk_driver = {
 		.name = "sky1-audss-clk",
 		.suppress_bind_attrs = true,
 		.of_match_table = sky1_audss_clk_of_match,
+		.acpi_match_table = ACPI_PTR(sky1_audss_clk_acpi_match),
 		.pm = &sky1_audss_clk_pm_ops,
 	},
 };
