From: Jianfeng Liu <Jianfeng.Liu@cixtech.com>
Date: Thu, 2 Jul 2026 15:40:23 +0800
Subject: DPTSW-26459: ALSA: hda/realtek: suppress auto-mic on CIX Sky1 boards

CIX Sky1 boards (EVB / Orion O6 / ORAPI 6P) match their realtek fixups by
model name rather than SSID. The fixups only set pin config and coef
verbs, leaving the generic parser's auto-mic heuristic enabled. With two
jack-detectable mic inputs, auto-mic fires and forces a single ADC,
suppressing the "Input Source" mux and the second capture PCM (device 2).
The UCM profiles shipped for these boards expect that dual-ADC topology,
so the mux controls' absence makes their EnableSequence fail and the card
disappears from sound settings.

The 6.6 BSP driver sets suppress_auto_mic for all CIX boards via the
0x10EC129E SSID quirk (ALC256_FIXUP_CIX_PHECDA); the 6.18 model-name
fixups neither set that SSID nor carry the quirk.

Add a shared FUNC fixup ALC256_FIXUP_CIX_SKY1_NO_AUTO_MIC that sets
spec->gen.suppress_auto_mic = true in PRE_PROBE, and chain it after each
board's _COEF entry, restoring the dual-ADC topology to match 6.6.

Signed-off-by: Jianfeng Liu <Jianfeng.Liu@cixtech.com>
Change-Id: Id385284dc9374af5e65589e280c66515a77b3b19
---
 sound/hda/codecs/realtek/alc269.c | 36 +++++++++-
 1 file changed, 33 insertions(+), 3 deletions(-)

diff --git a/sound/hda/codecs/realtek/alc269.c b/sound/hda/codecs/realtek/alc269.c
index 111111111111..222222222222 100644
--- a/sound/hda/codecs/realtek/alc269.c
+++ b/sound/hda/codecs/realtek/alc269.c
@@ -2821,6 +2821,25 @@ static void alc256_fixup_chromebook(struct hda_codec *codec,
 	}
 }
 
+/*
+ * CIX Sky1 boards (EVB / Orion O6 / ORAPI 6P) share a codec SSID and rely on
+ * UCM profiles that reference the generic parser's input mux
+ * ("Input Source" / "Capture Source"). The parser's auto-mic heuristic would
+ * otherwise force a single ADC and suppress that mux (see
+ * check_auto_mic_availability() in generic.c). Disable it so the codec
+ * topology matches the 6.6 BSP driver, which set suppress_auto_mic for all
+ * CIX boards via the 0x10EC129E SSID quirk (alc_fixup_cix_phecda).
+ */
+static void alc256_fixup_cix_sky1_no_auto_mic(struct hda_codec *codec,
+					      const struct hda_fixup *fix,
+					      int action)
+{
+	struct alc_spec *spec = codec->spec;
+
+	if (action == HDA_FIXUP_ACT_PRE_PROBE)
+		spec->gen.suppress_auto_mic = true;
+}
+
 static void alc_fixup_disable_mic_vref(struct hda_codec *codec,
 				  const struct hda_fixup *fix, int action)
 {
@@ -4161,6 +4180,7 @@ enum {
 	ALC256_FIXUP_CIX_SKY1_ORION_O6_COEF,
 	ALC269_FIXUP_CIX_SKY1_ORAPI_6P,
 	ALC269_FIXUP_CIX_SKY1_ORAPI_6P_COEF,
+	ALC256_FIXUP_CIX_SKY1_NO_AUTO_MIC,
 };
 
 /* A special fixup for Lenovo C940 and Yoga Duet 7;
@@ -6778,7 +6798,9 @@ static const struct hda_fixup alc269_fixups[] = {
 			{ 0x57, AC_VERB_SET_COEF_INDEX, 0x03 },
 			{ 0x57, AC_VERB_SET_PROC_COEF,  0x09a3 },
 			{ }
-		}
+		},
+		.chained = true,
+		.chain_id = ALC256_FIXUP_CIX_SKY1_NO_AUTO_MIC
 	},
 	[ALC256_FIXUP_CIX_SKY1_ORION_O6] = {
 		.type = HDA_FIXUP_PINS,
@@ -6823,7 +6845,9 @@ static const struct hda_fixup alc269_fixups[] = {
 			{ 0x57, AC_VERB_SET_COEF_INDEX, 0x03 },
 			{ 0x57, AC_VERB_SET_PROC_COEF,  0x09a3 },
 			{ }
-		}
+		},
+		.chained = true,
+		.chain_id = ALC256_FIXUP_CIX_SKY1_NO_AUTO_MIC
 	},
 	[ALC269_FIXUP_CIX_SKY1_ORAPI_6P] = {
 		.type = HDA_FIXUP_PINS,
@@ -6867,7 +6891,13 @@ static const struct hda_fixup alc269_fixups[] = {
 			{ 0x0d, AC_VERB_SET_AMP_GAIN_MUTE, 0x7080 },
 			{ 0x03, AC_VERB_SET_CHANNEL_STREAMID, 0x10 },
 			{ }
-		}
+		},
+		.chained = true,
+		.chain_id = ALC256_FIXUP_CIX_SKY1_NO_AUTO_MIC
+	},
+	[ALC256_FIXUP_CIX_SKY1_NO_AUTO_MIC] = {
+		.type = HDA_FIXUP_FUNC,
+		.v.func = alc256_fixup_cix_sky1_no_auto_mic
 	}
 };
 
