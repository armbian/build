--- /dev/null
+++ b/drivers/soc/cix/cix-acpi-resource-lookup.c
@@ -0,0 +1,646 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * CIX ACPI Resource Lookup driver
+ *
+ * Processes custom DSDT tables (RSTL, RSNL, DLKL) attached to CIX ACPI
+ * devices to bridge the gap between CIX's ACPI firmware and the Linux
+ * kernel's standard resource lookup mechanisms.
+ *
+ * RSTL (Reset Lookup):   Injects _DSD reset-names/resets properties so that
+ *                        devm_reset_control_get() works under ACPI.
+ * RSNL (Resource Names): Assigns names to platform_device resources by
+ *                        index so platform_get_resource_byname() works.
+ * DLKL (Device Links):   Creates device_link dependencies between
+ *                        supplier and consumer devices.
+ * CLKT (Clock Table):    Creates device_link from each CLKT consumer to
+ *                        the ACPI clock provider (CIXHA010) so that
+ *                        clk-sky1-acpi probes before its consumers.
+ *
+ * Based on vendor driver by Zichar Zhang <zichar.zhang@cixtech.com>
+ */
+
+#include <linux/acpi.h>
+#include <linux/device.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/platform_device.h>
+#include <linux/slab.h>
+#include <linux/uuid.h>
+
+static struct acpi_device *acpi_obj_to_adev(const union acpi_object *obj)
+{
+	acpi_handle handle;
+
+	if (!obj)
+		return NULL;
+
+	if (obj->type == ACPI_TYPE_LOCAL_REFERENCE) {
+		handle = obj->reference.handle;
+	} else if (obj->type == ACPI_TYPE_STRING) {
+		if (ACPI_FAILURE(acpi_get_handle(NULL, obj->string.pointer,
+						 &handle)))
+			return NULL;
+	} else {
+		return NULL;
+	}
+
+	return acpi_fetch_acpi_dev(handle);
+}
+
+static struct device *acpi_obj_to_platform_device(const union acpi_object *obj)
+{
+	struct acpi_device *adev = acpi_obj_to_adev(obj);
+
+	if (!adev)
+		return NULL;
+
+	return bus_find_device_by_acpi_dev(&platform_bus_type, adev);
+}
+
+/*
+ * RSTL — Reset Lookup Table → _DSD property injection
+ *
+ * Each entry: { <provider_ref>, <index>, <consumer_ref>, [<con_id>] }
+ *
+ * Since v7.1 the reset core routes devm_reset_control_get() for ACPI devices
+ * through __fwnode_reset_control_get(), which reads the _DSD-style
+ * "reset-names" and "resets" properties from the consumer's firmware node.
+ * CIX firmware supplies RSTL packages instead of those _DSD properties, so
+ * each RSTL entry is translated into native _DSD Device Properties
+ * (Package() { {name, value}, ... }) and injected into the consumer's
+ * acpi_device_data via acpi_data_add_props().  The "resets" value is a flat
+ * package of (ACPI_TYPE_LOCAL_REFERENCE, ACPI_TYPE_INTEGER) pairs: each
+ * reference points at the reset controller's ACPI handle and the integer is
+ * the reset index.  Provider devices get a "#reset-cells = 1" integer
+ * property.  reset-sky1.c is auto-provisioned by reset_controller_register()
+ * as a fwnode provider (fwnode_reset_simple_xlate, 1 cell), so no
+ * provider-driver change is needed.
+ *
+ * Because the properties live on the ACPI primary fwnode's _DSD data (not a
+ * secondary software node), they do not collide with IORT's secondary swnode
+ * (used for IOMMU props) — the two occupy different layers of the fwnode.
+ *
+ * Entries are collected during the namespace walk and injected afterwards by
+ * rst_inject_dsd_props().
+ */
+struct rst_ref {
+	struct list_head list;
+	acpi_handle provider_handle;
+	unsigned int index;
+	const char *con_id;		/* NULL for index-only resets */
+};
+
+struct rst_dev_entry {
+	struct list_head list;
+	struct acpi_device *adev;	/* provider and/or consumer */
+	bool is_provider;
+	struct list_head resets;	/* list of rst_ref (consumer side) */
+};
+
+static LIST_HEAD(rst_devices);
+
+/* Find or create the per-device collector entry (deduped by adev). */
+static struct rst_dev_entry *rst_dev_entry_get(struct acpi_device *adev)
+{
+	struct rst_dev_entry *entry;
+
+	list_for_each_entry(entry, &rst_devices, list)
+		if (entry->adev == adev)
+			return entry;
+
+	entry = kzalloc_obj(*entry, GFP_KERNEL);
+	if (!entry)
+		return NULL;
+	INIT_LIST_HEAD(&entry->resets);
+	entry->adev = adev;
+	list_add_tail(&entry->list, &rst_devices);
+	return entry;
+}
+
+static int reset_lookup_handle(acpi_handle handle,
+			       const union acpi_object *obj, void *data)
+{
+	struct device *dev = data;
+	const union acpi_object *child, *el;
+	struct acpi_device *padev, *cadev;
+	struct rst_dev_entry *centry, *pentry;
+	struct rst_ref *ref;
+	int i, pcnt, count = 0;
+	struct acpi_device *adev = acpi_fetch_acpi_dev(handle);
+
+	if (!adev || !adev->status.present)
+		return -ENODEV;
+
+	for (i = 0; i < obj->package.count; i++) {
+		child = &obj->package.elements[i];
+		pcnt = child->package.count;
+
+		if (pcnt < 3)
+			continue;
+
+		el = child->package.elements;
+
+		if ((el[0].type != ACPI_TYPE_LOCAL_REFERENCE &&
+		     el[0].type != ACPI_TYPE_STRING) ||
+		    el[1].type != ACPI_TYPE_INTEGER ||
+		    (el[2].type != ACPI_TYPE_LOCAL_REFERENCE &&
+		     el[2].type != ACPI_TYPE_STRING) ||
+		    (pcnt > 3 && el[3].type != ACPI_TYPE_STRING))
+			continue;
+
+		padev = acpi_obj_to_adev(&el[0]);
+		cadev = acpi_obj_to_adev(&el[2]);
+		if (!padev || !cadev)
+			continue;
+
+		pentry = rst_dev_entry_get(padev);
+		centry = rst_dev_entry_get(cadev);
+		if (pentry)
+			pentry->is_provider = true;
+		if (!pentry || !centry)
+			continue;
+
+		ref = kzalloc_obj(*ref, GFP_KERNEL);
+		if (!ref)
+			return -ENOMEM;
+		ref->provider_handle = padev->handle;
+		ref->index = el[1].integer.value;
+		ref->con_id = pcnt > 3 ?
+			devm_kstrdup(dev, el[3].string.pointer, GFP_KERNEL) : NULL;
+		list_add_tail(&ref->list, &centry->resets);
+
+		dev_dbg(&adev->dev,
+			"rst entry: prov[%s] idx[%llu] dev[%s] con[%s]\n",
+			dev_name(&padev->dev), el[1].integer.value,
+			dev_name(&cadev->dev), ref->con_id ?: "<none>");
+		count++;
+	}
+
+	dev_dbg(&adev->dev, "reset entries collected: %d/%d\n",
+		count, obj->package.count);
+
+	return count;
+}
+
+/*
+ * RSNL — Resource Name Lookup Table
+ *
+ * Each entry: { <device_ref>, <type>, <index>, <name> }
+ * Assigns a name to the device's platform resource at <type>/<index>,
+ * so platform_get_resource_byname() can find it.
+ */
+static int resource_name_lookup_handle(acpi_handle handle,
+				       const union acpi_object *obj, void *data)
+{
+	struct device *rdev, *dev = data;
+	const union acpi_object *child, *el;
+	int i, pcnt, count = 0, index;
+	unsigned int type;
+	struct resource *res;
+	const char *name;
+	struct acpi_device *adev = acpi_fetch_acpi_dev(handle);
+
+	if (!adev || !adev->status.present)
+		return -ENODEV;
+
+	for (i = 0; i < obj->package.count; i++) {
+		child = &obj->package.elements[i];
+		pcnt = child->package.count;
+
+		if (pcnt != 4)
+			continue;
+
+		el = child->package.elements;
+
+		if ((el[0].type != ACPI_TYPE_LOCAL_REFERENCE &&
+		     el[0].type != ACPI_TYPE_STRING) ||
+		    el[1].type != ACPI_TYPE_INTEGER ||
+		    el[2].type != ACPI_TYPE_INTEGER ||
+		    el[3].type != ACPI_TYPE_STRING)
+			continue;
+
+		rdev = acpi_obj_to_platform_device(&el[0]);
+		type = el[1].integer.value;
+		index = el[2].integer.value;
+		name = devm_kstrdup(dev, el[3].string.pointer, GFP_KERNEL);
+		if (!rdev || !name)
+			continue;
+
+		res = platform_get_resource(to_platform_device(rdev),
+					    type, index);
+		if (!res)
+			continue;
+		res->name = name;
+
+		if ((res->flags & IORESOURCE_IRQ) &&
+		    (res->flags & IORESOURCE_DISABLED))
+			acpi_irq_get(ACPI_HANDLE(rdev), index, res);
+
+		dev_dbg(&adev->dev, "resource name [%s][0x%x][%d]->[%s]\n",
+			dev_name(rdev), type, index, name);
+
+		count++;
+	}
+
+	dev_dbg(&adev->dev, "resource name lookup: %d/%d entries\n",
+		count, obj->package.count);
+
+	return count;
+}
+
+/*
+ * DLKL — Device Link Lookup Table
+ *
+ * Each entry: { <supplier_ref>, <consumer_ref>, <flags> }
+ * Creates a device_link between supplier and consumer with given flags.
+ */
+static int device_link_lookup_handle(acpi_handle handle,
+				     const union acpi_object *obj, void *data)
+{
+	struct device *consumer, *supplier;
+	const union acpi_object *child, *el;
+	int i, pcnt, count = 0;
+	u32 flags;
+	struct acpi_device *adev = acpi_fetch_acpi_dev(handle);
+
+	if (!adev || !adev->status.present)
+		return -ENODEV;
+
+	for (i = 0; i < obj->package.count; i++) {
+		child = &obj->package.elements[i];
+		pcnt = child->package.count;
+
+		if (pcnt != 3)
+			continue;
+
+		el = child->package.elements;
+
+		if ((el[0].type != ACPI_TYPE_LOCAL_REFERENCE &&
+		     el[0].type != ACPI_TYPE_STRING) ||
+		    (el[1].type != ACPI_TYPE_LOCAL_REFERENCE &&
+		     el[1].type != ACPI_TYPE_STRING) ||
+		    el[2].type != ACPI_TYPE_INTEGER)
+			continue;
+
+		supplier = acpi_obj_to_platform_device(&el[0]);
+		consumer = acpi_obj_to_platform_device(&el[1]);
+		flags = (u32)el[2].integer.value;
+
+		if (!supplier || !consumer)
+			continue;
+
+		device_link_add(consumer, supplier, flags);
+
+		dev_dbg(&adev->dev, "device link [%s]->[%s] flags[%u]\n",
+			dev_name(consumer), dev_name(supplier), flags);
+
+		count++;
+	}
+
+	dev_dbg(&adev->dev, "device link lookup: %d/%d entries\n",
+		count, obj->package.count);
+
+	return count;
+}
+
+/*
+ * CLKT — Clock Table
+ *
+ * Devices with CLKT tables depend on the ACPI clock provider
+ * (CIXHA010 / clk-sky1-acpi) to register clkdev lookups before
+ * they can probe.  Create a device_link to enforce this ordering
+ * so consumers don't need to rely on deferred probe.
+ */
+static int clock_dependency_handle(acpi_handle handle,
+				   const union acpi_object *obj, void *data)
+{
+	struct acpi_device *adev;
+	struct device *consumer, *supplier;
+
+	if (!obj || obj->package.count == 0)
+		return 0;
+
+	adev = acpi_fetch_acpi_dev(handle);
+	if (!adev || !adev->status.present)
+		return -ENODEV;
+
+	consumer = bus_find_device_by_acpi_dev(&platform_bus_type, adev);
+	if (!consumer)
+		return 0;
+
+	supplier = bus_find_device_by_name(&platform_bus_type, NULL,
+					   "CIXHA010:00");
+	if (!supplier || supplier == consumer)
+		return 0;
+
+	device_link_add(consumer, supplier, DL_FLAG_AUTOREMOVE_CONSUMER);
+
+	dev_dbg(data, "clock link [%s]->[CIXHA010:00]\n", dev_name(consumer));
+
+	return 1;
+}
+
+static int acpi_res_lookup_eval(acpi_handle handle, const char *name,
+		int (*func)(acpi_handle, const union acpi_object *, void *),
+		void *data)
+{
+	struct acpi_buffer output = {ACPI_ALLOCATE_BUFFER, NULL};
+	acpi_status status;
+	int ret;
+
+	status = acpi_evaluate_object_typed(handle, (acpi_string)name,
+					    NULL, &output, ACPI_TYPE_PACKAGE);
+	if (ACPI_FAILURE(status))
+		return -ENODEV;
+
+	ret = func(handle, (const union acpi_object *)output.pointer, data);
+	kfree(output.pointer);
+
+	return ret;
+}
+
+static int acpi_resource_lookup_device(acpi_handle handle, void *data)
+{
+	struct device *dev = data;
+	int ret;
+
+	ret = acpi_res_lookup_eval(handle, "RSTL", reset_lookup_handle, dev);
+	if (ret < 0 && ret != -ENODEV)
+		dev_dbg(dev, "reset lookup handle failed for %s\n",
+			acpi_device_hid(acpi_fetch_acpi_dev(handle)));
+
+	ret = acpi_res_lookup_eval(handle, "RSNL",
+				   resource_name_lookup_handle, dev);
+	if (ret < 0 && ret != -ENODEV)
+		dev_dbg(dev, "resource name lookup handle failed for %s\n",
+			acpi_device_hid(acpi_fetch_acpi_dev(handle)));
+
+	ret = acpi_res_lookup_eval(handle, "DLKL",
+				   device_link_lookup_handle, dev);
+	if (ret < 0 && ret != -ENODEV)
+		dev_dbg(dev, "device link lookup handle failed for %s\n",
+			acpi_device_hid(acpi_fetch_acpi_dev(handle)));
+
+	ret = acpi_res_lookup_eval(handle, "CLKT",
+				   clock_dependency_handle, dev);
+	if (ret < 0 && ret != -ENODEV)
+		dev_dbg(dev, "clock dependency handle failed for %s\n",
+			acpi_device_hid(acpi_fetch_acpi_dev(handle)));
+
+	return 0;
+}
+
+static acpi_status acpi_bus_res_scan(acpi_handle handle, u32 level,
+				     void *context, void **ret_p)
+{
+	struct device *dev = context;
+	acpi_object_type acpi_type;
+
+	if (!dev)
+		return AE_OK;
+
+	if (ACPI_FAILURE(acpi_get_type(handle, &acpi_type)))
+		return AE_OK;
+
+	if (acpi_type != ACPI_TYPE_DEVICE)
+		return AE_OK;
+
+	acpi_resource_lookup_device(handle, dev);
+
+	return AE_OK;
+}
+
+/*
+ * rst_build_dsd_package - build a _DSD Device Properties package for @dent.
+ *
+ * Returns a devm-allocated top-level Package() of {name, value} sub-packages
+ * ("#reset-cells" for providers, "reset-names"+"resets" for consumers), or
+ * NULL if @dent has nothing to inject.  The "resets" value is a flat package
+ * of (ACPI_TYPE_LOCAL_REFERENCE, ACPI_TYPE_INTEGER) pairs; named resets come
+ * first and are aligned with "reset-names", index-only resets at the tail.
+ */
+static union acpi_object *
+rst_build_dsd_package(struct device *dev, struct rst_dev_entry *dent)
+{
+	struct rst_ref *ref;
+	int n = 0, n_named = 0, nsubs = 0, i = 0;
+	union acpi_object *top, *top_elems;
+
+	list_for_each_entry(ref, &dent->resets, list) {
+		n++;
+		if (ref->con_id)
+			n_named++;
+	}
+
+	if (dent->is_provider)
+		nsubs++;			/* #reset-cells */
+	if (n_named)
+		nsubs++;			/* reset-names */
+	if (n)
+		nsubs++;			/* resets */
+	if (!nsubs)
+		return NULL;
+
+	top_elems = devm_kcalloc(dev, nsubs, sizeof(*top_elems), GFP_KERNEL);
+	if (!top_elems)
+		return NULL;
+
+	if (dent->is_provider) {
+		union acpi_object *e = devm_kcalloc(dev, 2, sizeof(*e), GFP_KERNEL);
+
+		if (!e)
+			return NULL;
+		e[0].type = ACPI_TYPE_STRING;
+		e[0].string.pointer = (char *)"#reset-cells";
+		e[0].string.length = sizeof("#reset-cells") - 1;
+		e[1].type = ACPI_TYPE_INTEGER;
+		e[1].integer.value = 1;
+		top_elems[i].type = ACPI_TYPE_PACKAGE;
+		top_elems[i].package.count = 2;
+		top_elems[i].package.elements = e;
+		i++;
+	}
+
+	if (n_named) {
+		union acpi_object *names = devm_kcalloc(dev, n_named,
+							sizeof(*names), GFP_KERNEL);
+		union acpi_object *e;
+		int j = 0;
+
+		if (!names)
+			return NULL;
+		list_for_each_entry(ref, &dent->resets, list) {
+			if (!ref->con_id)
+				continue;
+			names[j].type = ACPI_TYPE_STRING;
+			names[j].string.pointer = (char *)ref->con_id;
+			names[j].string.length = strlen(ref->con_id);
+			j++;
+		}
+		e = devm_kcalloc(dev, 2, sizeof(*e), GFP_KERNEL);
+		if (!e)
+			return NULL;
+		e[0].type = ACPI_TYPE_STRING;
+		e[0].string.pointer = (char *)"reset-names";
+		e[0].string.length = sizeof("reset-names") - 1;
+		e[1].type = ACPI_TYPE_PACKAGE;
+		e[1].package.count = n_named;
+		e[1].package.elements = names;
+		top_elems[i].type = ACPI_TYPE_PACKAGE;
+		top_elems[i].package.count = 2;
+		top_elems[i].package.elements = e;
+		i++;
+	}
+
+	if (n) {
+		union acpi_object *rsets = devm_kcalloc(dev, 2 * n,
+							sizeof(*rsets), GFP_KERNEL);
+		union acpi_object *e;
+		int j = 0;
+
+		if (!rsets)
+			return NULL;
+		/* named resets first, aligned with reset-names[] */
+		list_for_each_entry(ref, &dent->resets, list) {
+			if (!ref->con_id)
+				continue;
+			rsets[j].type = ACPI_TYPE_LOCAL_REFERENCE;
+			rsets[j].reference.handle = ref->provider_handle;
+			j++;
+			rsets[j].type = ACPI_TYPE_INTEGER;
+			rsets[j].integer.value = ref->index;
+			j++;
+		}
+		/* index-only resets at the tail */
+		list_for_each_entry(ref, &dent->resets, list) {
+			if (ref->con_id)
+				continue;
+			rsets[j].type = ACPI_TYPE_LOCAL_REFERENCE;
+			rsets[j].reference.handle = ref->provider_handle;
+			j++;
+			rsets[j].type = ACPI_TYPE_INTEGER;
+			rsets[j].integer.value = ref->index;
+			j++;
+			dev_warn(dev, "rst: index-only reset on %s has no con_id\n",
+				 acpi_dev_name(dent->adev));
+		}
+		e = devm_kcalloc(dev, 2, sizeof(*e), GFP_KERNEL);
+		if (!e)
+			return NULL;
+		e[0].type = ACPI_TYPE_STRING;
+		e[0].string.pointer = (char *)"resets";
+		e[0].string.length = sizeof("resets") - 1;
+		e[1].type = ACPI_TYPE_PACKAGE;
+		e[1].package.count = 2 * n;
+		e[1].package.elements = rsets;
+		top_elems[i].type = ACPI_TYPE_PACKAGE;
+		top_elems[i].package.count = 2;
+		top_elems[i].package.elements = e;
+		i++;
+	}
+
+	top = devm_kmalloc(dev, sizeof(*top), GFP_KERNEL);
+	if (!top)
+		return NULL;
+	top->type = ACPI_TYPE_PACKAGE;
+	top->package.count = nsubs;
+	top->package.elements = top_elems;
+	return top;
+}
+
+/*
+ * rst_inject_dsd_props - inject the collected RSTL resets as _DSD properties.
+ *
+ * For each device that appeared in any RSTL entry, build a _DSD Device
+ * Properties package and add it to the device's acpi_device_data via
+ * acpi_data_add_props(), so __fwnode_reset_control_get() resolves the resets
+ * through the native ACPI fwnode ops (acpi_data_get_property /
+ * acpi_fwnode_get_reference_args).  acpi_data_get_property() requires
+ * adev->data.pointer to be non-NULL, so devices lacking a firmware _DSD get a
+ * small dummy buffer (never dereferenced — data.pointer is only a non-NULL
+ * guard and a kfree target — freed by the ACPI core on device removal).
+ */
+static void rst_inject_dsd_props(struct device *bridge_dev)
+{
+	/* ACPI _DSD Device Properties GUID: daffd814-6eba-4d8c-8a91-bc9bbf4aa301 */
+	static const guid_t dsd_guid =
+		GUID_INIT(0xdaffd814, 0x6eba, 0x4d8c,
+			  0x8a, 0x91, 0xbc, 0x9b, 0xbf, 0x4a, 0xa3, 0x01);
+	struct rst_dev_entry *dent, *dtmp;
+	struct rst_ref *ref, *rtmp;
+	int injected = 0;
+
+	list_for_each_entry_safe(dent, dtmp, &rst_devices, list) {
+		union acpi_object *pkg;
+		struct acpi_device_properties *props;
+
+		pkg = rst_build_dsd_package(bridge_dev, dent);
+		if (!pkg)
+			goto free_entry;
+
+		if (!dent->adev->data.pointer) {
+			union acpi_object *dummy = kzalloc_obj(*dummy, GFP_KERNEL);
+
+			if (!dummy)
+				goto free_entry;
+			dent->adev->data.pointer = dummy;
+		}
+
+		props = acpi_data_add_props(&dent->adev->data, &dsd_guid, pkg);
+		if (!props)
+			dev_warn(bridge_dev,
+				 "failed to inject reset _DSD props to %s\n",
+				 acpi_dev_name(dent->adev));
+		else
+			injected++;
+
+free_entry:
+		list_for_each_entry_safe(ref, rtmp, &dent->resets, list) {
+			list_del(&ref->list);
+			kfree(ref);
+		}
+		list_del(&dent->list);
+		kfree(dent);
+	}
+
+	dev_info(bridge_dev, "reset _DSD props injected on %d devices\n",
+		 injected);
+}
+
+static int acpi_resource_lookup_probe(struct platform_device *pdev)
+{
+	acpi_walk_namespace(ACPI_TYPE_ANY, ACPI_ROOT_OBJECT,
+			    ACPI_UINT32_MAX, acpi_bus_res_scan, NULL,
+			    &pdev->dev, NULL);
+
+	rst_inject_dsd_props(&pdev->dev);
+
+	dev_info(&pdev->dev, "ACPI resource lookup complete\n");
+	return 0;
+}
+
+static const struct acpi_device_id acpi_resource_lookup_match[] = {
+	{ "CIXA1019" },
+	{},
+};
+MODULE_DEVICE_TABLE(acpi, acpi_resource_lookup_match);
+
+static struct platform_driver acpi_resource_lookup_driver = {
+	.driver = {
+		.name = "cix-acpi-resource-lookup",
+		.acpi_match_table = ACPI_PTR(acpi_resource_lookup_match),
+	},
+	.probe = acpi_resource_lookup_probe,
+};
+
+static int __init acpi_resource_lookup_init(void)
+{
+	if (acpi_disabled)
+		return -ENODEV;
+
+	return platform_driver_register(&acpi_resource_lookup_driver);
+}
+subsys_initcall(acpi_resource_lookup_init);
+
+MODULE_DESCRIPTION("CIX ACPI resource lookup driver");
+MODULE_LICENSE("GPL");
