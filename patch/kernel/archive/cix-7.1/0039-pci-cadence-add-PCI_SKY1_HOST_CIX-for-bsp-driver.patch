From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Jianfeng Liu <Jianfeng.Liu@cixtech.com>
Date: Thu, 21 May 2026 18:11:17 +0800
Subject: pci: cadence: add PCI_SKY1_HOST_CIX for bsp driver

---
 drivers/pci/controller/cadence/Kconfig  | 6 ++++++
 drivers/pci/controller/cadence/Makefile | 5 ++---
 2 files changed, 8 insertions(+), 3 deletions(-)

diff --git a/drivers/pci/controller/cadence/Kconfig b/drivers/pci/controller/cadence/Kconfig
index 111111111111..222222222222 100644
--- a/drivers/pci/controller/cadence/Kconfig
+++ b/drivers/pci/controller/cadence/Kconfig
@@ -57,6 +57,12 @@ config PCI_SKY1_HOST
 	  (PCIE_CADENCE_HOST) and hardware platform adaptation layer
 	  to function.
 
+config PCI_SKY1_HOST_CIX
+	bool "CIX SKY1 PCIe controller (host mode) for ACPI"
+	depends on ACPI && (ARCH_CIX || COMPILE_TEST)
+	select PCIE_CADENCE_HOST
+	select PCI_ECAM
+
 config PCIE_SG2042_HOST
 	tristate "Sophgo SG2042 PCIe controller (host mode)"
 	depends on OF && (ARCH_SOPHGO || COMPILE_TEST)
diff --git a/drivers/pci/controller/cadence/Makefile b/drivers/pci/controller/cadence/Makefile
index 111111111111..222222222222 100644
--- a/drivers/pci/controller/cadence/Makefile
+++ b/drivers/pci/controller/cadence/Makefile
@@ -10,6 +10,5 @@ obj-$(CONFIG_PCIE_CADENCE_PLAT) += pcie-cadence-plat.o
 obj-$(CONFIG_PCI_J721E) += pci-j721e.o
 obj-$(CONFIG_PCIE_SG2042_HOST) += pcie-sg2042.o
 obj-$(CONFIG_PCI_SKY1_HOST) += pci-sky1.o
-obj-$(CONFIG_PCI_SKY1_HOST) += pci-sky1-acpi.o
-obj-$(CONFIG_PCI_SKY1_HOST) += pci-sky1-cix.o
-obj-$(CONFIG_PCI_SKY1_HOST) += pci-sky1-debugfs.o
+pci-sky1-host-cix-y := pci-sky1-acpi.o pci-sky1-cix.o pci-sky1-debugfs.o
+obj-$(CONFIG_PCI_SKY1_HOST_CIX) += pci-sky1-host-cix.o
-- 
Armbian

