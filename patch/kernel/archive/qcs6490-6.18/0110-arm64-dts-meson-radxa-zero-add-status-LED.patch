From 568c41c88ae96a8adba10ec69576cf8a95dfaad6 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Tue, 30 Dec 2025 09:50:31 +0000
Subject: [PATCH 110/121] arm64: dts: meson: radxa-zero: add status LED

Add the device tree node for the green status LED found on the Radxa Zero.

In version 1.51, the LED is connected to GPIOAO_10, while in older versions,
the LED is connected to GPIOAO_8.

Both are configured to use the 'heartbeat' default trigger
to indicate system activity.

If the user needs to use the corresponding GPIO,
they can use the radxa-overlay to disable it.

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 .../dts/amlogic/meson-g12a-radxa-zero.dts     | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
index d6a117b49b1b..a2e9869d295a 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
@@ -7,6 +7,7 @@
 
 #include "meson-g12a.dtsi"
 #include <dt-bindings/gpio/meson-g12a-gpio.h>
+#include <dt-bindings/leds/common.h>
 #include <dt-bindings/sound/meson-g12a-tohdmitx.h>
 #include <dt-bindings/usb/pd.h>
 
@@ -130,6 +131,24 @@ vddcpu: regulator-vddcpu {
 		regulator-always-on;
 	};
 
+	leds {
+		compatible = "gpio-leds";
+
+		led_power: led-power {
+			color = <LED_COLOR_ID_GREEN>;
+			function = LED_FUNCTION_STATUS;
+			gpios = <&gpio_ao GPIOAO_8 GPIO_ACTIVE_HIGH>;
+			linux,default-trigger = LED_FUNCTION_HEARTBEAT;
+		};
+
+		led_power_151: led-power-151 {
+			color = <LED_COLOR_ID_GREEN>;
+			function = LED_FUNCTION_STATUS;
+			gpios = <&gpio_ao GPIOAO_10 GPIO_ACTIVE_HIGH>;
+			linux,default-trigger = LED_FUNCTION_HEARTBEAT;
+		};
+	};
+
 	typec_vbus: regulator-typec-vbus {
 		compatible = "regulator-fixed";
 		regulator-name = "TYPEC_VBUS";
-- 
