From e4a2634881f38c5e294d12253c8e60615bc9b6b3 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Mon, 5 Jan 2026 02:42:37 +0000
Subject: [PATCH 113/121] arm64: dts: meson: radxa-zero series: rename
 TYPEC_VBUS to AO_5V_B

As per the schematic.

Link:
  https://dl.radxa.com/zero/docs/hw/
  https://dl.radxa.com/zero2pro/docs/hw/

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts  | 6 +++---
 arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts | 6 +++---
 2 files changed, 6 insertions(+), 6 deletions(-)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
index a2e9869d295a..96b54e74612c 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
@@ -149,9 +149,9 @@ led_power_151: led-power-151 {
 		};
 	};
 
-	typec_vbus: regulator-typec-vbus {
+	ao_5v_b: regulator-ao-5v-b {
 		compatible = "regulator-fixed";
-		regulator-name = "TYPEC_VBUS";
+		regulator-name = "AO_5V_B";
 		regulator-min-microvolt = <5000000>;
 		regulator-max-microvolt = <5000000>;
 		vin-supply = <&ao_5v>;
@@ -318,7 +318,7 @@ fusb302@22 {
 		tcpm,skip-vsafe0v-check;
 		fcs,force-vbus-toggle;
 
-		vbus-supply = <&typec_vbus>;
+		vbus-supply = <&ao_5v_b>;
 
 		status = "okay";
 
diff --git a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
index fd069bf71b7d..f6c1891511e2 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
@@ -168,9 +168,9 @@ vddcpu_b: regulator-vddcpu-b {
 		regulator-always-on;
 	};
 
-	typec_vbus: regulator-typec-vbus {
+	ao_5v_b: regulator-ao-5v-b {
 		compatible = "regulator-fixed";
-		regulator-name = "TYPEC_VBUS";
+		regulator-name = "AO_5V_B";
 		regulator-min-microvolt = <5000000>;
 		regulator-max-microvolt = <5000000>;
 		pinctrl-0 = <&typec_vbus_en>;
@@ -424,7 +424,7 @@ fusb302@22 {
 		interrupt-parent = <&gpio_intc>;
 		interrupts = <IRQID_GPIOA_13 IRQ_TYPE_LEVEL_LOW>;
 
-		vbus-supply = <&typec_vbus>;
+		vbus-supply = <&ao_5v_b>;
 
 		status = "okay";
 
-- 
2.39.5

