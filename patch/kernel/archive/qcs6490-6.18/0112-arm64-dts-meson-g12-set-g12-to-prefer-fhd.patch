From e86b59e476df71836f4cbb60561dcf705860d021 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Sun, 4 Jan 2026 09:43:30 +0000
Subject: [PATCH 112/121] arm64: dts: meson: g12: set g12 to prefer-fhd

Enhanced unboxing experience

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 arch/arm64/boot/dts/amlogic/meson-g12.dtsi | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12.dtsi b/arch/arm64/boot/dts/amlogic/meson-g12.dtsi
index 664912d1beaa..4e10616b494e 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12.dtsi
+++ b/arch/arm64/boot/dts/amlogic/meson-g12.dtsi
@@ -369,6 +369,8 @@ &hdmi_tx {
 
 &vpu {
 	power-domains = <&pwrc PWRC_G12A_VPU_ID>;
+	quirk-prefer-fhd;
+	quirk-prefer-large-60;
 };
 
 &sd_emmc_a {
