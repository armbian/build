From 030a115176f57bf47e7b76c9fd3a3894483c9e65 Mon Sep 17 00:00:00 2001
From: Xilin Wu <sophon@radxa.com>
Date: Mon, 17 Nov 2025 10:23:29 +0800
Subject: [PATCH 052/121] arm64: dts: qcom: sc7280: Describe the MBI
 functionality in gic-v3

Describe the Message Based Interrupt functionality provided by the GICv3
in sc7280. Also, add the msi-map properties needed to use the feature.
This allows for assigning affinity to individual MSIs.

Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 arch/arm64/boot/dts/qcom/sc7280.dtsi | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/sc7280.dtsi b/arch/arm64/boot/dts/qcom/sc7280.dtsi
index d5994f5759c1..36a21f4f9ea8 100644
--- a/arch/arm64/boot/dts/qcom/sc7280.dtsi
+++ b/arch/arm64/boot/dts/qcom/sc7280.dtsi
@@ -2225,6 +2225,8 @@ pcie0: pcie@1c00000 {
 			ranges = <0x01000000 0x0 0x00000000 0x0 0x60200000 0x0 0x100000>,
 				 <0x02000000 0x0 0x60300000 0x0 0x60300000 0x0 0x3d00000>;
 
+			msi-map = <0x0 &intc 0x0 0x1000>;
+
 			interrupts = <GIC_SPI 141 IRQ_TYPE_LEVEL_HIGH>,
 				     <GIC_SPI 142 IRQ_TYPE_LEVEL_HIGH>,
 				     <GIC_SPI 143 IRQ_TYPE_LEVEL_HIGH>,
@@ -2387,6 +2389,8 @@ pcie1: pcie@1c08000 {
 			ranges = <0x01000000 0x0 0x00000000 0x0 0x40200000 0x0 0x100000>,
 				 <0x02000000 0x0 0x40300000 0x0 0x40300000 0x0 0x1fd00000>;
 
+			msi-map = <0x0 &intc 0x0 0x1000>;
+
 			interrupts = <GIC_SPI 307 IRQ_TYPE_LEVEL_HIGH>,
 				     <GIC_SPI 308 IRQ_TYPE_LEVEL_HIGH>,
 				     <GIC_SPI 309 IRQ_TYPE_LEVEL_HIGH>,
@@ -6530,6 +6534,9 @@ intc: interrupt-controller@17a00000 {
 			reg = <0 0x17a00000 0 0x10000>,     /* GICD */
 			      <0 0x17a60000 0 0x100000>;    /* GICR * 8 */
 			interrupts = <GIC_PPI 9 IRQ_TYPE_LEVEL_LOW>;
+			mbi-alias = <0x0 0x17a10000>;
+			mbi-ranges = <832 128>;
+			msi-controller;
 			#interrupt-cells = <3>;
 			interrupt-controller;
 			#address-cells = <2>;
-- 
2.39.5

