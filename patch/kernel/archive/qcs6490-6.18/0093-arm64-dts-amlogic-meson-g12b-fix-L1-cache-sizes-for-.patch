From 30ef72b978068bc98c17ece2a23c0ecd19b5b752 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Wed, 10 Dec 2025 08:03:44 +0000
Subject: [PATCH 093/121] arm64: dts: amlogic: meson-g12b: fix L1 cache sizes
 for S922X CPUs

Amlogic S922X SoC each Cortex-A73 core has 64 KB of L1 instruction cache and
64 KB of L1 data cache available.
The original addition of cache information for the Amlogic S922X SoC
used the wrong sizes of L1 cache.

Fixes: e7f85e6c155a ("arm64: dts: amlogic: Add cache information to the Amlogic S922X
SoC")

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 arch/arm64/boot/dts/amlogic/meson-g12b.dtsi | 24 ++++++++++-----------
 1 file changed, 12 insertions(+), 12 deletions(-)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12b.dtsi b/arch/arm64/boot/dts/amlogic/meson-g12b.dtsi
index 23358d94844c..28e426f1f0ed 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12b.dtsi
+++ b/arch/arm64/boot/dts/amlogic/meson-g12b.dtsi
@@ -81,12 +81,12 @@ cpu100: cpu@100 {
 			reg = <0x0 0x100>;
 			enable-method = "psci";
 			capacity-dmips-mhz = <1024>;
-			d-cache-line-size = <32>;
-			d-cache-size = <0x8000>;
-			d-cache-sets = <32>;
-			i-cache-line-size = <32>;
-			i-cache-size = <0x8000>;
-			i-cache-sets = <32>;
+			d-cache-line-size = <64>;
+			d-cache-size = <0x10000>;
+			d-cache-sets = <64>;
+			i-cache-line-size = <64>;
+			i-cache-size = <0x10000>;
+			i-cache-sets = <64>;
 			next-level-cache = <&l2_cache_b>;
 			#cooling-cells = <2>;
 		};
@@ -97,12 +97,12 @@ cpu101: cpu@101 {
 			reg = <0x0 0x101>;
 			enable-method = "psci";
 			capacity-dmips-mhz = <1024>;
-			d-cache-line-size = <32>;
-			d-cache-size = <0x8000>;
-			d-cache-sets = <32>;
-			i-cache-line-size = <32>;
-			i-cache-size = <0x8000>;
-			i-cache-sets = <32>;
+			d-cache-line-size = <64>;
+			d-cache-size = <0x10000>;
+			d-cache-sets = <64>;
+			i-cache-line-size = <64>;
+			i-cache-size = <0x10000>;
+			i-cache-sets = <64>;
 			next-level-cache = <&l2_cache_b>;
 			#cooling-cells = <2>;
 		};
-- 
2.39.5

