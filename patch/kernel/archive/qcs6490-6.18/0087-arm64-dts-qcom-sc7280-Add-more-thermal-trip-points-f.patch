From 3816753de266b5964a912367ab58f016f4d95100 Mon Sep 17 00:00:00 2001
From: Xilin Wu <sophon@radxa.com>
Date: Tue, 23 Dec 2025 21:59:26 +0800
Subject: [PATCH 087/121] arm64: dts: qcom: sc7280: Add more thermal trip
 points for GPU

On some devices (e.g. Radxa Dragon Q6A), it is easy to trigger an
emergency shutdown due to the GPU overheating when no fan is installed.

Add more thermal trip points for the GPU to ensure it throttles
proactively before reaching critical temperatures.

Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 arch/arm64/boot/dts/qcom/sc7280.dtsi | 44 ++++++++++++++++++++++++++++
 1 file changed, 44 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/sc7280.dtsi b/arch/arm64/boot/dts/qcom/sc7280.dtsi
index 842086cfa824..d8a1130e37d0 100644
--- a/arch/arm64/boot/dts/qcom/sc7280.dtsi
+++ b/arch/arm64/boot/dts/qcom/sc7280.dtsi
@@ -7332,6 +7332,18 @@ gpuss0_alert0: trip-point0 {
 					type = "passive";
 				};
 
+				gpuss0_alert1: trip-point1 {
+					temperature = <100000>;
+					hysteresis = <2000>;
+					type = "passive";
+				};
+
+				gpuss0_alert2: trip-point2 {
+					temperature = <105000>;
+					hysteresis = <2000>;
+					type = "passive";
+				};
+
 				gpuss0_crit: gpuss0-crit {
 					temperature = <110000>;
 					hysteresis = <0>;
@@ -7344,6 +7356,16 @@ map0 {
 					trip = <&gpuss0_alert0>;
 					cooling-device = <&gpu THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
 				};
+
+				map1 {
+					trip = <&gpuss0_alert1>;
+					cooling-device = <&gpu THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
+				};
+
+				map2 {
+					trip = <&gpuss0_alert2>;
+					cooling-device = <&gpu THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
+				};
 			};
 		};
 
@@ -7359,6 +7381,18 @@ gpuss1_alert0: trip-point0 {
 					type = "passive";
 				};
 
+				gpuss1_alert1: trip-point1 {
+					temperature = <100000>;
+					hysteresis = <2000>;
+					type = "passive";
+				};
+
+				gpuss1_alert2: trip-point2 {
+					temperature = <105000>;
+					hysteresis = <2000>;
+					type = "passive";
+				};
+
 				gpuss1_crit: gpuss1-crit {
 					temperature = <110000>;
 					hysteresis = <0>;
@@ -7371,6 +7405,16 @@ map0 {
 					trip = <&gpuss1_alert0>;
 					cooling-device = <&gpu THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
 				};
+
+				map1 {
+					trip = <&gpuss1_alert1>;
+					cooling-device = <&gpu THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
+				};
+
+				map2 {
+					trip = <&gpuss1_alert2>;
+					cooling-device = <&gpu THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
+				};
 			};
 		};
 
