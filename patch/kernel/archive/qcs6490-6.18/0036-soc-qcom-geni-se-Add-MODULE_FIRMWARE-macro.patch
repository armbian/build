From: Xilin Wu <sophon@radxa.com>
Date: Tue, 22 Jul 2025 18:01:54 +0800
Subject: [PATCH 036/121] soc: qcom: geni-se: Add MODULE_FIRMWARE macro

Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 drivers/i2c/busses/i2c-qcom-geni.c    | 1 +
 drivers/soc/qcom/qcom-geni-se.c       | 1 +
 drivers/spi/spi-geni-qcom.c           | 1 +
 drivers/tty/serial/qcom_geni_serial.c | 1 +
 4 files changed, 4 insertions(+)

diff --git a/drivers/i2c/busses/i2c-qcom-geni.c b/drivers/i2c/busses/i2c-qcom-geni.c
index 43fdd89b8beb..aa54d2f3b6d2 100644
--- a/drivers/i2c/busses/i2c-qcom-geni.c
+++ b/drivers/i2c/busses/i2c-qcom-geni.c
@@ -1082,3 +1082,4 @@ module_platform_driver(geni_i2c_driver);
 
 MODULE_DESCRIPTION("I2C Controller Driver for GENI based QUP cores");
 MODULE_LICENSE("GPL v2");
+MODULE_FIRMWARE("qcom/qcm6490/qupv3fw.elf");
diff --git a/drivers/soc/qcom/qcom-geni-se.c b/drivers/soc/qcom/qcom-geni-se.c
index cd1779b6a91a..eebaf2794615 100644
--- a/drivers/soc/qcom/qcom-geni-se.c
+++ b/drivers/soc/qcom/qcom-geni-se.c
@@ -1449,3 +1449,4 @@ module_platform_driver(geni_se_driver);
 
 MODULE_DESCRIPTION("GENI Serial Engine Driver");
 MODULE_LICENSE("GPL v2");
+MODULE_FIRMWARE("qcom/qcm6490/qupv3fw.elf");
diff --git a/drivers/spi/spi-geni-qcom.c b/drivers/spi/spi-geni-qcom.c
index a0d8d3425c6c..11030cb9f16d 100644
--- a/drivers/spi/spi-geni-qcom.c
+++ b/drivers/spi/spi-geni-qcom.c
@@ -1258,3 +1258,4 @@ module_platform_driver(spi_geni_driver);
 
 MODULE_DESCRIPTION("SPI driver for GENI based QUP cores");
 MODULE_LICENSE("GPL v2");
+MODULE_FIRMWARE("qcom/qcm6490/qupv3fw.elf");
diff --git a/drivers/tty/serial/qcom_geni_serial.c b/drivers/tty/serial/qcom_geni_serial.c
index 8058b839b26c..ea1fa08417b6 100644
--- a/drivers/tty/serial/qcom_geni_serial.c
+++ b/drivers/tty/serial/qcom_geni_serial.c
@@ -1948,3 +1948,4 @@ module_exit(qcom_geni_serial_exit);
 
 MODULE_DESCRIPTION("Serial driver for GENI based QUP cores");
 MODULE_LICENSE("GPL v2");
+MODULE_FIRMWARE("qcom/qcm6490/qupv3fw.elf");
