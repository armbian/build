From 85666011f2e17f97dbbdd04bd8763ac61ebdbfa7 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Tue, 13 Jan 2026 06:50:23 +0000
Subject: [PATCH 118/121] arm64: dts: amlogic: radxa-zero2: lower cpu active
 thermal trip point
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Lower the CPU active thermal trip point from 70°C to 60°C.

To maintain consistency with other Radxa products.

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
index 0322bc3523b8..203224f0843e 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
@@ -322,7 +322,7 @@ &cpu103 {
 &cpu_thermal {
 	trips {
 		cpu_active: cpu-active {
-			temperature = <70000>; /* millicelsius */
+			temperature = <60000>; /* millicelsius */
 			hysteresis = <2000>; /* millicelsius */
 			type = "active";
 		};
-- 
2.39.5

