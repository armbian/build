From cccda6602c30a87950d32619717fb2fc44d11064 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Fri, 19 Dec 2025 04:00:25 +0000
Subject: [PATCH 095/121] arm64: dts: amlogic: add meson-g12b-radxa-zero-2pro

To maintain compatibility with older versions of radxa-pkg/u-boot-latest.
Use a symbolic link to meson-g12b-radxa-zero2 instead of copying for easier tracking and modification.

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 arch/arm64/boot/dts/amlogic/Makefile                       | 1 +
 arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero-2pro.dts | 1 +
 2 files changed, 2 insertions(+)
 create mode 120000 arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero-2pro.dts

diff --git a/arch/arm64/boot/dts/amlogic/Makefile b/arch/arm64/boot/dts/amlogic/Makefile
index ee95e6246412..9d332c139930 100644
--- a/arch/arm64/boot/dts/amlogic/Makefile
+++ b/arch/arm64/boot/dts/amlogic/Makefile
@@ -40,6 +40,7 @@ dtb-$(CONFIG_ARCH_MESON) += meson-g12b-odroid-n2-plus.dtb
 dtb-$(CONFIG_ARCH_MESON) += meson-g12b-odroid-n2.dtb
 dtb-$(CONFIG_ARCH_MESON) += meson-g12b-odroid-n2l.dtb
 dtb-$(CONFIG_ARCH_MESON) += meson-g12b-radxa-zero2.dtb
+dtb-$(CONFIG_ARCH_MESON) += meson-g12b-radxa-zero-2pro.dtb	# Symbolic link to meson-g12b-radxa-zero2
 dtb-$(CONFIG_ARCH_MESON) += meson-g12b-s922x-bananapi-m2s.dtb
 dtb-$(CONFIG_ARCH_MESON) += meson-g12b-s922x-khadas-vim3.dtb
 dtb-$(CONFIG_ARCH_MESON) += meson-g12b-ugoos-am6.dtb
diff --git a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero-2pro.dts b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero-2pro.dts
new file mode 120000
index 000000000000..cd5e35bf0116
--- /dev/null
+++ b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero-2pro.dts
@@ -0,0 +1 @@
+meson-g12b-radxa-zero2.dts
\ No newline at end of file
