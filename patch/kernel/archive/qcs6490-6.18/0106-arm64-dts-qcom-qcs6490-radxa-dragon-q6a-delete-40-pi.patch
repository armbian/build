From e40fc18916b256e713f72fd26c02268ed9e9a82d Mon Sep 17 00:00:00 2001
From: Nascs Fang <nascs@radxa.com>
Date: Wed, 31 Dec 2025 10:34:57 +0000
Subject: [PATCH 106/121] arm64: dts: qcom: qcs6490-radxa-dragon-q6a: delete
 40-pin gpio pinctrl

Disable I2C and SPI to free some pins on the 40-pin header.
Make these pins function as gpio by default.

Signed-off-by: Nascs Fang <nascs@radxa.com>
---
 .../dts/qcom/qcs6490-radxa-dragon-q6a.dts     | 36 -------------------
 1 file changed, 36 deletions(-)

diff --git a/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts b/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts
index 3ce0111db204..518db4129c98 100644
--- a/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts
+++ b/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts
@@ -526,24 +526,6 @@ &gpu_zap_shader {
 	firmware-name = "qcom/qcs6490/a660_zap.mbn";
 };
 
-/* Pin 13, 15 in GPIO header */
-&i2c0 {
-	qcom,enable-gsi-dma;
-	status = "okay";
-};
-
-/* Pin 27, 28 in GPIO header */
-&i2c2 {
-	qcom,enable-gsi-dma;
-	status = "okay";
-};
-
-/* Pin 3, 5 in GPIO header */
-&i2c6 {
-	qcom,enable-gsi-dma;
-	status = "okay";
-};
-
 &i2c10 {
 	qcom,enable-gsi-dma;
 	status = "okay";
@@ -856,24 +838,6 @@ platform {
 	};
 };
 
-/* Pin 11, 29, 31, 32 in GPIO header */
-&spi7 {
-	qcom,enable-gsi-dma;
-	status = "okay";
-};
-
-/* Pin 19, 21, 23, 24, 26 in GPIO header */
-&spi12 {
-	qcom,enable-gsi-dma;
-	status = "okay";
-};
-
-/* Pin 22, 33, 36, 37 in GPIO header */
-&spi14 {
-	qcom,enable-gsi-dma;
-	status = "okay";
-};
-
 &swr0 {
 	status = "okay";
 
-- 
