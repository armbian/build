From 0953eb69bc0cb9a29a20c5ea86f299aa1e3610fb Mon Sep 17 00:00:00 2001
From: Xilin Wu <sophon@radxa.com>
Date: Fri, 10 Oct 2025 00:22:18 +0800
Subject: [PATCH 048/121] arm64: dts: qcom: qcs6490-radxa-dragon-q6a: Change
 user led function to heartbeat

For RadxaOS usecase.

Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts | 6 ++----
 1 file changed, 2 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts b/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts
index 2fcef3fac9b4..2f45d5d5c17f 100644
--- a/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts
+++ b/arch/arm64/boot/dts/qcom/qcs6490-radxa-dragon-q6a.dts
@@ -184,11 +184,9 @@ leds {
 
 		user-led {
 			color = <LED_COLOR_ID_BLUE>;
-			function = LED_FUNCTION_INDICATOR;
+			function = LED_FUNCTION_STATUS;
 			gpios = <&tlmm 42 GPIO_ACTIVE_HIGH>;
-			linux,default-trigger = "none";
-			default-state = "off";
-			panic-indicator;
+			linux,default-trigger = "heartbeat";
 		};
 	};
 
-- 
2.39.5

