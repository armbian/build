From 27cc28afe90ffdd51e04c7577be4893fe27136ef Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Wed, 10 Dec 2025 08:19:41 +0000
Subject: [PATCH 097/121] arm64: dts: meson: radxa-zero2: add fcs,fusb302 and
 gpio-sbu-mux

To support Type-C automatic flipping

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 .../dts/amlogic/meson-g12b-radxa-zero2.dts    | 136 ++++++++++++++++++
 1 file changed, 136 insertions(+)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
index 1e5c6f984945..292ff105ffce 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
@@ -14,6 +14,7 @@
 #include <dt-bindings/leds/common.h>
 #include <dt-bindings/gpio/meson-g12a-gpio.h>
 #include <dt-bindings/sound/meson-g12a-tohdmitx.h>
+#include <dt-bindings/usb/pd.h>
 
 / {
 	compatible = "radxa,zero2", "amlogic,a311d", "amlogic,g12b";
@@ -167,6 +168,19 @@ vddcpu_b: regulator-vddcpu-b {
 		regulator-always-on;
 	};
 
+	typec_vbus: regulator-typec-vbus {
+		compatible = "regulator-fixed";
+		regulator-name = "TYPEC_VBUS";
+		regulator-min-microvolt = <5000000>;
+		regulator-max-microvolt = <5000000>;
+		pinctrl-0 = <&typec_vbus_en>;
+		pinctrl-names = "default";
+		vin-supply = <&ao_5v>;
+
+		gpio = <&gpio GPIOH_8 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
+		enable-active-high;
+	};
+
 	sound {
 		compatible = "amlogic,axg-sound-card";
 		model = "RADXA-ZERO2";
@@ -225,6 +239,20 @@ codec {
 		};
 	};
 
+	usb-sbu-mux {
+		compatible = "gpio-sbu-mux";
+		select-gpios = <&gpio GPIOC_7 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
+		pinctrl-0 = <&usb_sbu_default>;
+		pinctrl-names = "default";
+		orientation-switch;
+
+		port {
+			usb0_sbu_mux: endpoint {
+				remote-endpoint = <&ucsi0_sbu>;
+			};
+		};
+	};
+
 	wifi32k: clock-0 {
 		compatible = "pwm-clock";
 		#clock-cells = <0>;
@@ -364,6 +392,83 @@ hdmi_tx_tmds_out: endpoint {
 	};
 };
 
+&dwc2 {
+	port {
+		usb_dwc2_out: endpoint {
+			remote-endpoint = <&ucsi0_hs_in>;
+		};
+	};
+};
+
+&dwc3 {
+	port {
+		usb_dwc3_out: endpoint {
+			remote-endpoint = <&ucsi0_ss_in>;
+		};
+	};
+};
+
+&i2c3 {
+	#address-cells = <1>;
+	#size-cells = <0>;
+	pinctrl-0 = <&i2c3_sda_a_pins>, <&i2c3_sck_a_pins>;
+	pinctrl-names = "default";
+	status = "okay";
+
+	fusb302@22 {
+		compatible = "fcs,fusb302";
+		reg = <0x22>;
+
+		pinctrl-0 = <&fusb302_irq_pins>;
+		pinctrl-names = "default";
+		interrupt-parent = <&gpio_intc>;
+		interrupts = <IRQID_GPIOA_13 IRQ_TYPE_LEVEL_LOW>;
+
+		vbus-supply = <&typec_vbus>;
+
+		status = "okay";
+
+		usb_con: connector {
+			compatible = "usb-c-connector";
+			label = "USB-C";
+			data-role = "host";
+			/* fusb302 supports PD Rev 2.0 Ver 1.2 */
+			pd-revision = /bits/ 8 <0x2 0x0 0x1 0x2>;
+			power-role = "source";
+			source-pdos = <PDO_FIXED(5000, 1500, PDO_FIXED_USB_COMM)>;
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				port@0 {
+					reg = <0>;
+
+					ucsi0_hs_in: endpoint {
+						remote-endpoint = <&usb_dwc2_out>;
+					};
+				};
+
+				port@1 {
+					reg = <1>;
+
+					ucsi0_ss_in: endpoint {
+						remote-endpoint = <&usb_dwc3_out>;
+					};
+				};
+
+				port@2 {
+					reg = <2>;
+
+					ucsi0_sbu: endpoint {
+						remote-endpoint = <&usb0_sbu_mux>;
+					};
+				};
+			};
+		};
+	};
+};
+
 &ir {
 	status = "disabled";
 	pinctrl-0 = <&remote_input_ao_pins>;
@@ -501,3 +606,34 @@ &uart_AO {
 &usb {
 	status = "okay";
 };
+
+&periphs_pinctrl {
+	/*
+	 * Make sure the irq pin of the TYPE C controller is not driven
+	 * by the SoC.
+	 */
+	fusb302_irq_pins: fusb302_irq {
+		mux {
+			groups = "GPIOA_13";
+			function = "gpio_periphs";
+			bias-pull-up;
+			output-disable;
+		};
+	};
+
+	usb_sbu_default: usb0-sbu-state {
+		mux {
+			groups = "GPIOC_7";
+			function = "gpio_periphs";
+			bias-disable;
+		};
+	};
+
+	typec_vbus_en: typec-vbus-en {
+		mux {
+			groups = "GPIOH_8";
+			function = "gpio_periphs";
+			bias-disable;
+		};
+	};
+};
-- 
2.39.5

