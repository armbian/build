From d5fd9f69bd3f4a4691d2d8b622b8b9774e93d1f0 Mon Sep 17 00:00:00 2001
From: Jiali Chen <chenjiali@radxa.com>
Date: Tue, 13 Jan 2026 07:01:17 +0000
Subject: [PATCH 120/121] arm64: dts: amlogic: meson-g12b-radxa-zero2: fix
 gpio-line-names

Update the GPIO line names to correctly match the physical pin header
layout of the Radxa Zero 2 Pro board.

This change:
- Adds missing labels for PIN_16 (GPIOZ_8) and PIN_22 (GPIOZ_9).
- Corrects the mapping for PIN_36 (moved from GPIOC_7 to GPIOA_3).
- Corrects the mapping for PIN_31 (moved from GPIOA_13 to GPIOA_4).

Signed-off-by: Jiali Chen <chenjiali@radxa.com>
---
 arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
index 203224f0843e..c479a8c2ebd9 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12b-radxa-zero2.dts
@@ -352,7 +352,7 @@ &gpio {
 	gpio-line-names =
 		/* GPIOZ */
 		"PIN_27", "PIN_28", "PIN_7", "PIN_11", "PIN_13", "PIN_15", "PIN_18", "PIN_40",
-		"", "", "", "", "", "", "", "",
+		"PIN_16", "PIN_22", "", "", "", "", "", "",
 		/* GPIOH */
 		"", "", "", "", "PIN_19", "PIN_21", "PIN_24", "PIN_23",
 		"",
@@ -360,10 +360,10 @@ &gpio {
 		"", "", "", "", "", "", "", "",
 		"", "", "", "", "EMMC_PWRSEQ", "", "", "",
 		/* GPIOC */
-		"", "", "", "", "", "", "SD_CD", "PIN_36",
+		"", "", "", "", "", "", "SD_CD", "",
 		/* GPIOA */
-		"PIN_32", "PIN_12", "PIN_35", "", "", "PIN_38", "", "",
-		"", "", "", "", "LED_GREEN", "PIN_31", "PIN_3", "PIN_5",
+		"PIN_32", "PIN_12", "PIN_35", "PIN_36", "PIN_31", "PIN_38", "", "",
+		"", "", "", "", "LED_GREEN", "", "PIN_3", "PIN_5",
 		/* GPIOX */
 		"", "", "", "", "", "", "SDIO_PWRSEQ", "",
 		"", "", "", "", "", "", "", "",
