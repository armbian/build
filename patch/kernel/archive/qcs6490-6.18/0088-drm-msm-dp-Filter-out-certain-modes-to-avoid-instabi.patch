From b8149f82a5c20638b521ffe5fb5dded61f449154 Mon Sep 17 00:00:00 2001
From: Xilin Wu <sophon@radxa.com>
Date: Mon, 4 Aug 2025 10:35:01 +0800
Subject: [PATCH 088/121] drm/msm/dp: Filter out certain modes to avoid
 instability

Filter out modes with resolution higher than 3440 * 1440 and refresh rate
higher than 30Hz.

Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 drivers/gpu/drm/msm/dp/dp_display.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/drivers/gpu/drm/msm/dp/dp_display.c b/drivers/gpu/drm/msm/dp/dp_display.c
index b8a0e61b806e..a5fcb4ba527a 100644
--- a/drivers/gpu/drm/msm/dp/dp_display.c
+++ b/drivers/gpu/drm/msm/dp/dp_display.c
@@ -929,6 +929,7 @@ enum drm_mode_status msm_dp_bridge_mode_valid(struct drm_bridge *bridge,
 	u32 mode_rate_khz = 0, supported_rate_khz = 0, mode_bpp = 0;
 	struct msm_dp *dp;
 	int mode_pclk_khz = mode->clock;
+	int vrefresh = drm_mode_vrefresh(mode);
 
 	dp = to_dp_bridge(bridge)->msm_dp_display;
 
@@ -961,6 +962,9 @@ enum drm_mode_status msm_dp_bridge_mode_valid(struct drm_bridge *bridge,
 	if (mode_rate_khz > supported_rate_khz)
 		return MODE_BAD;
 
+	if ((mode->hdisplay * mode->vdisplay > 3440 * 1440) && vrefresh > 30)
+		return MODE_BAD;
+
 	return MODE_OK;
 }
 
