From 39e29a8e3eb04526091050f758a17a2a2628b21b Mon Sep 17 00:00:00 2001
From: Xilin Wu <sophon@radxa.com>
Date: Sun, 21 Dec 2025 23:13:18 +0800
Subject: [PATCH 067/121] spi: geni-qcom: Implement max_transfer_size for GPI
 DMA

When using the GENI SPI driver in GPI DMA mode (enabled via
"qcom,enable-gsi-dma"), large transfers fail with the following error:

  gpi a00000.dma-controller: Multi sg sent, we support only one atm: 3
  geni_spi a90000.spi: Err setting up tx desc

This occurs because the QCOM GPI DMA driver currently supports only a
single scatter-gather entry per transfer. However, the SPI core splits
buffers larger than the DMA max segment size (typically 64KB) into
multiple SG entries. For example, a ~134KB frame update from a MIPI DBI
panel driver results in 3 SG entries, which the GPI driver rejects.

To fix this, implement the max_transfer_size callback in the SPI
controller. This function reports the maximum segment size supported by
the DMA device (defaulting to 64KB if not set). This signals upper
layers (such as mipi_dbi_spi_transfer) to split the data into smaller
chunks before creating the scatterlist, ensuring each transfer maps to
exactly one SG entry.

This restriction is applied only when the controller is operating in
GENI_GPI_DMA mode.

Signed-off-by: Xilin Wu <sophon@radxa.com>
---
 drivers/spi/spi-geni-qcom.c | 28 ++++++++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/drivers/spi/spi-geni-qcom.c b/drivers/spi/spi-geni-qcom.c
index 36c0e8f9491f..d2f43bf3ef9e 100644
--- a/drivers/spi/spi-geni-qcom.c
+++ b/drivers/spi/spi-geni-qcom.c
@@ -13,6 +13,7 @@
 #include <linux/pm_opp.h>
 #include <linux/pm_runtime.h>
 #include <linux/property.h>
+#include <linux/sizes.h>
 #include <linux/soc/qcom/geni-se.h>
 #include <linux/spi/spi.h>
 #include <linux/spinlock.h>
@@ -547,6 +548,32 @@ static int spi_geni_prepare_message(struct spi_controller *spi,
 	return -EINVAL;
 }
 
+static size_t spi_geni_max_transfer_size(struct spi_device *slv)
+{
+	struct spi_controller *ctlr = slv->controller;
+	struct spi_geni_master *mas = spi_controller_get_devdata(ctlr);
+	struct device *dma_dev = NULL;
+	size_t max_seg = 0;
+
+	if (mas->cur_xfer_mode != GENI_GPI_DMA)
+		return SIZE_MAX;
+
+	if (mas->tx && mas->tx->device)
+		dma_dev = mas->tx->device->dev;
+	else if (ctlr->dma_map_dev)
+		dma_dev = ctlr->dma_map_dev;
+	else
+		dma_dev = ctlr->dev.parent;
+
+	if (dma_dev)
+		max_seg = dma_get_max_seg_size(dma_dev);
+
+	if (!max_seg)
+		max_seg = SZ_64K;
+
+	return max_seg;
+}
+
 static void spi_geni_release_dma_chan(void *data)
 {
 	struct spi_geni_master *mas = data;
@@ -1065,6 +1092,7 @@ static int spi_geni_probe(struct platform_device *pdev)
 	spi->max_dma_len = 0xffff0; /* 24 bits for tx/rx dma length */
 	spi->prepare_message = spi_geni_prepare_message;
 	spi->transfer_one = spi_geni_transfer_one;
+	spi->max_transfer_size = spi_geni_max_transfer_size;
 	spi->can_dma = geni_can_dma;
 	spi->dma_map_dev = dev->parent;
 	spi->auto_runtime_pm = true;
-- 
