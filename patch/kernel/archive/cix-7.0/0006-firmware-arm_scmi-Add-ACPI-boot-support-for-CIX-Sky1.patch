 drivers/firmware/arm_scmi/driver.c            | 52 +++++++++-
 drivers/firmware/arm_scmi/shmem.c             | 98 ++++++++++++++++++-
 .../firmware/arm_scmi/transports/mailbox.c    | 58 +++++++++--
 drivers/firmware/arm_scmi/transports/optee.c  |  2 +-
 drivers/firmware/arm_scmi/transports/smc.c    | 16 ++-
 drivers/firmware/arm_scmi/transports/virtio.c |  2 +-
 10 files changed, 227 insertions(+), 16 deletions(-)

