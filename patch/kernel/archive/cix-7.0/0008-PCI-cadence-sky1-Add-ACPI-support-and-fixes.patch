+static void sky1_pcie_enable_irq(struct sky1_pcie *pcie, bool en)
+{
+	/* local (some error status) */
+	sky1_pcie_enable_local_irq(pcie, en);
+	sky1_pcie_enable_indicatbit_int(pcie, en);
+}
