+		break;
+	case 4:
+		ret = 2;
+		break;
+	case 2:
+		ret = 1;
+		break;
+	case 1:
+		ret = 0;
+		break;
+	default:
+		ret = -EINVAL;
+		break;
+	}
+
+	return ret;
+}
