+static void sky1_pcie_set_bits32(void __iomem *addr, u32 bits_msk)
+{
+	u32 value;
+
+	value = readl(addr);
+	value |= bits_msk;
+	writel(value, addr);
+}
+
+static void sky1_pcie_clear_bits32(void __iomem *addr, u32 bits_msk)
+{
