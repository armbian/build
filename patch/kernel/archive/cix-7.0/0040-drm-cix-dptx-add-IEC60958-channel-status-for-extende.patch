From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 28 Feb 2026 14:29:57 +1100
Subject: [PATCH] drm/cix/dptx: add IEC60958 channel status for extended sample
 rates

Add support for 88.2, 96, 176.4, and 192kHz sample rates in the DPTX
audio channel status registers. Previously only 32, 44.1, and 48kHz
were handled; any other rate silently fell through to the 48kHz default.
---
 drivers/gpu/drm/cix/dptx/trilin_dptx_audio.c | 16 ++++++++++++++++
 drivers/gpu/drm/cix/dptx/trilin_dptx_audio.h |  8 ++++++++
 2 files changed, 24 insertions(+)

diff --git a/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.c b/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.c
index 740ddaea47a64..0addb5f13205d 100644
--- a/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.c
+++ b/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.c
@@ -58,6 +58,22 @@ static void dptx_audio_setup(struct trilin_dp *dp, int source, int freq,
 		cs_length_orig_freq |= DPTX_CS_SAMPLING_ORIG_FREQ_44100HZ;
 		cs_freq_clock_accuracy = DPTX_CS_SAMPLING_FREQ_44100Hz;
 		break;
+	case 88200:
+		cs_length_orig_freq |= DPTX_CS_SAMPLING_ORIG_FREQ_88200HZ;
+		cs_freq_clock_accuracy = DPTX_CS_SAMPLING_FREQ_88200Hz;
+		break;
+	case 96000:
+		cs_length_orig_freq |= DPTX_CS_SAMPLING_ORIG_FREQ_96000HZ;
+		cs_freq_clock_accuracy = DPTX_CS_SAMPLING_FREQ_96000Hz;
+		break;
+	case 176400:
+		cs_length_orig_freq |= DPTX_CS_SAMPLING_ORIG_FREQ_176400HZ;
+		cs_freq_clock_accuracy = DPTX_CS_SAMPLING_FREQ_176400Hz;
+		break;
+	case 192000:
+		cs_length_orig_freq |= DPTX_CS_SAMPLING_ORIG_FREQ_192000HZ;
+		cs_freq_clock_accuracy = DPTX_CS_SAMPLING_FREQ_192000Hz;
+		break;
 	case 48000:
 	default:
 		cs_length_orig_freq |= DPTX_CS_SAMPLING_ORIG_FREQ_48000HZ;
diff --git a/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.h b/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.h
index 8df1f961f97fb..80e7410b9986d 100644
--- a/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.h
+++ b/drivers/gpu/drm/cix/dptx/trilin_dptx_audio.h
@@ -18,6 +18,10 @@
 #define DPTX_CS_SAMPLING_FREQ_32000Hz (0b1100 << 4)
 #define DPTX_CS_SAMPLING_FREQ_44100Hz (0b0000 << 4)
 #define DPTX_CS_SAMPLING_FREQ_48000Hz (0b0100 << 4)
+#define DPTX_CS_SAMPLING_FREQ_88200Hz (0b0001 << 4)
+#define DPTX_CS_SAMPLING_FREQ_96000Hz (0b0101 << 4)
+#define DPTX_CS_SAMPLING_FREQ_176400Hz (0b0011 << 4)
+#define DPTX_CS_SAMPLING_FREQ_192000Hz (0b0111 << 4)
 /* bit 32~35 Word length */
 #define DPTX_CS_SAMPLE_WORD_LENGTH_16BITS (0b0100 << 4)
 #define DPTX_CS_SAMPLE_WORD_LENGTH_18BITS (0b0010 << 4)
@@ -27,6 +31,10 @@
 #define DPTX_CS_SAMPLING_ORIG_FREQ_32000HZ (0b0011)
 #define DPTX_CS_SAMPLING_ORIG_FREQ_44100HZ (0b1111)
 #define DPTX_CS_SAMPLING_ORIG_FREQ_48000HZ (0b1011)
+#define DPTX_CS_SAMPLING_ORIG_FREQ_88200HZ (0b1110)
+#define DPTX_CS_SAMPLING_ORIG_FREQ_96000HZ (0b1010)
+#define DPTX_CS_SAMPLING_ORIG_FREQ_176400HZ (0b1100)
+#define DPTX_CS_SAMPLING_ORIG_FREQ_192000HZ (0b1000)
 #define DPTX_CS_SOURCE_NUMBER_SHIFT (4)
 #define DPTX_CS_CATEGORY_CODE (0)
 #define DPTX_CS_COPYRIGHT (0)
