+static unsigned int cix_get_perf_level_count(struct cpufreq_policy *policy)
+{
+	struct cppc_cpudata *cpu_data = policy->driver_data;
+
+	if (!cpu_data) {
+		pr_warn("No CPU data for CPU%d\n", policy->cpu);
+		return 0;
