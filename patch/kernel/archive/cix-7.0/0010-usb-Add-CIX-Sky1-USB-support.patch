diff --git a/drivers/usb/typec/rts5453.c b/drivers/usb/typec/rts5453.c
new file mode 100644
index 0000000000000..5521a00d41d40
--- /dev/null
+++ b/drivers/usb/typec/rts5453.c
@@ -0,0 +1,621 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Realtek RTS5453 USB Type-C PD Controller Driver
+ *
+ * Copyright (C) 2024 CIX Technology
+ * Author: Chao Zeng <Chao.Zeng@cixtech.com>
+ *
+ * This driver supports the Realtek RTS5453H USB Type-C Power Delivery
+ * controller, providing USB role switching and DisplayPort alternate
+ * mode support.
+ */
+
+#include <linux/acpi.h>
+#include <linux/i2c.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/regmap.h>
+#include <linux/interrupt.h>
+#include <linux/workqueue.h>
+#include <linux/usb/pd.h>
+#include <linux/usb/typec.h>
+#include <linux/usb/typec_altmode.h>
+#include <linux/usb/typec_dp.h>
+#include <linux/usb/typec_mux.h>
+#include <linux/usb/role.h>
+
+/* Register addresses */
+#define RTS5453_REG_DATA_CTRL		0x50
+#define RTS5453_REG_DATA_STATUS		0x5F
+
+/* DATA_CTRL bits */
+#define RTS5453_I2C_INT_ACK		BIT(2)
+#define RTS5453_HPD_IRQ_ACK		BIT(5)
+
+/* DATA_STATUS byte 1 bits */
+#define RTS5453_ORIENTATION		BIT(1)
+#define RTS5453_USB2_CONN		BIT(4)
+#define RTS5453_USB3_CONN		BIT(5)
+#define RTS5453_DATA_ROLE		BIT(7)
+
+/* DATA_STATUS byte 2 bits */
+#define RTS5453_DP_CONN			BIT(0)
+#define RTS5453_DP_SOURCE_SINK		BIT(1)
+#define RTS5453_DEBUG_ACCESSORY		BIT(4)
+#define RTS5453_HPD_IRQ			BIT(6)
+#define RTS5453_HPD_STATE		BIT(7)
+
+/* DATA_STATUS byte 3 bits */
+#define RTS5453_PWR_SOURCE		BIT(0)
+#define RTS5453_PWR_SINK		BIT(1)
+#define RTS5453_PWR_MASK		(RTS5453_PWR_SOURCE | RTS5453_PWR_SINK)
+
+#define RTS5453_DATA_STATUS_LEN		6
+
+struct rts5453 {
+	struct device *dev;
+	struct regmap *regmap;
+	struct mutex lock;
+	int id;
+
+	/* Type-C port */
+	struct typec_port *port;
+	struct typec_capability typec_cap;
+	struct typec_partner *partner;
+	struct typec_partner_desc partner_desc;
+
+	/* Switches and muxes */
+	struct typec_switch *sw;
+	struct typec_mux *mux;
+	struct usb_role_switch *role_sw;
+
+	/* Alt-mode */
+	struct typec_altmode *alt_dp;
+
+	/* Mux state */
+	struct typec_mux_state mux_state;
+	struct typec_displayport_data dp_data;
+
+	/* Status tracking */
+	u8 data_status[RTS5453_DATA_STATUS_LEN];
+	enum usb_role role;
+	unsigned long mode;
+	u32 hpd_status;
+};
+
+static const struct regmap_config rts5453_regmap_config = {
+	.reg_bits = 8,
+	.val_bits = 8,
+	.max_register = 0x7F,
+};
+
+static int rts5453_read_status(struct rts5453 *rts)
+{
+	int ret;
+
+	ret = regmap_bulk_read(rts->regmap, RTS5453_REG_DATA_STATUS,
+			       rts->data_status, RTS5453_DATA_STATUS_LEN);
+	if (ret) {
+		dev_err(rts->dev, "Failed to read data status: %d\n", ret);
+		return ret;
+	}
+
+	dev_dbg(rts->dev, "port %d: status=%02x %02x %02x %02x %02x %02x\n",
+		rts->id, rts->data_status[0], rts->data_status[1],
+		rts->data_status[2], rts->data_status[3],
+		rts->data_status[4], rts->data_status[5]);
+
+	return 0;
+}
+
+static int rts5453_ack_irq(struct rts5453 *rts, bool ack_hpd)
+{
+	u8 ctrl[3] = { 2, RTS5453_I2C_INT_ACK, 0 };
+
+	if (ack_hpd)
+		ctrl[2] = RTS5453_HPD_IRQ_ACK;
+
+	return regmap_bulk_write(rts->regmap, RTS5453_REG_DATA_CTRL, ctrl, 3);
+}
+
+static void rts5453_update_partner(struct rts5453 *rts)
+{
+	bool connected = rts->data_status[1] || rts->data_status[2];
+
+	if (!connected && rts->partner) {
+		dev_info(rts->dev, "port %d: unregister partner\n", rts->id);
+		typec_unregister_partner(rts->partner);
+		rts->partner = NULL;
+	} else if (connected && !rts->partner) {
+		dev_info(rts->dev, "port %d: register partner\n", rts->id);
+		rts->partner_desc.accessory = TYPEC_ACCESSORY_NONE;
+		rts->partner_desc.usb_pd = false;
+		rts->partner = typec_register_partner(rts->port,
+						      &rts->partner_desc);
+		if (IS_ERR(rts->partner)) {
+			dev_err(rts->dev, "Failed to register partner\n");
+			rts->partner = NULL;
+		}
+	}
+}
+
+static void rts5453_update_port(struct rts5453 *rts)
+{
+	enum typec_orientation orientation;
+	enum usb_role role;
+	u32 dp_status = 0;
+	unsigned long mode;
+
+	/* Determine orientation */
+	if (!(rts->data_status[1] & RTS5453_USB3_CONN) &&
+	    !(rts->data_status[2] & RTS5453_DP_CONN))
+		orientation = TYPEC_ORIENTATION_NONE;
+	else if (rts->data_status[1] & RTS5453_ORIENTATION)
+		orientation = TYPEC_ORIENTATION_REVERSE;
+	else
+		orientation = TYPEC_ORIENTATION_NORMAL;
+
+	typec_switch_set(rts->sw, orientation);
+
+	/* Determine USB role */
+	if (!(rts->data_status[1] & (RTS5453_USB3_CONN | RTS5453_USB2_CONN))) {
+		role = USB_ROLE_NONE;
+	} else if (rts->data_status[1] & RTS5453_DATA_ROLE) {
+		role = USB_ROLE_DEVICE;
+	} else {
+		/* Host mode - check if USB3 or USB2 only */
+		if (!(rts->data_status[1] & RTS5453_USB3_CONN) &&
+		    (rts->data_status[2] & RTS5453_DP_CONN))
+			role = USB_ROLE_HOST;
+		else
+			role = USB_ROLE_HOST;
+	}
+
+	/* Handle debug accessory mode */
+	if (rts->data_status[2] & RTS5453_DEBUG_ACCESSORY) {
+		dev_warn(rts->dev, "Debug accessory mode not supported\n");
+		return;
+	}
+
+	/* Determine mux state and DP status */
+	if ((rts->data_status[1] & RTS5453_USB3_CONN) &&
+	    (rts->data_status[2] & RTS5453_DP_CONN)) {
+		/* USB + DP mode */
+		mode = TYPEC_DP_STATE_D;
+		dp_status = DP_STATUS_ENABLED;
+		if (rts->data_status[2] & RTS5453_HPD_STATE)
+			dp_status |= DP_STATUS_HPD_STATE;
+		if (rts->data_status[2] & RTS5453_HPD_IRQ)
+			dp_status |= DP_STATUS_IRQ_HPD;
+
+		rts->dp_data.status = dp_status;
+		rts->dp_data.conf = 0;
+		rts->mux_state.alt = rts->alt_dp;
+		rts->mux_state.mode = mode;
+		rts->mux_state.data = &rts->dp_data;
+	} else if (rts->data_status[2] & RTS5453_DP_CONN) {
+		/* DP only mode */
+		mode = TYPEC_DP_STATE_E;
+		dp_status = DP_STATUS_ENABLED;
+		if (rts->data_status[2] & RTS5453_HPD_STATE)
+			dp_status |= DP_STATUS_HPD_STATE;
+		if (rts->data_status[2] & RTS5453_HPD_IRQ)
+			dp_status |= DP_STATUS_IRQ_HPD;
+
+		rts->dp_data.status = dp_status;
+		rts->dp_data.conf = 0;
+		rts->mux_state.alt = rts->alt_dp;
+		rts->mux_state.mode = mode;
+		rts->mux_state.data = &rts->dp_data;
+	} else if (rts->data_status[1] & RTS5453_USB3_CONN) {
+		/* USB only mode */
+		mode = TYPEC_STATE_USB;
+		rts->mux_state.alt = NULL;
+		rts->mux_state.mode = mode;
+		rts->mux_state.data = NULL;
+	} else {
+		/* Disconnected */
+		mode = TYPEC_STATE_SAFE;
+		rts->mux_state.alt = NULL;
+		rts->mux_state.mode = mode;
+		rts->mux_state.data = NULL;
+	}
+
+	typec_mux_set(rts->mux, &rts->mux_state);
+
+	/* Update power role */
+	if ((rts->data_status[3] & RTS5453_PWR_MASK) == RTS5453_PWR_SOURCE)
+		typec_set_pwr_role(rts->port, TYPEC_SOURCE);
+	else if ((rts->data_status[3] & RTS5453_PWR_MASK) == RTS5453_PWR_SINK)
+		typec_set_pwr_role(rts->port, TYPEC_SINK);
+
+	/* Update USB role if changed */
+	if (rts->role != role) {
+		rts->role = role;
+		usb_role_switch_set_role(rts->role_sw, role);
+		typec_set_data_role(rts->port,
+				    role == USB_ROLE_DEVICE ? TYPEC_DEVICE : TYPEC_HOST);
+	}
+
+	/* Log mode changes */
+	if (rts->mode != mode || rts->hpd_status != dp_status) {
+		const char *mode_str;
+
+		switch (mode) {
+		case TYPEC_DP_STATE_D:
+			mode_str = "USB+DP";
+			break;
+		case TYPEC_DP_STATE_E:
+			mode_str = "DP";
+			break;
+		case TYPEC_STATE_USB:
+			mode_str = "USB";
+			break;
+		default:
+			mode_str = "disconnected";
+			break;
+		}
+
+		dev_info(rts->dev,
+			 "port %d: mode=%s orient=%s role=%s pwr=%s hpd=%d\n",
+			 rts->id, mode_str,
+			 orientation == TYPEC_ORIENTATION_REVERSE ? "reverse" : "normal",
+			 role == USB_ROLE_DEVICE ? "device" : "host",
+			 (rts->data_status[3] & RTS5453_PWR_MASK) == RTS5453_PWR_SOURCE ?
+				"source" : "sink",
+			 !!(dp_status & DP_STATUS_HPD_STATE));
+
+		rts->mode = mode;
+		rts->hpd_status = dp_status;
+	}
+
+	/* Update partner registration */
+	rts5453_update_partner(rts);
+}
+
+static int rts5453_event_handler(struct rts5453 *rts, bool clear_irq)
+{
+	int ret;
+
+	mutex_lock(&rts->lock);
+
+	if (clear_irq) {
+		ret = rts5453_ack_irq(rts, false);
+		if (ret) {
+			dev_err(rts->dev, "Failed to ack IRQ: %d\n", ret);
+			goto unlock;
+		}
+	}
+
+	ret = rts5453_read_status(rts);
+	if (ret)
+		goto unlock;
+
+	rts5453_update_port(rts);
+
+	/* Ack HPD IRQ if set */
+	if (rts->data_status[2] & RTS5453_HPD_IRQ) {
+		ret = rts5453_ack_irq(rts, true);
+		if (ret)
+			dev_err(rts->dev, "Failed to ack HPD IRQ: %d\n", ret);
+	}
+
+unlock:
+	mutex_unlock(&rts->lock);
+	return ret;
+}
+
+static irqreturn_t rts5453_irq_handler(int irq, void *data)
+{
+	struct rts5453 *rts = data;
+	int ret;
+
+	ret = rts5453_event_handler(rts, true);
+	if (ret == -ESHUTDOWN) {
+		disable_irq_nosync(irq);
+		return IRQ_HANDLED;
+	}
+
+	return IRQ_HANDLED;
+}
+
+static int rts5453_dr_set(struct typec_port *port, enum typec_data_role role)
+{
+	/* RTS5453 doesn't support software-initiated data role swap */
+	return -EOPNOTSUPP;
+}
+
+static int rts5453_pr_set(struct typec_port *port, enum typec_role role)
+{
+	/* RTS5453 doesn't support software-initiated power role swap */
+	return -EOPNOTSUPP;
+}
+
+static const struct typec_operations rts5453_ops = {
+	.dr_set = rts5453_dr_set,
+	.pr_set = rts5453_pr_set,
+};
+
+static int rts5453_register_altmode(struct rts5453 *rts)
+{
+	struct typec_altmode_desc desc = { };
+
+	desc.svid = USB_TYPEC_DP_SID;
+	desc.mode = USB_TYPEC_DP_MODE;
+	desc.vdo = DP_CAP_DFP_D | DP_CAP_UFP_D |
+		   DP_CONF_SET_PIN_ASSIGN(BIT(DP_PIN_ASSIGN_C) |
+					  BIT(DP_PIN_ASSIGN_D) |
+					  BIT(DP_PIN_ASSIGN_E));
+
+	rts->alt_dp = typec_port_register_altmode(rts->port, &desc);
+	if (IS_ERR(rts->alt_dp)) {
+		dev_err(rts->dev, "Failed to register DP altmode: %ld\n",
+			PTR_ERR(rts->alt_dp));
+		return PTR_ERR(rts->alt_dp);
+	}
+
+	return 0;
+}
+
+static int rts5453_parse_port_caps(struct rts5453 *rts,
+				   struct fwnode_handle *fwnode)
+{
+	const char *buf;
+	int ret;
+
+	ret = fwnode_property_read_string(fwnode, "power-role", &buf);
+	if (ret) {
+		dev_err(rts->dev, "power-role not found: %d\n", ret);
+		return ret;
+	}
+	ret = typec_find_port_power_role(buf);
+	if (ret < 0)
+		return ret;
+	rts->typec_cap.type = ret;
+
+	ret = fwnode_property_read_string(fwnode, "data-role", &buf);
+	if (ret) {
+		dev_err(rts->dev, "data-role not found: %d\n", ret);
+		return ret;
+	}
+	ret = typec_find_port_data_role(buf);
+	if (ret < 0)
+		return ret;
+	rts->typec_cap.data = ret;
+
+	ret = fwnode_property_read_string(fwnode, "try-power-role", &buf);
+	if (ret) {
+		dev_err(rts->dev, "try-power-role not found: %d\n", ret);
+		return ret;
+	}
+	ret = typec_find_power_role(buf);
+	if (ret < 0)
+		return ret;
+	rts->typec_cap.prefer_role = ret;
+
+	return 0;
+}
+
+static int rts5453_probe(struct i2c_client *client)
+{
+	struct fwnode_handle *fwnode;
+	struct rts5453 *rts;
+	int ret;
+
+	rts = devm_kzalloc(&client->dev, sizeof(*rts), GFP_KERNEL);
+	if (!rts)
+		return -ENOMEM;
+
+	rts->dev = &client->dev;
+	mutex_init(&rts->lock);
+
+	rts->regmap = devm_regmap_init_i2c(client, &rts5453_regmap_config);
+	if (IS_ERR(rts->regmap))
+		return PTR_ERR(rts->regmap);
+
+	if (!i2c_check_functionality(client->adapter, I2C_FUNC_I2C)) {
+		dev_err(&client->dev, "I2C functionality not supported\n");
+		return -ENODEV;
+	}
+
+	ret = device_property_read_u32(&client->dev, "id", &rts->id);
+	if (ret < 0) {
+		dev_err(&client->dev, "Failed to read id property: %d\n", ret);
+		return ret;
+	}
+
+	i2c_set_clientdata(client, rts);
+
+	/* Get connector fwnode (child node) */
+	fwnode = device_get_next_child_node(&client->dev, NULL);
+	if (!fwnode) {
+		dev_err(&client->dev, "No connector child node found\n");
+		return -ENODEV;
+	}
+
+	/* Get switches and muxes via fwnode */
+	rts->sw = fwnode_typec_switch_get(fwnode);
+	if (IS_ERR(rts->sw)) {
+		ret = PTR_ERR(rts->sw);
+		if (ret == -EPROBE_DEFER)
+			goto err_put_fwnode;
+		dev_warn(&client->dev, "No orientation switch: %d\n", ret);
+		rts->sw = NULL;
+	}
+
+	rts->mux = fwnode_typec_mux_get(fwnode);
+	if (IS_ERR(rts->mux)) {
+		ret = PTR_ERR(rts->mux);
+		if (ret == -EPROBE_DEFER)
+			goto err_put_sw;
+		dev_warn(&client->dev, "No mode mux: %d\n", ret);
+		rts->mux = NULL;
+	}
+
+	rts->role_sw = fwnode_usb_role_switch_get(fwnode);
+	if (IS_ERR(rts->role_sw)) {
+		ret = PTR_ERR(rts->role_sw);
+		if (ret == -EPROBE_DEFER)
+			goto err_put_mux;
+		dev_warn(&client->dev, "No USB role switch: %d\n", ret);
+		rts->role_sw = NULL;
+	}
+
+	/* Parse port capabilities from DT */
+	ret = rts5453_parse_port_caps(rts, fwnode);
+	if (ret)
+		goto err_put_role_sw;
+
+	/* Setup typec_capability */
+	rts->typec_cap.revision = USB_TYPEC_REV_1_2;
+	rts->typec_cap.pd_revision = 0x0300;
+	rts->typec_cap.driver_data = rts;
+	rts->typec_cap.ops = &rts5453_ops;
+	rts->typec_cap.fwnode = fwnode;
+
+	/* Register Type-C port */
+	rts->port = typec_register_port(&client->dev, &rts->typec_cap);
+	if (IS_ERR(rts->port)) {
+		ret = PTR_ERR(rts->port);
+		dev_err(&client->dev, "Failed to register port: %d\n", ret);
+		goto err_put_role_sw;
+	}
+
+	/* Register DP alt-mode */
+	ret = rts5453_register_altmode(rts);
+	if (ret)
+		goto err_unreg_port;
+
+	/* Initialize mux state */
+	rts->mux_state.alt = NULL;
+	rts->mux_state.mode = TYPEC_STATE_SAFE;
+	rts->mux_state.data = NULL;
+
+	/* Read initial status */
+	ret = rts5453_event_handler(rts, false);
+	if (ret) {
+		dev_err(&client->dev, "Failed to read initial status: %d\n", ret);
+		goto err_unreg_altmode;
+	}
+
+	/* Setup IRQ */
+	if (client->irq) {
+		irq_set_status_flags(client->irq, IRQ_DISABLE_UNLAZY);
+		ret = devm_request_threaded_irq(&client->dev, client->irq,
+						NULL, rts5453_irq_handler,
+						IRQF_TRIGGER_LOW | IRQF_SHARED |
+						IRQF_ONESHOT,
+						dev_name(&client->dev), rts);
+		if (ret) {
+			dev_err(&client->dev, "Failed to request IRQ: %d\n", ret);
+			goto err_unreg_altmode;
+		}
+	}
+
+	device_set_wakeup_capable(&client->dev, true);
+
+	dev_info(&client->dev, "RTS5453 port %d initialized\n", rts->id);
+
+	fwnode_handle_put(fwnode);
+	return 0;
+
+err_unreg_altmode:
+	typec_unregister_altmode(rts->alt_dp);
+err_unreg_port:
+	typec_unregister_port(rts->port);
+err_put_role_sw:
+	usb_role_switch_put(rts->role_sw);
+err_put_mux:
+	typec_mux_put(rts->mux);
+err_put_sw:
+	typec_switch_put(rts->sw);
+err_put_fwnode:
+	fwnode_handle_put(fwnode);
+	return ret;
+}
+
+static void rts5453_remove(struct i2c_client *client)
+{
+	struct rts5453 *rts = i2c_get_clientdata(client);
+
+	if (rts->partner) {
+		typec_unregister_partner(rts->partner);
+		rts->partner = NULL;
+	}
+
+	typec_unregister_altmode(rts->alt_dp);
+	typec_unregister_port(rts->port);
+	usb_role_switch_put(rts->role_sw);
+	typec_mux_put(rts->mux);
+	typec_switch_put(rts->sw);
+}
+
+static int rts5453_suspend(struct device *dev)
+{
+	struct i2c_client *client = to_i2c_client(dev);
+
+	if (client->irq) {
+		disable_irq(client->irq);
+		if (device_may_wakeup(dev))
+			enable_irq_wake(client->irq);
+	}
+
+	return 0;
+}
+
+static int rts5453_resume(struct device *dev)
+{
+	struct i2c_client *client = to_i2c_client(dev);
+	struct rts5453 *rts = i2c_get_clientdata(client);
+
+	if (client->irq) {
+		if (device_may_wakeup(dev))
+			disable_irq_wake(client->irq);
+		enable_irq(client->irq);
+	}
+
+	/* Re-read status after resume */
+	rts5453_event_handler(rts, false);
+
+	return 0;
+}
+
+static DEFINE_SIMPLE_DEV_PM_OPS(rts5453_pm_ops, rts5453_suspend, rts5453_resume);
+
+static const struct of_device_id rts5453_of_match[] = {
+	{ .compatible = "realtek,rts5453h" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, rts5453_of_match);
+
+#ifdef CONFIG_ACPI
+static const struct acpi_device_id rts5453_acpi_match[] = {
+	{ "CIXH200D", 0 },
+	{ }
+};
+MODULE_DEVICE_TABLE(acpi, rts5453_acpi_match);
+#endif
+
+static const struct i2c_device_id rts5453_id[] = {
+	{ "rts5453h" },
+	{ }
+};
+MODULE_DEVICE_TABLE(i2c, rts5453_id);
+
+static struct i2c_driver rts5453_driver = {
+	.driver = {
+		.name = "rts5453",
+		.of_match_table = rts5453_of_match,
+		.acpi_match_table = ACPI_PTR(rts5453_acpi_match),
+		.pm = pm_sleep_ptr(&rts5453_pm_ops),
+	},
+	.probe = rts5453_probe,
+	.remove = rts5453_remove,
+	.id_table = rts5453_id,
+};
+
+module_i2c_driver(rts5453_driver);
