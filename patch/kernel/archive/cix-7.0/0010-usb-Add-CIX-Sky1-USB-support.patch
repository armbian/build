+/*
+ * Note: Mainline doesn't have platform_reset and platform_u3_disable hooks
+ * in struct cdns3_platform_data. These vendor extensions are not needed:
+ * - Role switching is handled by mainline's usb_role_switch framework
+ * - USB3 disabling is handled via standard "maximum-speed" DT property
+ */
+
+static void *sky1_of_get_addr_by_name(struct device_node *parent, char *name)
+{
+	struct device_node *node;
+	int index;
+
+	node = of_get_next_child(parent, NULL);
+	if (node) {
+		index = of_property_match_string(node, "reg-names", name);
+		if (index >= 0)
+			return of_iomap(node, index);
+	}
+
+	return NULL;
+}
