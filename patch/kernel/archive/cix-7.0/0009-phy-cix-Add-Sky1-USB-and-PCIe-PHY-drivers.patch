+static const struct regmap_config cix_udphy_regmap_cfg = {
+	.reg_bits = 32,
+	.reg_stride = 1,//register width, if =2, then only reg 0 2 4 ...2^n can access
+	.val_bits = 16,
+	.fast_io = true,
+	.reg_write = udphy_regmap_write,
+	.reg_read = udphy_regmap_read,
+};
