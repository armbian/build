From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Mon, 16 Feb 2026 17:35:58 +1100
Subject: [PATCH] phy: cix: Add Sky1 USB and PCIe PHY drivers

Add USB2, USB3, USB-DP combo, and PCIe PHY drivers for Sky1.
Includes ACPI boot guards and full PHY reset support.
---
 drivers/phy/Kconfig             |    1 +
 drivers/phy/Makefile            |    1 +
 drivers/phy/cix/Kconfig         |   36 +
 drivers/phy/cix/Makefile        |    5 +
 drivers/phy/cix/phy-cix-pcie.c  |  637 ++++++++++++
 drivers/phy/cix/phy-cix-usb2.c  |   58 ++
 drivers/phy/cix/phy-cix-usb3.c  |  477 +++++++++
 drivers/phy/cix/phy-cix-usbdp.c | 1643 +++++++++++++++++++++++++++++++
 drivers/phy/cix/phy-cix-usbdp.h |  347 +++++++
 9 files changed, 3205 insertions(+)
 create mode 100644 drivers/phy/cix/Kconfig
 create mode 100644 drivers/phy/cix/Makefile
 create mode 100644 drivers/phy/cix/phy-cix-pcie.c
 create mode 100644 drivers/phy/cix/phy-cix-usb2.c
 create mode 100644 drivers/phy/cix/phy-cix-usb3.c
 create mode 100644 drivers/phy/cix/phy-cix-usbdp.c
 create mode 100644 drivers/phy/cix/phy-cix-usbdp.h

diff --git a/drivers/phy/Kconfig b/drivers/phy/Kconfig
index 02467dfd4fb0a..11d96605ca250 100644
--- a/drivers/phy/Kconfig
+++ b/drivers/phy/Kconfig
@@ -151,6 +151,7 @@ source "drivers/phy/amlogic/Kconfig"
 source "drivers/phy/apple/Kconfig"
 source "drivers/phy/broadcom/Kconfig"
 source "drivers/phy/cadence/Kconfig"
+source "drivers/phy/cix/Kconfig"
 source "drivers/phy/freescale/Kconfig"
 source "drivers/phy/hisilicon/Kconfig"
 source "drivers/phy/ingenic/Kconfig"
diff --git a/drivers/phy/Makefile b/drivers/phy/Makefile
index a648c2e02a830..3e60ed13f9edd 100644
--- a/drivers/phy/Makefile
+++ b/drivers/phy/Makefile
@@ -22,6 +22,7 @@ obj-$(CONFIG_GENERIC_PHY)		+= allwinner/	\
 					   apple/	\
 					   broadcom/	\
 					   cadence/	\
+					   cix/		\
 					   freescale/	\
 					   hisilicon/	\
 					   ingenic/	\
diff --git a/drivers/phy/cix/Kconfig b/drivers/phy/cix/Kconfig
new file mode 100644
index 0000000000000..dcf77de2ffedb
--- /dev/null
+++ b/drivers/phy/cix/Kconfig
@@ -0,0 +1,36 @@
+# SPDX-License-Identifier: GPL-2.0-only
+
+config PHY_CIX_PCIE
+	bool "CIX Sky1 PCIe PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the PCIe PHY on CIX Sky1 SoCs.
+	  This driver provides PHY support for the Cadence PCIe controller
+	  on CIX Sky1 platforms.
+
+config PHY_CIX_USB2
+	bool "CIX Sky1 USB2 PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the USB2 PHY on CIX Sky1 SoCs.
+
+config PHY_CIX_USB3
+	bool "CIX Sky1 USB3 PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the USB3 PHY on CIX Sky1 SoCs.
+
+config PHY_CIX_USBDP
+	bool "CIX Sky1 USB-DP combo PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the USB-DP combo PHY on CIX Sky1 SoCs.
+	  This PHY supports both USB3 and DisplayPort alternate mode.
diff --git a/drivers/phy/cix/Makefile b/drivers/phy/cix/Makefile
new file mode 100644
index 0000000000000..8ab9af6e060b1
--- /dev/null
+++ b/drivers/phy/cix/Makefile
@@ -0,0 +1,5 @@
+# SPDX-License-Identifier: GPL-2.0
+obj-$(CONFIG_PHY_CIX_PCIE)	+= phy-cix-pcie.o
+obj-$(CONFIG_PHY_CIX_USB2)	+= phy-cix-usb2.o
+obj-$(CONFIG_PHY_CIX_USB3)	+= phy-cix-usb3.o
+obj-$(CONFIG_PHY_CIX_USBDP)	+= phy-cix-usbdp.o
