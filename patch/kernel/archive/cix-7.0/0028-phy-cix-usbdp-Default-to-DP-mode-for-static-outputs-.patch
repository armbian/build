From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Thu, 26 Feb 2026 14:04:48 +1100
Subject: [PATCH] phy: cix: usbdp: Default to DP mode for static outputs
 without mode-switch

Fixes an issue where static DisplayPort outputs without a Type-C
mode-switch would timeout waiting for PHY readiness by defaulting
to DP mode if a dp_phy subnode is present.
---
 drivers/phy/cix/phy-cix-usbdp.c | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/drivers/phy/cix/phy-cix-usbdp.c b/drivers/phy/cix/phy-cix-usbdp.c
index 91dbc14473d03..a9b192265db27 100644
--- a/drivers/phy/cix/phy-cix-usbdp.c
+++ b/drivers/phy/cix/phy-cix-usbdp.c
@@ -1600,8 +1600,15 @@ static int cix_udphy_probe(struct platform_device *pdev)
 		dev_err(dev, "failed to register phy provider\n");
 		goto put_child;
 	}
-	if (!device_property_present(dev, "mode-switch"))
+	if (!device_property_present(dev, "mode-switch")) {
+		if (udphy->next_mode == UDPHY_MODE_NONE) {
+			if (udphy->dp_phy)
+				udphy->next_mode = UDPHY_MODE_DP;
+			else
+				udphy->next_mode = UDPHY_MODE_USB;
+		}
 		usbdp_set_dpphy_mode(udphy);
+	}
 
 	return 0;
 
