From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 28 Feb 2026 13:28:02 +1100
Subject: [PATCH] fix allmodconfig build warnings across CIX drivers

- soc: cix-ddr-lp: make cix_set_ddrlp static (no external callers,
  remove unused EXPORT_SYMBOL)
- misc: armchina-npu: make aipu_mm_hold_tcb_buf_free and
  tensor_dcache_inval_poc static (file-local only)
- usb: cdnsp-sky1: make sky1_usb_clk_enable_all and sky1_handshake
  static (file-local only)
- drm: linlondp: guard component bind helpers with
  CONFIG_DRM_CIX_COMPONENT_BIND_BYPASSED to avoid unused
  function/variable warnings; remove dead LINUX_VERSION_CODE check
---
 drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c | 8 ++++----
 drivers/misc/armchina-npu/aipu_mm.c          | 4 ++--
 drivers/soc/cix/cix-ddr-lp.c                 | 3 +--
 drivers/usb/cdns3/cdnsp-sky1.c               | 4 ++--
 4 files changed, 9 insertions(+), 10 deletions(-)

diff --git a/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c b/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c
index f3464a63c4265..af334b56f6911 100644
--- a/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c
+++ b/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c
@@ -100,6 +100,7 @@ static int linlondp_bind(struct device *dev)
 	return err;
 }
 
+#if !IS_ENABLED(CONFIG_DRM_CIX_COMPONENT_BIND_BYPASSED)
 static const struct component_master_ops linlondp_master_ops = {
 	.bind = linlondp_bind,
 	.unbind = linlondp_unbind,
@@ -112,11 +113,7 @@ static int compare_of(struct device *dev, void *data)
 	if (has_acpi_companion(dev)) {
 		ret = dev->fwnode == data;
 	} else {
-#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 0, 0)
 		ret = component_compare_of(dev, data);
-#else
-		ret = dev->of_node == data;
-#endif
 	}
 
 	return ret;
@@ -156,14 +153,17 @@ static void linlondp_add_slave(struct device *master,
 		of_node_put(remote);
 	}
 }
+#endif
 
 static int linlondp_platform_probe(struct platform_device *pdev)
 {
 	struct device *dev = &pdev->dev;
+#if !IS_ENABLED(CONFIG_DRM_CIX_COMPONENT_BIND_BYPASSED)
 	struct component_match *match = NULL;
 	struct fwnode_handle *acpi_child;
 	struct device_node *of_child;
 	const char *tmp_name = NULL;
+#endif
 
 	dev_dbg(dev, "probe enter\n");
 #if !IS_ENABLED(CONFIG_DRM_CIX_COMPONENT_BIND_BYPASSED)
diff --git a/drivers/misc/armchina-npu/aipu_mm.c b/drivers/misc/armchina-npu/aipu_mm.c
index acd18f1e60c7c..03d34a50046d2 100755
--- a/drivers/misc/armchina-npu/aipu_mm.c
+++ b/drivers/misc/armchina-npu/aipu_mm.c
@@ -266,7 +266,7 @@ int aipu_mm_hold_tcb_buf_alloc(struct aipu_memory_manager *mm, struct aipu_job *
 	return ret;
 }
 
-void aipu_mm_hold_tcb_buf_free(struct aipu_memory_manager *mm)
+static void aipu_mm_hold_tcb_buf_free(struct aipu_memory_manager *mm)
 {
 	struct aipu_hold_tcb_buf *htbuf_head = mm->hold_tcb_head;
 	struct aipu_hold_tcb_buf *htbuf = NULL;
@@ -1615,7 +1615,7 @@ int aipu_mm_free(struct aipu_memory_manager *mm, struct aipu_buf_desc *buf, stru
 	return ret;
 }
 
-void tensor_dcache_inval_poc(void *start, void *end) {
+static void tensor_dcache_inval_poc(void *start, void *end) {
     uintptr_t line_size, addr_start, addr_end, tmp;
 
     line_size = cache_line_size();
diff --git a/drivers/soc/cix/cix-ddr-lp.c b/drivers/soc/cix/cix-ddr-lp.c
index 09076f37a11c9..a309d00283657 100644
--- a/drivers/soc/cix/cix-ddr-lp.c
+++ b/drivers/soc/cix/cix-ddr-lp.c
@@ -66,7 +66,7 @@ static int cix_enable_ddrlp(struct cix_ddrlp_data *dd)
 	return 0;
 }
 
-int cix_set_ddrlp(int on)
+static int cix_set_ddrlp(int on)
 {
 	if (!gdd)
 		return -ENODEV;
@@ -76,7 +76,6 @@ int cix_set_ddrlp(int on)
 	else
 		return cix_disable_ddrlp(gdd);
 }
-EXPORT_SYMBOL(cix_set_ddrlp);
 
 static ssize_t on_show(struct device *dev,
 		       struct device_attribute *attr, char *buf)
diff --git a/drivers/usb/cdns3/cdnsp-sky1.c b/drivers/usb/cdns3/cdnsp-sky1.c
index ed61e2a928b14..c43b07d51a850 100644
--- a/drivers/usb/cdns3/cdnsp-sky1.c
+++ b/drivers/usb/cdns3/cdnsp-sky1.c
@@ -81,7 +81,7 @@ static int sky1_set_mode_by_id(struct device *dev, int mode)
  *
  */
 
-int sky1_usb_clk_enable_all(struct device *dev)
+static int sky1_usb_clk_enable_all(struct device *dev)
 {
 	int i, ret;
 	struct cdnsp_sky1 *data = dev_get_drvdata(dev);
@@ -197,7 +197,7 @@ static void sky1_usb_clk_disable_suspend(struct device *dev)
 #define PS_D3			3
 #define PS_PME_En		(1 << 8)
 
-int sky1_handshake(void __iomem *ptr, u32 mask, u32 done, u64 timeout_us)
+static int sky1_handshake(void __iomem *ptr, u32 mask, u32 done, u64 timeout_us)
 {
 	u32	result;
 	int	ret;
