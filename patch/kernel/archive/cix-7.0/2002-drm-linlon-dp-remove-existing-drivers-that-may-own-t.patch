From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Jianfeng Liu <Jianfeng.Liu@cixtech.com>
Date: Mon, 23 Mar 2026 17:19:08 +0800
Subject: drm: linlon-dp: remove existing drivers that may own the framebuffer
 memory

---
 drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c b/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c
index 111111111111..222222222222 100644
--- a/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c
+++ b/drivers/gpu/drm/cix/linlon-dp/linlondp_drv.c
@@ -4,6 +4,7 @@
  * ALL RIGHTS RESERVED
  *
  */
+#include <linux/aperture.h>
 #include <linux/module.h>
 #include <linux/kernel.h>
 #include <linux/version.h>
@@ -66,6 +67,15 @@ static int linlondp_bind(struct device *dev)
 	struct linlondp_drv *mdrv;
 	int err;
 
+	/* Remove existing drivers that may own the framebuffer memory. */
+	err = aperture_remove_all_conflicting_devices("linlondp");
+	if (err) {
+		DRM_DEV_ERROR(dev,
+			      "Failed to remove existing framebuffers - %d.\n",
+			      err);
+		return err;
+	}
+
 	mdrv = devm_kzalloc(dev, sizeof(*mdrv), GFP_KERNEL);
 	if (!mdrv)
 		return -ENOMEM;
-- 
Armbian

