From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 21 Feb 2026 02:41:44 +1100
Subject: [PATCH] drm: add sky1-drm render node bridge for CIX Sky1 SoC

The Mali GPU on Sky1 uses a non-standard /dev/mali0 interface instead
of a DRM render node.  This prevents GBM and Mesa Zink from discovering
the GPU through the standard Linux graphics stack.

Add a minimal DRM module that provides:
- A render node (/dev/dri/renderDN)
- GEM shmem buffer allocation with write-combining
- PRIME (DMA-BUF) import/export

This replaces VGEM as the GBM backing device and enables proper GPU
discovery for hardware-accelerated OpenGL/Vulkan compositing on KDE
Plasma Wayland.

Modeled on drivers/gpu/drm/vgem/vgem_drv.c, minus fence ioctls.
---
 drivers/gpu/drm/Kconfig         |   2 +
 drivers/gpu/drm/Makefile        |   1 +
 drivers/gpu/drm/sky1/Kconfig    |  14 ++++
 drivers/gpu/drm/sky1/Makefile   |   2 +
 drivers/gpu/drm/sky1/sky1-drm.c | 115 ++++++++++++++++++++++++++++++++
 5 files changed, 134 insertions(+)
 create mode 100644 drivers/gpu/drm/sky1/Kconfig
 create mode 100644 drivers/gpu/drm/sky1/Makefile
 create mode 100644 drivers/gpu/drm/sky1/sky1-drm.c

diff --git a/drivers/gpu/drm/Kconfig b/drivers/gpu/drm/Kconfig
index 4011f5c3c38d2..e624d140036e3 100644
--- a/drivers/gpu/drm/Kconfig
+++ b/drivers/gpu/drm/Kconfig
@@ -275,6 +275,8 @@ config DRM_LIB_RANDOM
 
 source "drivers/gpu/drm/cix/Kconfig"
 
+source "drivers/gpu/drm/sky1/Kconfig"
+
 # DRM driver Kconfig files, sorted
 source "drivers/gpu/drm/adp/Kconfig"
 source "drivers/gpu/drm/amd/amdgpu/Kconfig"
diff --git a/drivers/gpu/drm/Makefile b/drivers/gpu/drm/Makefile
index c5334ea97d14f..7de0c58934949 100644
--- a/drivers/gpu/drm/Makefile
+++ b/drivers/gpu/drm/Makefile
@@ -170,6 +170,7 @@ obj-$(CONFIG_DRM_MIPI_DBI) += drm_mipi_dbi.o
 obj-$(CONFIG_DRM_MIPI_DSI) += drm_mipi_dsi.o
 obj-y			+= arm/
 obj-$(CONFIG_DRM_CIX)	+= cix/
+obj-$(CONFIG_DRM_SKY1)	+= sky1/
 obj-y			+= clients/
 obj-y			+= display/
 obj-$(CONFIG_DRM_TTM)	+= ttm/
diff --git a/drivers/gpu/drm/sky1/Kconfig b/drivers/gpu/drm/sky1/Kconfig
new file mode 100644
index 0000000000000..8a4bfcaa10234
--- /dev/null
+++ b/drivers/gpu/drm/sky1/Kconfig
@@ -0,0 +1,14 @@
+config DRM_SKY1
+	tristate "Sky1 GPU render node bridge"
+	depends on DRM && MMU
+	select DRM_GEM_SHMEM_HELPER
+	help
+	  Provides a DRM render node for the CIX Sky1 SoC.  The Mali GPU
+	  on Sky1 uses a non-standard device interface (/dev/mali0) that
+	  the Linux graphics stack cannot discover.  This module bridges
+	  the gap with a standard DRM render node providing GEM buffer
+	  allocation and DMA-BUF export/import (PRIME).
+
+	  Required for hardware-accelerated OpenGL via Mesa Zink on Sky1.
+
+	  If M is selected the module will be called sky1-drm.
diff --git a/drivers/gpu/drm/sky1/Makefile b/drivers/gpu/drm/sky1/Makefile
new file mode 100644
index 0000000000000..dbdc99f8fec83
--- /dev/null
+++ b/drivers/gpu/drm/sky1/Makefile
@@ -0,0 +1,2 @@
+# SPDX-License-Identifier: GPL-2.0-only
+obj-$(CONFIG_DRM_SKY1) += sky1-drm.o
diff --git a/drivers/gpu/drm/sky1/sky1-drm.c b/drivers/gpu/drm/sky1/sky1-drm.c
new file mode 100644
index 0000000000000..31ac998552578
--- /dev/null
+++ b/drivers/gpu/drm/sky1/sky1-drm.c
@@ -0,0 +1,115 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * sky1-drm - DRM render node bridge for CIX Sky1 SoC
+ *
+ * The Mali GPU on Sky1 uses a non-standard device interface (/dev/mali0)
+ * instead of a DRM render node.  This module provides a standard DRM render
+ * node with GEM shmem buffer allocation and PRIME (DMA-BUF) support, enabling
+ * GBM and Mesa Zink to discover and use the GPU via the normal Linux graphics
+ * stack.
+ *
+ * Modeled on drivers/gpu/drm/vgem/vgem_drv.c, minus fence ioctls.
+ */
+
+#include <linux/dma-buf.h>
+#include <linux/module.h>
+#include <linux/device/faux.h>
+
+#include <drm/drm_drv.h>
+#include <drm/drm_file.h>
+#include <drm/drm_gem_shmem_helper.h>
+#include <drm/drm_ioctl.h>
+#include <drm/drm_managed.h>
+
+#define DRIVER_NAME	"sky1-drm"
+#define DRIVER_DESC	"Sky1 GPU render node bridge"
+#define DRIVER_MAJOR	1
+#define DRIVER_MINOR	0
+
+static struct sky1_drm_device {
+	struct drm_device drm;
+	struct faux_device *faux_dev;
+} *sky1_device;
+
+static struct drm_gem_object *sky1_gem_create_object(struct drm_device *dev,
+						     size_t size)
+{
+	struct drm_gem_shmem_object *obj;
+
+	obj = kzalloc(sizeof(*obj), GFP_KERNEL);
+	if (!obj)
+		return ERR_PTR(-ENOMEM);
+
+	/* Write-combining ensures CPU writes are visible to DMA devices
+	 * (DPU, other consumers) without explicit cache management. */
+	obj->map_wc = true;
+
+	return &obj->base;
+}
+
+DEFINE_DRM_GEM_FOPS(sky1_drm_fops);
+
+static const struct drm_driver sky1_drm_driver = {
+	.driver_features	= DRIVER_GEM | DRIVER_RENDER,
+	.fops			= &sky1_drm_fops,
+
+	DRM_GEM_SHMEM_DRIVER_OPS,
+	.gem_create_object	= sky1_gem_create_object,
+
+	.name	= DRIVER_NAME,
+	.desc	= DRIVER_DESC,
+	.major	= DRIVER_MAJOR,
+	.minor	= DRIVER_MINOR,
+};
+
+static int __init sky1_drm_init(void)
+{
+	int ret;
+	struct faux_device *fdev;
+
+	fdev = faux_device_create(DRIVER_NAME, NULL, NULL);
+	if (!fdev)
+		return -ENODEV;
+
+	if (!devres_open_group(&fdev->dev, NULL, GFP_KERNEL)) {
+		ret = -ENOMEM;
+		goto out_destroy;
+	}
+
+	dma_coerce_mask_and_coherent(&fdev->dev, DMA_BIT_MASK(64));
+
+	sky1_device = devm_drm_dev_alloc(&fdev->dev, &sky1_drm_driver,
+					 struct sky1_drm_device, drm);
+	if (IS_ERR(sky1_device)) {
+		ret = PTR_ERR(sky1_device);
+		goto out_devres;
+	}
+	sky1_device->faux_dev = fdev;
+
+	ret = drm_dev_register(&sky1_device->drm, 0);
+	if (ret)
+		goto out_devres;
+
+	return 0;
+
+out_devres:
+	devres_release_group(&fdev->dev, NULL);
+out_destroy:
+	faux_device_destroy(fdev);
+	return ret;
+}
+
+static void __exit sky1_drm_exit(void)
+{
+	struct faux_device *fdev = sky1_device->faux_dev;
+
+	drm_dev_unregister(&sky1_device->drm);
+	devres_release_group(&fdev->dev, NULL);
+	faux_device_destroy(fdev);
+}
+
+module_init(sky1_drm_init);
+module_exit(sky1_drm_exit);
+
+MODULE_DESCRIPTION(DRIVER_DESC);
+MODULE_LICENSE("GPL");
