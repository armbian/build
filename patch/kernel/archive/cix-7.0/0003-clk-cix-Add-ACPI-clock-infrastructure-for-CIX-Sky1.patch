+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * CIX Sky1 Audio Subsystem Clock Controller
+ *
+ * Copyright 2024 Cix Technology Group Co., Ltd.
+ */
+
+#include <linux/acpi.h>
+#include <linux/clk.h>
+#include <linux/clk-provider.h>
+#include <linux/clkdev.h>
+#include <linux/device/bus.h>
+#include <linux/io.h>
+#include <linux/mfd/syscon.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/platform_device.h>
+#include <linux/pm_runtime.h>
+#include <linux/property.h>
+#include <linux/regmap.h>
+#include <linux/reset.h>
+
+#include <dt-bindings/clock/sky1-audss.h>
+
+/* Register offsets within AUDSS CRU */
+#define INFO_HIFI0		0x00
+#define INFO_CLK_GATE		0x10
+#define INFO_CLK_DIV		0x14
+#define INFO_CLK_MUX		0x18
+#define INFO_MCLK		0x70
+
+/* RCSU registers for DSP initialization */
+#define SKY1_AUDSS_RCSU_ADDR		0x07000000
+#define SKY1_AUDSS_RCSU_LEN		0x10000
+#define SKY1_AUDSS_RCSU_REMAP		0x34
+#define SKY1_AUDSS_RCSU_REMAP_VAL	0x20000000
+#define SKY1_AUDSS_RCSU_TIMEOUT		0x1000
+#define SKY1_AUDSS_RCSU_TIMEOUT_EN	BIT(31)
+#define SKY1_AUDSS_RCSU_TIMEOUT_VAL	0x78
+
+#define SKY1_AUDSS_CLKS_NUM		6
+
+static DEFINE_SPINLOCK(sky1_audss_lock);
+
+static const char * const sky1_audss_clk_names[SKY1_AUDSS_CLKS_NUM] = {
+	"audio_clk0", "audio_clk1", "audio_clk2",
+	"audio_clk3", "audio_clk4", "audio_clk5",
+};
+
+static const u32 sky1_audss_clk_rates[SKY1_AUDSS_CLKS_NUM] = {
+	SKY1_AUDSS_AUDIO_CLK0_RATE,
+	SKY1_AUDSS_AUDIO_CLK1_RATE,
+	SKY1_AUDSS_AUDIO_CLK2_RATE,
+	SKY1_AUDSS_AUDIO_CLK3_RATE,
+	SKY1_AUDSS_AUDIO_CLK4_RATE,
+	SKY1_AUDSS_AUDIO_CLK5_RATE,
+};
+
+struct sky1_audss_priv {
+	struct device *dev;
+	struct regmap *regmap;
+	void __iomem *rcsu_base;
+	struct clk *parent_clks[SKY1_AUDSS_CLKS_NUM];
+	struct reset_control *rst_noc;
+	struct clk_hw_onecell_data *clk_data;
+};
+
+/* Clock configuration structures */
+struct muxdiv_cfg {
+	int offset;
+	u8 shift;
+	u8 width;
+	u8 flags;
+};
+
+struct gate_cfg {
+	int offset;
+	u8 shift;
+	u8 flags;
+};
+
+struct composite_clk_cfg {
+	u32 id;
+	const char *name;
+	const char * const *parent_names;
+	int num_parents;
+	struct muxdiv_cfg *mux_cfg;
+	struct muxdiv_cfg *div_cfg;
+	struct gate_cfg *gate_cfg;
+	unsigned long flags;
+};
+
+/* Custom clock structures with regmap support */
+struct sky1_clk_mux {
+	struct clk_mux mux;
+	struct regmap *regmap;
+	int offset;
+};
+
+struct sky1_clk_divider {
+	struct clk_divider div;
+	struct regmap *regmap;
+	int offset;
+};
+
+struct sky1_clk_gate {
+	struct clk_gate gate;
+	struct regmap *regmap;
+	struct device *dev;
+	int offset;
+};
+
+/* Registers to save/restore during suspend/resume */
+static u32 sky1_audss_reg_save[][2] = {
+	{ INFO_HIFI0, 0 },
+	{ INFO_CLK_GATE, 0 },
+	{ INFO_CLK_DIV, 0 },
+	{ INFO_CLK_MUX, 0 },
+	{ INFO_MCLK, 0 },
+};
+
+/* Parent clock arrays */
+static const char * const dsp_clk_parent[] = { "audio_clk4" };
+static const char * const dsp_bclk_parent[] = { "audio_clk4_div2" };
+static const char * const dsp_pbclk_parent[] = { "audio_clk4_div4" };
+static const char * const sram_axi_parent[] = { "audio_clk4_div2" };
+static const char * const hda_sys_parent[] = { "audio_clk4_div2" };
+static const char * const hda_hda_parent[] = { "audio_clk5" };
+static const char * const dmac_axi_parent[] = { "audio_clk4_div2" };
+static const char * const wdg_parent[] = { "audio_clk5_div2" };
+static const char * const timer_apb_parent[] = { "audio_clk4_div4" };
+static const char * const timer_timer_parent[] = { "audio_clk5_div2" };
+static const char * const mailbox_apb_parent[] = { "audio_clk4_div4" };
+static const char * const i2s_apb_parent[] = { "audio_clk4_div4" };
+static const char * const i2s_sc_parents[] = { "audio_clk0", "audio_clk2" };
+static const char * const i2s_mc_parents[] = { "audio_clk0", "audio_clk1", "audio_clk2", "audio_clk3" };
+static const char * const mclk_parents[] = { "audio_clk0", "audio_clk2" };
+
+/* Configuration macro */
+#define CFG(_id, _name, _parents, \
+	    _mux_off, _mux_sh, _mux_w, _mux_fl, \
+	    _div_off, _div_sh, _div_w, _div_fl, \
+	    _gate_off, _gate_sh, _gate_fl, \
+	    _flags) \
+{ \
+	.id = _id, \
+	.name = _name, \
+	.parent_names = _parents, \
+	.num_parents = ARRAY_SIZE(_parents), \
+	.mux_cfg = &(struct muxdiv_cfg){ _mux_off, _mux_sh, _mux_w, _mux_fl }, \
+	.div_cfg = &(struct muxdiv_cfg){ _div_off, _div_sh, _div_w, _div_fl }, \
+	.gate_cfg = &(struct gate_cfg){ _gate_off, _gate_sh, _gate_fl }, \
+	.flags = _flags, \
+}
+
