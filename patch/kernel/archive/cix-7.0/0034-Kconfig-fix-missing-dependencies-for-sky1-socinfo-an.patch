From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 28 Feb 2026 01:40:40 +1100
Subject: [PATCH] Kconfig: fix missing dependencies for sky1-socinfo and
 trilin-dpsub

sky1-socinfo uses soc_device_to_device() from the SOC_BUS framework but
didn't select it, causing modpost errors when built as a module without
SOC_BUS enabled by another driver.

trilin-dpsub uses backlight_device_get_by_name() for eDP panel support
but didn't select BACKLIGHT_CLASS_DEVICE.

Fixes: https://github.com/Sky1-Linux/linux-sky1/issues/13
---
 drivers/gpu/drm/cix/dptx/Kconfig | 1 +
 drivers/soc/cix/Kconfig          | 1 +
 2 files changed, 2 insertions(+)

diff --git a/drivers/gpu/drm/cix/dptx/Kconfig b/drivers/gpu/drm/cix/dptx/Kconfig
index 08e5641df6a6a..38eaefd2c11fa 100644
--- a/drivers/gpu/drm/cix/dptx/Kconfig
+++ b/drivers/gpu/drm/cix/dptx/Kconfig
@@ -8,6 +8,7 @@ config DRM_TRILIN_DPSUB
 	select DRM_DISPLAY_HDMI_HELPER
 	select DRM_DP_AUX_CHARDEV
 	select GENERIC_PHY
+	select BACKLIGHT_CLASS_DEVICE
 	select SND_SOC_HDMI_CODEC if SND_SOC
 	help
 	  This is a DRM/KMS driver for Trilinear Technologies DisplayPort controller.
diff --git a/drivers/soc/cix/Kconfig b/drivers/soc/cix/Kconfig
index 01acdfdebd33d..abb48cc3bac87 100644
--- a/drivers/soc/cix/Kconfig
+++ b/drivers/soc/cix/Kconfig
@@ -4,6 +4,7 @@ config CIX_SKY1_SOCINFO
 	tristate "CIX Sky1 SoC information driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on NVMEM
+	select SOC_BUS
 	default ARCH_CIX
 	help
 	  Say yes here to enable support for the CIX Sky1 SoC information
