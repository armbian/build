From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 28 Feb 2026 00:52:18 +1100
Subject: [PATCH] media: linlon: add missing VIDEOBUF2_DMA_SG and
 VIDEOBUF2_MEMOPS dependencies

VIDEO_LINLON uses vb2_dma_sg_plane_desc() and vb2_dma_sg_memops from
the videobuf2-dma-sg module, but its Kconfig entry didn't select the
required symbols. This caused build failures when VIDEOBUF2_DMA_SG
wasn't already enabled by another driver.

Add select VIDEOBUF2_DMA_SG and select VIDEOBUF2_MEMOPS to fix the
dependency chain.
---
 drivers/media/platform/cix/Kconfig | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/media/platform/cix/Kconfig b/drivers/media/platform/cix/Kconfig
index 6d9391eeafff9..dd3a6c2cd8ee2 100755
--- a/drivers/media/platform/cix/Kconfig
+++ b/drivers/media/platform/cix/Kconfig
@@ -2,6 +2,8 @@
 config VIDEO_LINLON
 	tristate "Linlon VPU support"
 	depends on VIDEO_DEV
+	select VIDEOBUF2_DMA_SG
+	select VIDEOBUF2_MEMOPS
 	default y
 	help
 	  This enables support for the Linlon VPU family.
