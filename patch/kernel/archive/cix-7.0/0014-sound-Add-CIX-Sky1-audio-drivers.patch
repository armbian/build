+{
+	.name = "i2s0",
+	.playback = {
+		.channels_min = 1,
+		.channels_max = 16,
+	},
+	.capture = {
+		.channels_min = 1,
+		.channels_max = 16,
+	},
+	.symmetric_rate = 1,
+	.symmetric_channels = 1,
+},
+{
