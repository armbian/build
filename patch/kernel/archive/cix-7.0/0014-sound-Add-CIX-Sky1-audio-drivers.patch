+	case I2S_SRES:
+	case I2S_SRES_FDR:
+	case I2S_SRATE:
+	case I2S_STAT:
+	case I2S_FIFO_LEVEL:
+	case I2S_FIFO_AEMPTY:
+	case I2S_FIFO_AFULL:
+	case I2S_FIFO_LEVEL_FDR:
+	case I2S_FIFO_AEMPTY_FDR:
+	case I2S_FIFO_AFULL_FDR:
+	case I2S_TDM_CTRL:
+	case I2S_TDM_FD_DIR:
+		return true;
+	default:
