+//  TR_DPTX_HDCP_KS_1                   WO  Km bits 63:32
+//  TR_DPTX_HDCP_KM_31_0                WO  Km bits 95:64
+//  TR_DPTX_HDCP_KM_63_32               WO  Km bits 127:96
+//
+//  Parameters:
