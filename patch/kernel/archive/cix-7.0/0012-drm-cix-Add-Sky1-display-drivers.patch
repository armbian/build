index 0000000000000..6081aa19cdf3c
--- /dev/null
+++ b/drivers/gpu/drm/cix/dptx/cix_edp_panel.c
@@ -0,0 +1,880 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
