+static int trilin_dp_panel_config_misc(struct trilin_dp *dp,
+				       struct trilin_dp_panel *dp_panel)
+{
+	struct trilin_connector *conn = dp_panel->connector;
+
+	trilin_dp_set_misc(dp, dp_panel->stream_id, &conn->config);
