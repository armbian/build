+static void trilin_dp_gop_set(void)
+{
+	struct arm_smccc_res res;
+	int dp_gop_bit = 1;
+
+	arm_smccc_smc(CIX_SIP_DP_GOP_CTRL, SKY1_SIP_DP_GOP_SET,
+			dp_gop_bit << DP_GOP_SHIFT, 0, 0, 0, 0, 0, &res);
+}
