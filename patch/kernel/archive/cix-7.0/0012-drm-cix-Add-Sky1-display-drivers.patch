+	u32 __iomem *periph_addr;
+
+	struct dp_pipeline *pipes[DP_MAX_PIPELINE];
+	struct linlondp_coeffs_manager *it_mgr;
+	struct linlondp_coeffs_manager *ft_mgr;
+	struct linlondp_coeffs_manager *it_s_mgr;
+};
