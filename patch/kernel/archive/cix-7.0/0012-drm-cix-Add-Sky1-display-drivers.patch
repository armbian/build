+int trilin_connector_update_modes(struct drm_connector *connector,
+				  struct edid *edid)
+{
+	int ret;
+	struct trilin_dp *dp = connector_to_dp(connector);
+
+	DP_DEBUG("enter\n");
+	drm_connector_update_edid_property(connector, edid);
+	ret = drm_add_edid_modes(connector, edid);
+
+	return ret;
+}
