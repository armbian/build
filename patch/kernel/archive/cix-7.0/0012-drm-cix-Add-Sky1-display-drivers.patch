+//------------------------------------------------------------------------------
+typedef enum {
+	aes_tx_sel_disabled,
+	aes_tx_sel_normal,
+	aes_tx_sel_key_derivation,
+	aes_tx_sel_ekh,
+} aes_tx_select_t;
