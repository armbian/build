+	(GLB_IRQ_STATUS_LPU0 | GLB_IRQ_STATUS_ATU0 | GLB_IRQ_STATUS_ATU1 | \
+	 GLB_IRQ_STATUS_CU0 | GLB_IRQ_STATUS_DOU0)
