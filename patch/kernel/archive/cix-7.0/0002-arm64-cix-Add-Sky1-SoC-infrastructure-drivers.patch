new file mode 100644
index 0000000000000..01acdfdebd33d
--- /dev/null
+++ b/drivers/soc/cix/Kconfig
@@ -0,0 +1,87 @@
+# SPDX-License-Identifier: GPL-2.0-only
+
+config CIX_SKY1_SOCINFO
+	tristate "CIX Sky1 SoC information driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on NVMEM
+	default ARCH_CIX
+	help
+	  Say yes here to enable support for the CIX Sky1 SoC information
+	  driver. This provides SoC identification, firmware version
+	  information, and board details via sysfs.
+
+	  This driver can also be built as a module. If so, the module
+	  will be called sky1-socinfo.
+
+config CIX_DDR_LP
+	tristate "CIX DDR Low Power control driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on HAVE_ARM_SMCCC
+	default ARCH_CIX
+	help
+	  Say yes here to enable support for the CIX DDR low power control
+	  driver. This allows enabling/disabling DDR self-refresh and power-down
+	  states via SMC calls to TF-A firmware.
+
+	  The driver exposes a sysfs interface at /sys/devices/.../on to control
+	  DDR low power mode (1=enabled, 0=disabled).
+
+	  This driver can also be built as a module. If so, the module
+	  will be called cix-ddr-lp.
+
+config CIX_ACPI_RESOURCE_LOOKUP
+	bool "CIX ACPI resource lookup driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on ACPI
+	depends on RESET_CONTROLLER
+	default ARCH_CIX
+	help
+	  Processes custom CIX DSDT tables (RSTL, RSNL, DLKL) to register
+	  reset control lookups, assign names to platform resources, and
+	  create device link dependencies. This bridges CIX's ACPI firmware
+	  with the Linux kernel's standard resource lookup mechanisms.
+
+	  Required for CIX Sky1 ACPI boot with drivers that use
+	  platform_get_resource_byname() or devm_reset_control_get().
+
+config CIX_ACPI_USB_SCAN
+	bool "CIX ACPI USB scan handler"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on ACPI
+	default ARCH_CIX
+	help
+	  Block PNP0D10 (generic xHCI) platform device creation on CIX Sky1
+	  so the vendor USB driver chain (cdnsp-sky1 + cdnsp-plat) can own
+	  the hardware instead of xhci-plat.
+
+	  Required for proper USB controller initialization under ACPI boot.
+
+config CIX_ACPI_GPU_SCAN
+	bool "CIX ACPI GPU coherency scan handler"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on ACPI
+	default ARCH_CIX
+	help
+	  Override _CCA (Cache Coherency Attribute) for the CIX Sky1 GPU
+	  (CIXH5000) from coherent to non-coherent during ACPI enumeration.
+
+	  The Sky1 DSDT declares the GPU as coherent (_CCA=1) but the SoC
+	  was designed for non-coherent GPU operation.  Without this fix,
+	  the GPU enables ACE-Lite coherency causing stale framebuffer
+	  reads by the non-coherent DPU (display corruption).
+
+config CIX_BUS_PERF
+	tristate "CIX Bus Performance State Control driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on PM_GENERIC_DOMAINS
+	depends on PM_OPP
+	default ARCH_CIX
+	help
+	  Say yes here to enable support for the CIX CI700/NI700 bus frequency
+	  control driver. This allows controlling memory interconnect frequency
+	  via SCMI performance domains.
+
+	  The driver exposes a sysfs interface for setting bus frequency.
+
+	  This driver can also be built as a module. If so, the module
+	  will be called cix-bus-perf.
