From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: SuperKali <hello@superkali.me>
Date: Thu, 28 May 2026 11:00:00 +0200
Subject: arm64: dts: rockchip: Complete NanoPi M5 board description

The mainline rk3576-nanopi-m5.dts is a minimal first-cut that omits
several on-board peripherals described in the FriendlyElec schematics.
Fill in the gaps:

  - Wi-Fi: enable the SDIO host (sdio @ 0x2a320000) for the optional
    M.2 RTL8822CS module, with mmc-pwrseq-simple toggling GPIO1_C2 to
    power-cycle the chip on probe.

  - Bluetooth: enable UART5 with hardware flow control and expose the
    BT_REG_ON / BT_HOST_WAKE / BT_DEV_WAKE lines via a
    "realtek,rtl8822cs-bt" child node.

  - Pinctrl: add the matching wireless-bluetooth and wireless-wlan
    groups for uart5_gpios / wifi_host_wake_irq / wifi_poweren_gpio.

  - GMAC: set RGMII tx_delay (0x21 on gmac0, 0x20 on gmac1) to match
    the FriendlyElec vendor kernel. Leave rx_delay unset: the on-board
    RTL8211F PHYs use rgmii-id and apply the RX delay internally, so an
    extra SoC-side rx_delay double-delays RX and breaks gigabit.

  - ADC keys: add the saradc back button on saradc channel 0
    (~17 mV press threshold) so the BACK key on the carrier works.

  - UART3 / UART8: enable the auxiliary UARTs exposed on the GPIO
    header (uart3m0_xfer / uart8m1_xfer pinmuxes) for users wiring up
    sensors, GPS, etc.

  - USB DRD0: force usb_drd0_dwc3 to dr_mode = "host" and drop the
    extcon link to u2phy0. Both physical USB3 ports on the M5 are
    Type-A; DRD0 is wired to the second one and was declared as OTG
    by mainline, but dwc3-rockchip on 6.18 / 7.0 / 7.1 does not
    consume the rockchip-usb2phy OTG extcon to switch role at probe,
    so the controller stays stuck in peripheral and the SuperSpeed
    lane on that port never enumerates. Pinning it to host exposes
    the second 5 Gbps Type-A port; OTG gadget usage on this port
    was never functional anyway.

Signed-off-by: SuperKali <hello@superkali.me>
---
 arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts | 86 +++++++++-
 1 file changed, 84 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts b/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts
index 111111111111..222222222222 100644
--- a/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3576-nanopi-m5.dts
@@ -212,6 +212,28 @@ vcc_3v3_s0: regulator-vcc-3v3-s0 {
 		vin-supply = <&vcc_3v3_s3>;
 	};
 
+	saradc_keys: adc-keys {
+		compatible = "adc-keys";
+		io-channels = <&saradc 0>;
+		io-channel-names = "buttons";
+		keyup-threshold-microvolt = <1800000>;
+		poll-interval = <100>;
+
+		button-back {
+			label = "back";
+			linux,code = <KEY_BACK>;
+			press-threshold-microvolt = <17000>;
+		};
+	};
+
+	sdio_pwrseq: sdio-pwrseq {
+		compatible = "mmc-pwrseq-simple";
+		pinctrl-names = "default";
+		pinctrl-0 = <&wifi_poweren_gpio>;
+		post-power-on-delay-ms = <200>;
+		reset-gpios = <&gpio1 RK_PC2 GPIO_ACTIVE_LOW>;
+	};
+
 	sound {
 		compatible = "simple-audio-card";
 		pinctrl-names = "default";
@@ -304,6 +326,7 @@ &gmac0 {
 		    <&eth0m0_rx_bus2>,
 		    <&eth0m0_rgmii_clk>,
 		    <&eth0m0_rgmii_bus>;
+	tx_delay = <0x21>;
 	status = "okay";
 };
 
@@ -318,6 +341,7 @@ &gmac1 {
 		    <&eth1m0_rx_bus2>,
 		    <&eth1m0_rgmii_clk>,
 		    <&eth1m0_rgmii_bus>;
+	tx_delay = <0x20>;
 	status = "okay";
 };
 
@@ -875,6 +899,22 @@ usb_otg0_pwren_h: usb-otg0-pwren-h {
 			rockchip,pins = <0 RK_PD1 RK_FUNC_GPIO &pcfg_pull_none>;
 		};
 	};
+
+	wireless-bluetooth {
+		uart5_gpios: uart5-gpios {
+			rockchip,pins = <3 RK_PD6 RK_FUNC_GPIO &pcfg_pull_none>;
+		};
+	};
+
+	wireless-wlan {
+		wifi_host_wake_irq: wifi-host-wake-irq {
+			rockchip,pins = <0 RK_PB0 RK_FUNC_GPIO &pcfg_pull_down>;
+		};
+
+		wifi_poweren_gpio: wifi-poweren-gpio {
+			rockchip,pins = <1 RK_PC2 RK_FUNC_GPIO &pcfg_pull_up>;
+		};
+	};
 };
 
 &sai2 {
@@ -890,6 +930,24 @@ &saradc {
 	status = "okay";
 };
 
+&sdio {
+	bus-width = <4>;
+	cap-sdio-irq;
+	keep-power-in-suspend;
+	max-frequency = <200000000>;
+	mmc-pwrseq = <&sdio_pwrseq>;
+	no-mmc;
+	no-sd;
+	non-removable;
+	pinctrl-names = "default";
+	pinctrl-0 = <&sdmmc1m0_bus4>, <&sdmmc1m0_clk>, <&sdmmc1m0_cmd>;
+	sd-uhs-sdr104;
+	vmmc-supply = <&vcc_3v3_s3>;
+	vqmmc-supply = <&vcc_1v8_s3>;
+	wakeup-source;
+	status = "okay";
+};
+
 &sdmmc {
 	bus-width = <4>;
 	cap-mmc-highspeed;
@@ -943,6 +1001,31 @@ &uart0 {
 	status = "okay";
 };
 
+&uart3 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart3m0_xfer>;
+	status = "okay";
+};
+
+&uart5 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart5m0_xfer>, <&uart5m0_ctsn>, <&uart5m0_rtsn>;
+	status = "okay";
+
+	bluetooth {
+		compatible = "realtek,rtl8822cs-bt";
+		device-wake-gpios = <&gpio3 RK_PD0 GPIO_ACTIVE_HIGH>;
+		enable-gpios = <&gpio3 RK_PC7 GPIO_ACTIVE_HIGH>;
+		host-wake-gpios = <&gpio0 RK_PB1 GPIO_ACTIVE_HIGH>;
+	};
+};
+
+&uart8 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart8m1_xfer>;
+	status = "okay";
+};
+
 &ufshc {
 	vcc-supply = <&vcc_3v3_s3>;
 	vccq-supply = <&vcc1v2_ufs_vccq>;
@@ -956,8 +1039,7 @@ &usbdp_phy {
 };
 
 &usb_drd0_dwc3 {
-	dr_mode = "otg";
-	extcon = <&u2phy0>;
+	dr_mode = "host";
 	status = "okay";
 };
 
-- 
Armbian

