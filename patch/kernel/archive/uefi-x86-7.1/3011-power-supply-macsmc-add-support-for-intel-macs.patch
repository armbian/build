+static int macsmc_ac_read_f32_scaled(struct apple_smc *smc, smc_key key,
+                                        int *p, int scale)
+{
+	u32 fval, val;
+	int ret, exp;
+
+	ret = apple_smc_read_u32(smc, key, &fval);
+	if (ret < 0)
+		return ret;
+
+	val = ((u32)((fval & GENMASK(22, 0)) | BIT(23)));
+	exp = ((fval >> 23) & 0xff) - 127 - 23;
+
+	/* We never have negatively scaled SMC floats */
+	val *= scale;
+
+	if (exp > 31)
+		val = U32_MAX;
+	else if (exp < -31)
+		val = 0;
+	else if (exp < 0)
+		val >>= -exp;
+	else if (exp != 0 && (val & ~((1ULL << (32 - exp)) - 1))) /* overflow */
+		val = U32_MAX;
+	else
+		val <<= exp;
+
+	if (fval & BIT(31)) {
+		if (val > (u32)INT_MAX + 1)
+			*p = INT_MIN;
+		else
+			*p = -(int)val;
+	} else {
+		if (val > (u32)INT_MAX)
+			*p = INT_MAX;
+		else
+			*p = (int)val;
+	}
+
+	return 0;
+}
