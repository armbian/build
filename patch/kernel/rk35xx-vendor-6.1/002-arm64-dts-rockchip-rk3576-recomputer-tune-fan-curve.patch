From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Baozhu Zuo <zuobaozhu@gmail.com>
Date: Fri, 17 Apr 2026 14:05:00 +0800
Subject: [PATCH] arm64: dts: rockchip: rk3576 recomputer: tune fan curve

Keep the fan spinning at the measured minimum duty after boot,
and add smaller intermediate PWM steps for smoother ramp-up.
---
--- a/arch/arm64/boot/dts/rockchip/rk3576-recomputer-rk3576-devkit.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3576-recomputer-rk3576-devkit.dts
@@ -42,7 +42,7 @@
 		status = "okay";
 		compatible = "pwm-fan";
 		#cooling-cells = <2>;
-		cooling-levels = <0 50 100 150 200 255>;
+		cooling-levels = <25 45 60 75 100 130 170 210 255>;
 		fan-supply = <&vcc_sys>;
 		pwms = <&pwm0_2ch_0 0 60000 0>;
 
@@ -53,11 +53,15 @@
 		pinctrl-0 = <&fan_tach>;
 
 		rockchip,temp-trips = <
-            20000    1
-            25000    2
-            30000    3
-            35000    5
-        >;
+			38000	1
+			44000	2
+			50000	3
+			56000	4
+			62000	5
+			68000	6
+			74000	7
+			80000	8
+		>;
 	};
 
 	vcc_sys: vcc5v0-sys {

-- 
2.43.0
