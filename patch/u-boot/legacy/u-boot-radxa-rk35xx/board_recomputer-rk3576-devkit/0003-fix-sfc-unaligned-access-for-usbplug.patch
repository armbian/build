From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Ming Zhangqun <north_sea@qq.com>
Date: Thu, 12 Jun 2026 16:00:00 +0800
Subject: [PATCH] fix: sfc unaligned access for usbplug SPI flash capability

Backport from Rockchip SDK: handle 1/2/3 byte unaligned SFC writes by
copying to an aligned temp buffer. Without this fix, usbplug fails to
read SPI flash capability in Maskrom mode.

Signed-off-by: Ming Zhangqun <north_sea@qq.com>
---
 drivers/rkflash/sfc.c | 19 ++++++++++++++++++-
 1 file changed, 18 insertions(+), 1 deletion(-)

diff --git a/drivers/rkflash/sfc.c b/drivers/rkflash/sfc.c
--- a/drivers/rkflash/sfc.c
+++ b/drivers/rkflash/sfc.c
@@ -84,6 +84,8 @@
 	union SFCCMD_DATA cmd;
 	int reg;
 	int timeout = 0;
+	u32 *p_data = (u32 *)data;
+	u32 temp = 0;
 
 	reg = readl(g_sfc_reg + SFC_FSR);
 
@@ -93,6 +95,22 @@
 
 	cmd.d32 = op->sfcmd.d32;
 
+	if (size && size < 4 && cmd.b.rw == SFC_WRITE) {
+		if (size == 1)
+			temp = *((u8 *)data);
+		else if (size == 2)
+			temp = *((u16 *)data);
+		else
+			temp = ((u8 *)data)[0] | ((u8 *)data)[1] << 8 | ((u8 *)data)[2] << 16;
+		p_data = &temp;
+	} else if (size >= 4 && ((uintptr_t)data & 0x3)) {
+		printf("%s data addr unaligned access\n", __func__);
+		return SFC_ERROR;
+	} else if (size & 0x3 && cmd.b.rw == SFC_WRITE) {
+		printf("%s data size unaligned access\n", __func__);
+		return SFC_ERROR;
+	}
+
 	if (cmd.b.addrbits == SFC_ADDR_XBITS) {
 		union SFCCTRL_DATA ctrl;
 
@@ -155,7 +171,6 @@
 	} else {
 		u32 i, words, count, bytes;
 		union SFCFSR_DATA    fifostat;
-		u32 *p_data = (u32 *)data;
 
 		if (cmd.b.rw == SFC_WRITE) {
 			words  = (size + 3) >> 2;
