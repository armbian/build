From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Armbian <build@armbian.com>
Date: Tue, 21 Jul 2026 00:00:00 +0000
Subject: [PATCH] rock-4d-spi: allow 128 GPT partition entries

Radxa defaults CONFIG_EFI_PARTITION_ENTRIES_NUMBERS=64. Armbian images
and mainline U-Boot use 128-entry GPTs, so bump Rock 4D SPI to match.

--- a/configs/rock-4d-spi-rk3576_defconfig
+++ b/configs/rock-4d-spi-rk3576_defconfig
@@ -81,7 +81,7 @@ CONFIG_CMD_MTD_BLK=y
 # CONFIG_SPL_DOS_PARTITION is not set
 # CONFIG_ISO_PARTITION is not set
-CONFIG_EFI_PARTITION_ENTRIES_NUMBERS=64
+CONFIG_EFI_PARTITION_ENTRIES_NUMBERS=128
 CONFIG_SPL_OF_CONTROL=y
 CONFIG_SPL_DTB_MINIMUM=y
 CONFIG_OF_LIVE=y
