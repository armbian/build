/dts-v1/;
#include "rk3588.dtsi"
#include "rk3588-u-boot.dtsi"
#include <dt-bindings/input/input.h>

/ {
	model = "Seeed Studio reComputer RK3588 DevKit";
	compatible = "seeed,recomputer-rk3588-devkit", "rockchip,rk3588";


	adc-keys {
		compatible = "adc-keys";
		io-channels = <&saradc 1>;
		io-channel-names = "buttons";
		keyup-threshold-microvolt = <1800000>;
		u-boot,dm-pre-reloc;
		status = "okay";

		volumeup-key {
			u-boot,dm-pre-reloc;
			linux,code = <KEY_VOLUMEUP>;
			label = "volume up";
			/*
			 * On this board the volume-up button shorts the
			 * SARADC channel directly to GND when pressed:
			 *
			 *   released: ~1.80 V (raw=4091 of 4095, VREF)
			 *   pressed:  ~0.02 V (raw=43 of 4095, near GND)
			 *
			 * U-Boot's adc_key driver uses a fixed +/-150000 uV
			 * margin around the threshold, so with a single key
			 * the press window becomes [0, threshold + 75000].
			 * A threshold of 100000 uV yields window [0, 175000]
			 * which cleanly captures the pressed rail (~18900 uV)
			 * and rejects the released rail (~1798000 uV) plus
			 * SARADC/OTG noise. The previous 1750000 uV setting
			 * put VREF itself inside the window and triggered a
			 * false download-mode entry; 900000 uV (~VREF/2)
			 * avoided the false trigger but could not detect the
			 * actual press because the channel never settles there.
			 */
			press-threshold-microvolt = <100000>;
		};
	};


	vcc12v0_sys: vcc12v0-sys {
		u-boot,dm-pre-reloc;
		compatible = "regulator-fixed";
		regulator-name = "vcc12v0_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
	};

	vcc3v3_ext: vcc3v3-ext-regulator {
		u-boot,dm-pre-reloc;
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_ext";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		startup-delay-us = <5000>;
		vin-supply = <&vcc12v0_sys>;
	};

	vcc3v3_pcie30_ssd: vcc3v3-pcie30-ssd-regulator {
		u-boot,dm-pre-reloc;
		regulator-boot-on;
		regulator-always-on;
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_pcie30_ssd";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc12v0_sys>;
	};

	sdmmc_pwr: sdmmc-pwr {
		u-boot,dm-pre-reloc;
		compatible = "regulator-fixed";
		regulator-name = "sdmmc_pwr";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		enable-active-high;
		gpio = <&gpio1 RK_PB1 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&sdmmc_pwr_en>;
	};

	vcc3v3_pcie_clk: vcc3v3-pcie-clk-regulator {
		u-boot,dm-pre-reloc;
		regulator-boot-on;
		regulator-always-on;
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_pcie_clk";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		enable-active-high;
		gpio = <&gpio1 RK_PA4 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&pcie30_clk_en>;
	};


	pcie_clk: pcie-clk-regulator {
		u-boot,dm-pre-reloc;
		/* Active-low enable (GPIO4_B4 low = clock on). U-Boot's fixed.c
		 * ignores the phandle polarity flag and only reads
		 * enable-active-high, so omit it or pci enum hangs. */
		gpio = <&gpio4 RK_PB4 GPIO_ACTIVE_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&pcie30_clk>;
		regulator-boot-on;
		regulator-always-on;
		compatible = "regulator-fixed";
		regulator-name = "pcie_clk";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
	};

	vcc5v0_usb_eth: vcc5v0-usb-eth-regulator {
		u-boot,dm-pre-reloc;
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&gpio3 RK_PB3 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&vcc5v0_usb_eth_en>;
		regulator-name = "vcc5v0_usb_eth";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&vcc12v0_sys>;
	};

};


&i2c4{
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&eeprom_i2c_pin>;
	u-boot,dm-pre-reloc;
};


&combphy0_ps {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&combphy1_ps {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&combphy2_psu {
	u-boot,dm-pre-reloc;
	status = "okay";
};

/* phy1 - right ethernet port PCIE20_1_TXP */
&pcie2x1l0 {
	u-boot,dm-pre-reloc;
	reset-gpios = <&gpio4 RK_PA5 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc5v0_usb_eth>;
	status = "okay";
};

/* phy2 - M.KEY socket  PCIE20_2_TXP */
&pcie2x1l1 {
	u-boot,dm-pre-reloc;
	reset-gpios = <&gpio4 RK_PA2 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

/* phy0 - left ethernet port PCIE20_0_TXP */
&pcie2x1l2 {
	u-boot,dm-pre-reloc;
	reset-gpios = <&gpio3 RK_PD0 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc5v0_usb_eth>;
	status = "okay";
};

&pcie30phy {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&pcie3x4 {
	u-boot,dm-pre-reloc;
	reset-gpios = <&gpio4 RK_PB6 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

&u2phy0 {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&u2phy0_otg {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usb2phy0_grf {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&u2phy1 {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&u2phy1_otg {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usb2phy1_grf {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&u2phy2 {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&u2phy2_host {
	u-boot,dm-pre-reloc;
	phy-supply = <&vcc5v0_usb_eth>;
	status = "okay";
};

&usb2phy2_grf {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&u2phy3 {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&u2phy3_host {
	u-boot,dm-pre-reloc;
	phy-supply = <&vcc5v0_usb_eth>;
	status = "okay";
};

&usb2phy3_grf {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usb_host0_ehci {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usb_host0_ohci {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usb_host1_ehci {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usb_host1_ohci {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usbdrd3_0 {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usbdrd_dwc3_0 {
	u-boot,dm-pre-reloc;
	dr_mode = "host";
	status = "okay";
};

&usbdrd3_1 {
	u-boot,dm-pre-reloc;
	status = "okay";
};

&usbdrd_dwc3_1 {
	u-boot,dm-pre-reloc;
	dr_mode = "host";
	status = "okay";
};

&sdmmc {
	u-boot,dm-pre-reloc;
	status = "okay";
	bus-width = <4>;
	cap-sd-highspeed;
	disable-wp;
	no-mmc;
	no-sdio;
	max-frequency = <115000000>;
	vmmc-supply = <&sdmmc_pwr>;
	/* Delete cd-gpios (inherited from rk3588-u-boot.dtsi with wrong polarity):
	 * U-Boot 2017's mmc_getcd() ignores non-removable and aborts mmc_init
	 * when the cd GPIO reads inactive. With cd-gpios gone, board_mmc_getcd()
	 * returns -1 and mmc_getcd() falls back to card-present. */
	/delete-property/ cd-gpios;
	non-removable;
};

&pinctrl {

	u-boot,dm-pre-reloc;
	u-boot,dm-spl;
	status = "okay";
	eeprom_i2c {
		u-boot,dm-pre-reloc;
		u-boot,dm-spl;
		eeprom_i2c_pin: eeprom-i2c-pin {
			u-boot,dm-pre-reloc;
			u-boot,dm-spl;
			rockchip,pins =
				/* i2c4_scl_m1 */
				<2 RK_PB5 9 &pcfg_pull_none>,
				/* i2c4_sda_m1 */
				<2 RK_PB4 9 &pcfg_pull_none>;
			};
	};


	usb {
		u-boot,dm-pre-reloc;
		vcc5v0_usb_eth_en: vcc5v0-usb20-en {
			u-boot,dm-pre-reloc;
			rockchip,pins = <3 RK_PB3 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	sdmmc {
		u-boot,dm-pre-reloc;
		sdmmc_pwr_en: sdmmc-pwr-en {
			u-boot,dm-pre-reloc;
			rockchip,pins = <1 RK_PB1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	pcie30_ssd {

		pcie30_clk_en: pcie30-clk-en {
			u-boot,dm-pre-reloc;
			rockchip,pins = <1 RK_PA4 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		pcie30_clk: pcie30-clk {
			u-boot,dm-pre-reloc;
			rockchip,pins = <4 RK_PB4 RK_FUNC_GPIO &pcfg_pull_none>;
		};
		
	};
};
