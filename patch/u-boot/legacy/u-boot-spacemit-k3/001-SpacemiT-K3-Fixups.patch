From e0821f0d74ea0ad632eb7bd69ea3a64408e20153 Mon Sep 17 00:00:00 2001
From: Patrick Yavitz <pyavitz@gmail.com>
Date: Sun, 31 May 2026 10:23:10 -0400
Subject: [PATCH] SpacemiT K3 fixup boot variables

Signed-off-by: Patrick Yavitz <pyavitz@gmail.com>
---
 board/spacemit/k3/k3.c | 44 +++++++++++++++++++++---------------------
 1 file changed, 22 insertions(+), 22 deletions(-)

diff --git a/board/spacemit/k3/k3.c b/board/spacemit/k3/k3.c
index 1240cb8cc2..d281eb2114 100644
--- a/board/spacemit/k3/k3.c
+++ b/board/spacemit/k3/k3.c
@@ -955,7 +955,7 @@ static int part_num;
 static int udisk_dev_num;
 static void try_boot_from_udisk(void)
 {
-	char bootfs_part[16] = "";
+	char distro_bootpart[16] = "";
 	char dev_num_str[4] = "";
 	struct blk_desc *dev_desc;
 	struct disk_partition info;
@@ -985,8 +985,8 @@ static void try_boot_from_udisk(void)
 		pr_info("udisk boot: Found 'bootfs' at usb %d, partition %d %s %s\n",
 			udisk_dev_num, part_num, dev_desc->vendor, dev_desc->product);
 
-		sprintf(bootfs_part, "%d:%d", udisk_dev_num, part_num);
-		if (fs_set_blk_dev("usb", bootfs_part, FS_TYPE_ANY) != 0) {
+		sprintf(distro_bootpart, "%d:%d", udisk_dev_num, part_num);
+		if (fs_set_blk_dev("usb", distro_bootpart, FS_TYPE_ANY) != 0) {
 			pr_info("udisk boot: set blk dev fail on usb %d\n", udisk_dev_num);
 			continue;
 		}
@@ -999,7 +999,7 @@ static void try_boot_from_udisk(void)
 		}
 
 		// reset related state, or env_k3.txt may not be detected even if this file exist
-		fs_set_blk_dev("usb", bootfs_part, FS_TYPE_ANY);
+		fs_set_blk_dev("usb", distro_bootpart, FS_TYPE_ANY);
 
 		if (fs_exists("env_k3.txt")) {
 			pr_info("udisk boot: found env_k3.txt on usb %d! setting environment value...\n",
@@ -1022,11 +1022,11 @@ static void try_boot_from_udisk(void)
 	}
 
 	env_set("boot_override", "udisk");
-	env_set("boot_device", "udisk");
+	env_set("devtype", "udisk");
 	env_set("boot_devname", "usb");
 
 	sprintf(dev_num_str, "%d", udisk_dev_num);
-	env_set("boot_devnum", dev_num_str);
+	env_set("devnum", dev_num_str);
 }
 #endif
 
@@ -1315,7 +1315,7 @@ void setenv_boot_mode(void)
 	const char *boot_override = env_get("boot_override");
 
 	if (boot_override) {
-		env_set("boot_device", boot_override);
+		env_set("devtype", boot_override);
 		env_set("boot_override", NULL);
 		return;
 	}
@@ -1323,14 +1323,14 @@ void setenv_boot_mode(void)
 	u32 boot_mode = get_boot_mode();
 	switch (boot_mode) {
 	case BOOT_MODE_NAND:
-		env_set("boot_device", "nand");
+		env_set("devtype", "nand");
 		break;
 	case BOOT_MODE_NOR: {
 		const struct k3_nor_boot_target *boot_prio;
 		unsigned int prio_count;
 		u32 i;
 
-		env_set("boot_device", "nor");
+		env_set("devtype", "nor");
 		/*
 		 * NOR-boot: select external boot device by bootfs presence, with
 		 * priority UFS(SCSI) -> SSD(NVMe) -> eMMC(MMC) -> USB(UMS).
@@ -1345,23 +1345,23 @@ void setenv_boot_mode(void)
 			if (desc && desc->type != DEV_TYPE_UNKNOWN &&
 			    k3_nor_has_bootfs(desc)) {
 				env_set("boot_devname", boot_prio[i].blk_name);
-				env_set("boot_devnum", simple_itoa(dev));
+				env_set("devnum", simple_itoa(dev));
 				break;
 			}
 		}
 		break;
 	}
 	case BOOT_MODE_EMMC:
-		env_set("boot_device", "mmc");
-		env_set("boot_devnum", simple_itoa(MMC_DEV_EMMC));
+		env_set("devtype", "mmc");
+		env_set("devnum", simple_itoa(MMC_DEV_EMMC));
 		break;
 	case BOOT_MODE_SD:
-		env_set("boot_device", "mmc");
-		env_set("boot_devnum", simple_itoa(MMC_DEV_SD));
+		env_set("devtype", "mmc");
+		env_set("devnum", simple_itoa(MMC_DEV_SD));
 		break;
 	case BOOT_MODE_UFS:
-		env_set("boot_device", "ufs");
-		env_set("boot_devnum", "0");
+		env_set("devtype", "ufs");
+		env_set("devnum", "0");
 		env_set("boot_devname", "scsi");
 		break;
 	case BOOT_MODE_USB:
@@ -1369,16 +1369,16 @@ void setenv_boot_mode(void)
 		env_set("bootcmd", USB_BOOT_COMMAND);
 		break;
 	default:
-		env_set("boot_device", "");
+		env_set("devtype", "");
 		break;
 	}
 }
 
 static bool k3_is_nfs_boot_path(void)
 {
-	const char *boot_device = env_get("boot_device");
+	const char *devtype = env_get("devtype");
 
-	return boot_device && !strcmp(boot_device, "nfs");
+	return devtype && !strcmp(devtype, "nfs");
 }
 
 static bool k3_is_net_flash_path(void)
@@ -1480,7 +1480,7 @@ static int _load_env_from_blk(struct blk_desc *dev_desc, const char *dev_name, i
 	if (part > MAX_SEARCH_PARTITIONS)
 		return -1;
 
-	env_set("bootfs_part", simple_itoa(part));
+	env_set("distro_bootpart", simple_itoa(part));
 
 	/*load env.txt and import to uboot*/
 	memset((void *)CONFIG_FASTBOOT_BUF_ADDR, 0, CONFIG_ENV_SIZE);
@@ -1596,10 +1596,10 @@ void import_env_from_bootfs(void)
 #endif
 
 #ifdef CONFIG_BOOT_FROM_USB_DISK
-	char *boot_device = env_get("boot_device");
+	char *devtype = env_get("devtype");
 	char cmd[128];
 
-	if (boot_device && !strncmp(boot_device, "udisk", 5)) {
+	if (devtype && !strncmp(devtype, "udisk", 5)) {
 		memset(cmd, 0, 128);
 		sprintf(cmd, "load usb %d:%d ${kernel_addr_r} env_k3.txt",
 			udisk_dev_num, part_num);
-- 
2.53.0

