From: Armbian
Subject: orangepi-zero: DRAM 408 + ZQ/ODT and CPU clock 480MHz

Rebased onto v2026.07-rc4's orangepi_zero_defconfig. Carries forward Armbian's
DRAM tuning (lower DRAM_CLK 624->408 with ZQ/ODT for stability) and the
small-board CPU clock (480 MHz). The old power-LED patch is dropped: upstream now
provides CONFIG_SPL_SUNXI_LED_STATUS (already in this defconfig).

--- a/configs/orangepi_zero_defconfig
+++ b/configs/orangepi_zero_defconfig
@@ -1,7 +1,9 @@
 CONFIG_ARM=y
 CONFIG_ARCH_SUNXI=y
 CONFIG_DEFAULT_DEVICE_TREE="sun8i-h2-plus-orangepi-zero"
-CONFIG_DRAM_CLK=624
+CONFIG_DRAM_CLK=408
+CONFIG_DRAM_ZQ=3881979
+CONFIG_DRAM_ODT_EN=y
 CONFIG_SPL=y
 CONFIG_MACH_SUN8I_H3=y
 # CONFIG_VIDEO_DE2 is not set
@@ -9,6 +11,7 @@
 CONFIG_SPL_SUNXI_LED_STATUS=y
 CONFIG_SPL_SUNXI_LED_STATUS_GPIO=362
 # CONFIG_SYS_MALLOC_CLEAR_ON_INIT is not set
+CONFIG_SYS_CLK_FREQ=480000000
 CONFIG_CONSOLE_MUX=y
 CONFIG_MTD=y
 CONFIG_SPI_FLASH_MACRONIX=y
