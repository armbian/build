From: Armbian
Subject: orangepi-zero-plus2-h3: DRAM 360 + ZQ/ODT (low-clock stability test)

Both 408 (old Armbian) and upstream 672 hang mid-kernel on this board; power
ruled out. Drop DRAM_CLK further to 360 with ZQ/ODT to test whether the DRAM is
just marginal at the higher clocks with the v2026.07 DRAM driver.

--- a/configs/orangepi_zero_plus2_h3_defconfig
+++ b/configs/orangepi_zero_plus2_h3_defconfig
@@ -1,10 +1,11 @@
 CONFIG_ARM=y
 CONFIG_ARCH_SUNXI=y
 CONFIG_DEFAULT_DEVICE_TREE="sun8i-h3-orangepi-zero-plus2"
-CONFIG_DRAM_CLK=672
+CONFIG_DRAM_CLK=360
+CONFIG_DRAM_ZQ=3881979
 CONFIG_SPL=y
 CONFIG_MACH_SUN8I_H3=y
-# CONFIG_DRAM_ODT_EN is not set
+CONFIG_DRAM_ODT_EN=y
 CONFIG_MMC_SUNXI_SLOT_EXTRA=2
 CONFIG_SPL_SUNXI_LED_STATUS=y
 CONFIG_SPL_SUNXI_LED_STATUS_GPIO=362
