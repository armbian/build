+++ b/arch/arm/dts/sun50i-h618-mellow-fly-c5.dts
@@ -0,0 +1,118 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright (C) 2023 Arm Ltd.
+ * Copyright (c) 2026 Alastair D'Silva <alastair@d-silva.org>
