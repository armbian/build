#include "rk356x-u-boot.dtsi"

/ {
	leds {
		led-0 {
			default-state = "on";
		};
	};

	/* HDMI 配置支持 U-Boot 第二阶段输出 */
	display-timings {
		native-mode = <&timing_1080p60>;

		timing_1080p60: timing-1080p60 {
			clock-frequency = <148500000>;
			hactive = <1920>;
			vactive = <1080>;
			hfront-porch = <88>;
			hback-porch = <148>;
			hsync-len = <44>;
			vfront-porch = <4>;
			vback-porch = <36>;
			vsync-len = <5>;
			hsync-active = <0>;
			vsync-active = <0>;
			de-active = <1>;
			pixelclk-active = <0>;
		};
	};

	/* 启动顺序配置 */
	chosen {
		u-boot,spl-boot-order = "same-as-spl", &sdhci, &usb_host0_xhci, &pcie3x2;
		u-boot,boot-order = "mmc0", "usb0", "pcie0";
	};
};

/* PCIe NVMe 支持 - 与主设备树保持一致 */
&pcie3x2 {
	pinctrl-names = "default";
	pinctrl-0 = <&pcie30x2m1_pins>;
	reset-gpios = <&gpio2 RK_PD6 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc3v3_pcie>;
	max-link-speed = <3>;
	num-lanes = <2>;
	status = "okay";
};

/* eMMC 启动支持 */
&sdhci {
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	mmc-hs400-enhanced-strobe;
	bootph-pre-ram;
	bootph-some-ram;
	status = "okay";
};

/* USB 启动支持 */
&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

&usb_host0_xhci {
	status = "okay";
};

&usb2phy0 {
	status = "okay";
};

/* HDMI 控制器配置，确保 U-Boot 第二阶段能够使用 */
&hdmi {
	avdd-0v9-supply = <&vdda0v9_image>;
	avdd-1v8-supply = <&vcca1v8_image>;
	status = "okay";
};

/* 确保 VP0 显示管道在 U-Boot 阶段启用 */
&vp0 {
	status = "okay";
};

/* 启用 U-Boot 启动菜单 */
&uart2 {
	status = "okay";
};
