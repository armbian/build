#include "rk3588-u-boot.dtsi"

/ {
	leds {
		led-0 {
			default-state = "on";
		};
	};

	/* 启动顺序配置 */
	chosen {
		u-boot,spl-boot-order = "same-as-spl", &usb_host0_xhci, &sdmmc, &sdhci;
		u-boot,boot-order = "usb0", "mmc1", "mmc0";
	};
};

/* eMMC 启动支持 */
&sdhci {
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	mmc-hs400-enhanced-strobe;
	bootph-pre-ram;
	bootph-some-ram;
	status = "okay";
};

/* TFcard (SDMMC) 启动支持 */
&sdmmc {
	cap-sd-highspeed;
	bootph-pre-ram;
	bootph-some-ram;
	status = "okay";
};

/* USB 启动支持 */
&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

&usb_host0_xhci {
	status = "okay";
};

&u2phy0 {
	status = "okay";
};

/* 启用 U-Boot 启动菜单 */
&uart2 {
	status = "okay";
};
