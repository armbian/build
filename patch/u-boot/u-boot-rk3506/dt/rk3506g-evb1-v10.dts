/dts-v1/;

#include <dt-bindings/leds/common.h>
#include "rk3506.dtsi"

/ {
	model = "Vanxoak HD-RK3506G-EVB V1 Board";
	compatible = "vanxoak,hd-rk3506g-evb", "rockchip,rk3506";

	aliases {
		ethernet0 = <&gmac0>;
		ethernet1 = <&gmac1>;
		mmc0 = &sdmmc;
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:1500000n8";
	};

	leds {
		compatible = "gpio-leds";

		led-0 {
			color = <LED_COLOR_ID_GREEN>;
			default-state = "on";
			function = LED_FUNCTION_HEARTBEAT;
			gpios = <&gpio0 RK_PD0 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "heartbeat";
			pinctrl-names = "default";
			pinctrl-0 = <&run_led>;
		};
	};

	vcc12v_dc: regulator-12v-dc {
		compatible = "regulator-fixed";
		regulator-name = "vcc12v_dc";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
	};

	vcc_sys: regulator-vcc-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&vcc12v_dc>;
	};

	vcc3v3_stb: regulator-3v3-stb {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_stb";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc_sys>;
	};

	vcc_1v8: regulator-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		vin-supply = <&vcc3v3_stb>;
	};

	vcc_ddr: regulator-vcc-ddr {
		compatible = "regulator-fixed";
		regulator-name = "vcc_ddr";
		regulator-always-on;
		regulator-boot-on;
		vin-supply = <&vcc_sys>;
	};
};

&fspi {
	status = "okay";

	flash@0 {
		compatible = "spi-nand";
		reg = <0>;
		spi-max-frequency = <80000000>;
		spi-rx-bus-width = <4>;
		spi-tx-bus-width = <1>;
		vcc-supply = <&vcc3v3_stb>;
	};
};

&gmac0 {
	clock_in_out = "input";
	phy-handle = <&rmii_phy0>;
	phy-supply = <&vcc3v3_stb>;
	pinctrl-names = "default";
	pinctrl-0 = <&eth_rmii0_miim>, <&eth_rmii0_tx_bus2>,
		    <&eth_rmii0_rx_bus2>, <&eth_rmii0_clk>;
	snps,reset-gpio = <&gpio1 RK_PD3 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 20000 100000>;
	status = "okay";
};

&gmac1 {
	clock_in_out = "input";
	phy-handle = <&rmii_phy1>;
	phy-supply = <&vcc3v3_stb>;
	pinctrl-names = "default";
	pinctrl-0 = <&eth_rmii1_miim>, <&eth_rmii1_tx_bus2>,
		    <&eth_rmii1_rx_bus2>, <&eth_rmii1_clk>;
	snps,reset-gpio = <&gpio1 RK_PD2 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 20000 100000>;
	status = "okay";
};

&mdio0 {
	rmii_phy0: ethernet-phy@0 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0>;
	};
};

&mdio1 {
	rmii_phy1: ethernet-phy@0 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0>;
	};
};

&pinctrl {
	leds {
		/omit-if-no-ref/
		run_led: run-led {
			rockchip,pins = <0 RK_PD0 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	sdmmc {
		/omit-if-no-ref/
		sdmmc_det_l: sdmmc-det-l {
			rockchip,pins = <1 RK_PB3 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};
};

&saradc {
	vref-supply = <&vcc_1v8>;
	status = "okay";
};

&sdmmc {
	cap-sd-highspeed;
	cd-gpios = <&gpio1 RK_PB3 GPIO_ACTIVE_LOW>;
	disable-wp;
	no-mmc;
	no-sdio;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc_bus4>, <&sdmmc_clk>, <&sdmmc_cmd>, <&sdmmc_det_l>;
	vmmc-supply = <&vcc3v3_stb>;
	vqmmc-supply = <&vcc3v3_stb>;
	status = "okay";
};

&uart0 {
	status = "okay";
};

&usb20_otg0 {
	status = "okay";
};

&usb20_otg1 {
	dr_mode = "host";
	status = "okay";
};

&usb2phy {
	status = "okay";
};

&usb2phy_otg0 {
	status = "okay";
};

&usb2phy_otg1 {
	status = "okay";
};
