From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Martin Schmiedel <Martin.Schmiedel@tq-group.com>
Date: Mon, 5 May 2025 08:00:00 +0200
Subject: tqma: add ramdisk_addr_r to env

distro_bootcmd / extlinux requires ramdisk_addr_r to know where to
load the initrd.  TQ board headers define initrd_addr for TQ's own
boot flow but omit the standard ramdisk_addr_r, causing:

  missing environment variable: ramdisk_addr_r

Memory layout:
  tqma8mpxl / tqma8mpxs (DRAM at 0x40000000):
    fdtoverlay_addr_r = 0x43080000
    ramdisk_addr_r    = 0x48000000  (320 MiB offset)

  tqma93xx (DRAM at 0x80000000, 1 GiB):
    fdtoverlay_addr_r = 0x83080000
    ramdisk_addr_r    = 0x96000000  (384 MiB offset)
---
 include/configs/tqma8mpxl.h | 1 +
 include/configs/tqma8mpxs.h | 1 +
 include/configs/tqma93xx.h  | 1 +
 3 files changed, 3 insertions(+)

diff --git a/include/configs/tqma8mpxl.h b/include/configs/tqma8mpxl.h
index 111111111111..222222222222 100644
--- a/include/configs/tqma8mpxl.h
+++ b/include/configs/tqma8mpxl.h
@@ -64,6 +64,7 @@
 	"pxefile_addr_r=0x40300000\0"                                  \
 	"fdt_addr_r=0x43000000\0"                                      \
 	"fdtoverlay_addr_r=0x43080000\0"                               \
+	"ramdisk_addr_r=0x48000000\0"                                  \
 	"initrd_addr=0x43800000\0"                                     \
 	"mmcdev=" __stringify(CONFIG_SYS_MMC_ENV_DEV) "\0"             \
 	"mmcautodetect=yes\0"                                          \
diff --git a/include/configs/tqma8mpxs.h b/include/configs/tqma8mpxs.h
index 111111111111..222222222222 100644
--- a/include/configs/tqma8mpxs.h
+++ b/include/configs/tqma8mpxs.h
@@ -64,6 +64,7 @@
 	"pxefile_addr_r=0x40300000\0"                                  \
 	"fdt_addr_r=0x43000000\0"                                      \
 	"fdtoverlay_addr_r=0x43080000\0"                               \
+	"ramdisk_addr_r=0x48000000\0"                                  \
 	"initrd_addr=0x43800000\0"                                     \
 	"mmcdev=" __stringify(CONFIG_SYS_MMC_ENV_DEV) "\0"             \
 	"mmcautodetect=yes\0"                                          \
diff --git a/include/configs/tqma93xx.h b/include/configs/tqma93xx.h
index 111111111111..222222222222 100644
--- a/include/configs/tqma93xx.h
+++ b/include/configs/tqma93xx.h
@@ -48,6 +48,7 @@
 	"pxefile_addr_r=0x80300000\0"                                  \
 	"fdt_addr_r=0x83000000\0"                                      \
 	"fdtoverlay_addr_r=0x83080000\0"                               \
+	"ramdisk_addr_r=0x96000000\0"                                  \
 	"initrd_addr=0x83800000\0"                                     \
 	"mmcdev=" __stringify(CONFIG_SYS_MMC_ENV_DEV) "\0"             \
 	"mmcautodetect=yes\0"                                          \
-- 
Armbian

