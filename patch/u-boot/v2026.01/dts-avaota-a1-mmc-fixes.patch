From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Armbian Build Framework <build@armbian.com>
Date: Wed, 16 Jul 2026 20:15:00 +0000
Subject: [PATCH] dts: avaota-a1: Fix MMC configuration

 Fix MMC node configuration for Avaota A1:
 - Add broken-cd property for card detection
 - Comment out cd-gpios, keep bus-width at 4-bit
 - Add max-frequency limit to 25MHz (high-speed SDHC mode)
 - Enable regulator-always-on for CLDO3

Signed-off-by: Armbian Build Framework <build@armbian.com>
---
 dts/upstream/src/arm64/allwinner/sun55i-t527-avaota-a1.dts | 15 ++++++++------
 1 file changed, 9 insertions(+), 6 deletions(-)

diff --git a/dts/upstream/src/arm64/allwinner/sun55i-t527-avaota-a1.dts b/dts/upstream/src/arm64/allwinner/sun55i-t527-avaota-a1.dts
index b9eeb6753e9..a7cde2a4d5d 100644
--- a/dts/upstream/src/arm64/allwinner/sun55i-t527-avaota-a1.dts
+++ b/dts/upstream/src/arm64/allwinner/sun55i-t527-avaota-a1.dts
@@ -90,8 +90,10 @@
 
 &mmc0 {
 	vmmc-supply = <&reg_cldo3>;
-	cd-gpios = <&pio 5 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; /* PF6 */
+	/* cd-gpios = <&pio 5 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; */ /* PF6 */
 	bus-width = <4>;
+	max-frequency = <25000000>;
+	broken-cd;
 	status = "okay";
 };
 
@@ -234,11 +236,12 @@
 				regulator-name = "vcc-efuse";
 			};
 
-			reg_cldo3: cldo3 {
-				regulator-min-microvolt = <3300000>;
-				regulator-max-microvolt = <3300000>;
-				regulator-name = "vcc-io-mmc-spi-ana";
-			};
+		reg_cldo3: cldo3 {
+			regulator-always-on;
+			regulator-min-microvolt = <3300000>;
+			regulator-max-microvolt = <3300000>;
+			regulator-name = "vcc-io-mmc-spi-ana";
+		};
 
 			reg_cldo4: cldo4 {
 				/* not connected */
