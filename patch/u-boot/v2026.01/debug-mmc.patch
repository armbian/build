From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Juan Sanchez Fuentes <juanesf91@gmail.com>
Date: Sun, 19 Jul 2026 01:30:00 -0400
Subject: [PATCH] debug: MMC diagnostics for Avaota A1 boot failure

Add printf-based debug output to diagnose SD card read failures on
Avaota A1 (A523). Output includes clock configuration, command
tracing, and controller error registers (rint, status, clkcr, gctrl).

Apply on top of the other MMC patches to get verbose SPL boot output.
Remove this patch for clean production builds.

Co-assisted-by: opencode/minimax-m3
Signed-off-by: Juan Sanchez Fuentes <juanesf91@gmail.com>
---
 drivers/mmc/sunxi_mmc.c | 30 ++++++++++++++++++++----------
 1 file changed, 20 insertions(+), 10 deletions(-)

diff --git a/drivers/mmc/sunxi_mmc.c b/drivers/mmc/sunxi_mmc.c
index XXXXXX..YYYYYY 100644
--- a/drivers/mmc/sunxi_mmc.c
+++ b/drivers/mmc/sunxi_mmc.c
--- a/drivers/mmc/sunxi_mmc.c
+++ b/drivers/mmc/sunxi_mmc.c
@@ -130,10 +130,14 @@
 	}
 
 	if (n > 3) {
-		printf("mmc %u error cannot set clock to %u\n", priv->mmc_no,
-		       hz);
+		printf("[MMC%d] CLOCK ERROR: req=%u pll_hz=%u n=%u div=%u\n",
+		       priv->mmc_no, hz, pll_hz, n, div);
 		return -1;
 	}
+
+	printf("[MMC%d] mod-clk: req=%u parent=%u n=%u div=%u rate=%u\n",
+	       priv->mmc_no, hz, pll_hz, 1u << n, div,
+	       pll_hz / (1u << n) / div);
 
 	/* determine delays */
 	if (hz <= 400000) {
@@ -226,6 +230,10 @@
 	if (mmc_set_mod_clk(priv, clock))
 		return -1;
 
+	printf("[MMC%d] cfg-clk: clkcr=0x%08x gctrl=0x%08x rint=0x%08x\n",
+	       priv->mmc_no, readl(&priv->reg->clkcr),
+	       readl(&priv->reg->gctrl), readl(&priv->reg->rint));
+
 	/* Clear internal divider */
 	rval &= ~SUNXI_MMC_CLK_DIVIDER_MASK;
 	if (IS_ENABLED(CONFIG_MACH_SUN55I_A523))
@@ -347,8 +355,12 @@
 		status = readl(&priv->reg->rint);
 		if ((get_timer(start) > timeout_msecs) ||
 		    (status & SUNXI_MMC_RINT_INTERRUPT_ERROR_BIT)) {
-			debug("%s timeout %x\n", what,
-			      status & SUNXI_MMC_RINT_INTERRUPT_ERROR_BIT);
+			printf("[MMC%d] %s ERR: rint=0x%08x status=0x%08x\n",
+			       priv->mmc_no, what, status,
+			       readl(&priv->reg->status));
+			printf("[MMC%d] gctrl=0x%08x clkcr=0x%08x\n",
+			       priv->mmc_no, readl(&priv->reg->gctrl),
+			       readl(&priv->reg->clkcr));
 			return -ETIMEDOUT;
 		}
 	} while (!(status & done_bit));
@@ -397,8 +409,8 @@
 		writel(data->blocks * data->blocksize, &priv->reg->bytecnt);
 	}
 
-	debug("mmc %d, cmd %d(0x%08x), arg 0x%08x\n", priv->mmc_no,
-	      cmd->cmdidx, cmdval | cmd->cmdidx, cmd->cmdarg);
+	printf("[MMC%d] cmd=%d arg=0x%08x\n",
+	       priv->mmc_no, cmd->cmdidx, cmd->cmdarg);
 	writel(cmd->cmdarg, &priv->reg->arg);
 
 	if (!data)
