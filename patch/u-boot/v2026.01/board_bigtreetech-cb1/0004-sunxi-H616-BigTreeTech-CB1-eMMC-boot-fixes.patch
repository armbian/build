From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Igor Pecovnik <igor@armbian.com>
Date: Wed, 17 Jun 2026 09:22:39 +0200
Subject: [PATCH 4/4] sunxi: H616: BigTreeTech CB1 eMMC boot fixes

Lower the sunxi MMC f_max to 20 MHz and set the PC3 eMMC select pin to pull-down
so the CB1 boots reliably from eMMC.
---
 board/sunxi/board.c     | 4 ++++
 drivers/mmc/sunxi_mmc.c | 2 +-
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/board/sunxi/board.c b/board/sunxi/board.c
index 62548e03..ed4dcef2 100644
--- a/board/sunxi/board.c
+++ b/board/sunxi/board.c
@@ -462,6 +462,10 @@ static void mmc_pinmux_setup(int sdc)
 			sunxi_gpio_set_pull(pin, SUNXI_GPIO_PULL_UP);
 			sunxi_gpio_set_drv(pin, 3);
 		}
+		/* PC3 eMMC sel pin set to pull down mode for boot from eMMC */
+		sunxi_gpio_set_cfgpin(SUNXI_GPC(3), SUNXI_GPIO_INPUT);
+		sunxi_gpio_set_pull(SUNXI_GPC(3), SUNXI_GPIO_PULL_DOWN);
+		sunxi_gpio_set_drv(SUNXI_GPC(3), 3);
 #elif defined(CONFIG_MACH_SUN9I)
 		/* SDC2: PC6-PC16 */
 		for (pin = SUNXI_GPC(6); pin <= SUNXI_GPC(16); pin++) {
diff --git a/drivers/mmc/sunxi_mmc.c b/drivers/mmc/sunxi_mmc.c
index e28c81af..e4cd7407 100644
--- a/drivers/mmc/sunxi_mmc.c
+++ b/drivers/mmc/sunxi_mmc.c
@@ -584,7 +584,7 @@ struct mmc *sunxi_mmc_init(int sdc_no)
 	cfg->b_max = CONFIG_SYS_MMC_MAX_BLK_COUNT;
 
 	cfg->f_min = 400000;
-	cfg->f_max = 52000000;
+	cfg->f_max = 20000000;
 
 	if (mmc_resource_init(sdc_no) != 0)
 		return NULL;
