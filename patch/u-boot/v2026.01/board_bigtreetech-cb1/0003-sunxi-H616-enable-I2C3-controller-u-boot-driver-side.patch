From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Igor Pecovnik <igor@armbian.com>
Date: Wed, 17 Jun 2026 09:22:21 +0200
Subject: [PATCH 3/4] sunxi: H616: enable I2C3 controller (u-boot driver side)

The I2C3 device-tree node is already upstream; add the u-boot MVTWSI base, the
MACH_SUN50I_H616 I2C3_ENABLE Kconfig, and the pin/clock bring-up in
i2c_init_board so the CB1 can use I2C3.
---
 arch/arm/include/asm/arch-sunxi/i2c.h |  3 +++
 arch/arm/mach-sunxi/Kconfig           |  9 +++++++++
 board/sunxi/board.c                   | 11 +++++++++++
 3 files changed, 23 insertions(+)

diff --git a/arch/arm/include/asm/arch-sunxi/i2c.h b/arch/arm/include/asm/arch-sunxi/i2c.h
index f0da46d8..100d4396 100644
--- a/arch/arm/include/asm/arch-sunxi/i2c.h
+++ b/arch/arm/include/asm/arch-sunxi/i2c.h
@@ -13,6 +13,9 @@
 #ifdef CONFIG_I2C1_ENABLE
 #define CFG_I2C_MVTWSI_BASE1	SUNXI_TWI1_BASE
 #endif
+#ifdef CONFIG_I2C3_ENABLE
+#define CFG_I2C_MVTWSI_BASE3	SUNXI_TWI3_BASE
+#endif
 #ifdef CONFIG_R_I2C_ENABLE
 #define CFG_I2C_MVTWSI_BASE2 SUNXI_R_TWI_BASE
 #endif
diff --git a/arch/arm/mach-sunxi/Kconfig b/arch/arm/mach-sunxi/Kconfig
index e979ee4a..0231d7bb 100644
--- a/arch/arm/mach-sunxi/Kconfig
+++ b/arch/arm/mach-sunxi/Kconfig
@@ -936,6 +936,15 @@ config I2C1_ENABLE
 	---help---
 	See I2C0_ENABLE help text.
 
+if MACH_SUN50I_H616
+config I2C3_ENABLE
+	bool "Enable I2C/TWI controller 3"
+	default n
+	select CMD_I2C
+	---help---
+	See I2C0_ENABLE help text.
+endif
+
 if SUNXI_GEN_SUN6I || SUN50I_GEN_H6 || SUNXI_GEN_NCAT2
 config R_I2C_ENABLE
 	bool "Enable the PRCM I2C/TWI controller"
diff --git a/board/sunxi/board.c b/board/sunxi/board.c
index 30e09d06..62548e03 100644
--- a/board/sunxi/board.c
+++ b/board/sunxi/board.c
@@ -109,6 +109,17 @@ void i2c_init_board(void)
 #endif
 #endif
 
+#ifdef CONFIG_I2C3_ENABLE
+#if defined(CONFIG_MACH_SUN50I_H616)
+	sunxi_gpio_set_cfgpin(SUNXI_GPA(10), 2);
+	sunxi_gpio_set_cfgpin(SUNXI_GPA(11), 2);
+	sunxi_gpio_set_cfgpin(SUNXI_GPA(12), 2);
+	sunxi_gpio_set_pull(SUNXI_GPA(10), SUNXI_GPIO_PULL_UP);
+	sunxi_gpio_set_pull(SUNXI_GPA(11), SUNXI_GPIO_PULL_UP);
+	clock_twi_onoff(3, 1);
+#endif
+#endif
+
 #ifdef CONFIG_R_I2C_ENABLE
 #ifdef CONFIG_MACH_SUN50I
 	clock_twi_onoff(5, 1);
