From: orangepi-xunlong <258384131@qq.com>
Subject: sunxi: power led support (PWRLED config option)

Forward-ported to v2026.07. Adds a generic CONFIG_PWRLED (defaults PH4 on H6)
and lights it in board_init(). board.c was restructured in v2026.07 (the old
H616-THS anchor moved), so the board_init hunk is rebased to insert before
eth_init_board(). Board-scoped to inovato-quadra; harmless default elsewhere.

--- a/arch/arm/mach-sunxi/Kconfig	2026-06-08 21:43:04.000000000 +0200
+++ b/arch/arm/mach-sunxi/Kconfig	2026-06-30 11:39:48.741947358 +0200
@@ -911,6 +911,15 @@
 	Set this to enable various workarounds for old kernels, this results in
 	sub-optimal settings for newer kernels, only enable if needed.
 
+config PWRLED
+	string "Power led pin"
+	default "PL10" if MACH_SUNXI_H3_H5
+	default "PH4" if MACH_SUN50I_H6
+	default ""
+	help
+	  Set the pin used to power the led. This takes a string in the format
+	  understood by sunxi_name_to_gpio, e.g. PC12 for pin 1 of port H.
+
 config MMC1_PINS_PH
 	bool "Pins for mmc1 are on Port H"
 	depends on MACH_SUN4I || MACH_SUN7I || MACH_SUN8I_R40
--- a/board/sunxi/board.c	2026-06-08 21:43:04.000000000 +0200
+++ b/board/sunxi/board.c	2026-06-30 11:39:48.748985813 +0200
@@ -192,7 +192,7 @@
 /* called only from U-Boot proper */
 int board_init(void)
 {
-	__maybe_unused int id_pfr1, ret;
+	__maybe_unused int id_pfr1, ret, pwrled_pin;
 
 	gd->bd->bi_boot_params = (PHYS_SDRAM_0 + 0x100);
 
@@ -229,6 +229,14 @@
 	if (ret)
 		return ret;
 
+	if (CONFIG_PWRLED[0]) {
+		pwrled_pin = sunxi_name_to_gpio(CONFIG_PWRLED);
+		if (pwrled_pin >= 0) {
+			gpio_request(pwrled_pin, "pwrled");
+			gpio_direction_output(pwrled_pin, 1);
+		}
+	}
+
 	eth_init_board();
 
 	return 0;
