diff --git a/arch/arm/mach-sunxi/clock_sun50i_h6.c b/arch/arm/mach-sunxi/clock_sun50i_h6.c
index 80004f13a1e..edc582b9b58 100644
--- a/arch/arm/mach-sunxi/clock_sun50i_h6.c
+++ b/arch/arm/mach-sunxi/clock_sun50i_h6.c
@@ -72,6 +72,16 @@ void clock_init_safe(void)
 		writel(MBUS_CLK_SRC_PLL6X2 | MBUS_CLK_M(3),
 		       ccm + CCU_H6_MBUS_CFG);
 	}
+
+	if (IS_ENABLED(CONFIG_MACH_SUN50I_H616)) {
+		/* Enable EPHY clock/reset */
+		writel(0x10001, (void *)SUNXI_CCM_BASE + 0x7ac);
+		/* Enable PWM clock and output for reference clock */
+		writel(0x50, (void *)0x0300a028);
+		writel(0x20, (void *)0x0300a040);
+		/* Configure PA12 to function 2 (PWM5) for PHY reference clock */
+		clrsetbits_le32((void *)0x0300b004, 0xf << 16, 2 << 16);
+	}
 }
 
 void clock_init_uart(void)
