From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Juergen Herrmann <shadowrom@me.com>
Date: Mon, 26 May 2026 21:25:00 +0000
Subject: arm: dts: rockchip: add qidi-x6 U-Boot dtsi
---
 arch/arm/dts/rk3328-qidi-x6-u-boot.dtsi | 31 +++++++++++++++++
 1 file changed, 31 insertions(+)

diff --git a/arch/arm/dts/rk3328-qidi-x6-u-boot.dtsi b/arch/arm/dts/rk3328-qidi-x6-u-boot.dtsi
new file mode 100644
index 0000000000..6085179f18
--- /dev/null
+++ b/arch/arm/dts/rk3328-qidi-x6-u-boot.dtsi
@@ -0,0 +1,31 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2018-2019 Rockchip Electronics Co., Ltd
+ */
+
+#include "rk3328-u-boot.dtsi"
+#include "rk3328-sdram-ddr3-666.dtsi"
+
+/ {
+	smbios {
+		compatible = "u-boot,sysinfo-smbios";
+
+		smbios {
+			system {
+				manufacturer = "qidi";
+				product = "x-6";
+			};
+
+			baseboard {
+				manufacturer = "qidi";
+				product = "x-6";
+			};
+
+			chassis {
+				manufacturer = "qidi";
+				product = "x-6";
+			};
+		};
+	};
+};
+
+&usb20_otg {
+	hnp-srp-disable;
+};
+
+&vcc_sd {
+	bootph-pre-ram;
+};
