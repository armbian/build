From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Maxim Medvedev <redrathnure@gmail.com>
Date: Thu, 2 Jul 2026 20:10:04 +0000
Subject: mkspi: add MKSPI U-Boot dtsi

Signed-off-by: Maxim Medvedev <redrathnure@gmail.com>
---
 arch/arm/dts/rk3328-mkspi-u-boot.dtsi | 33 +++++++++++++++++
 1 file changed, 33 insertions(+)

diff --git a/arch/arm/dts/rk3328-mkspi-u-boot.dtsi b/arch/arm/dts/rk3328-mkspi-u-boot.dtsi
new file mode 100644
index 0000000000..6085179f18
--- /dev/null
+++ b/arch/arm/dts/rk3328-mkspi-u-boot.dtsi
@@ -0,0 +1,33 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * (C) Copyright 2018-2019 Rockchip Electronics Co., Ltd
+ */
+
+// Based on arch/arm/dts/rk3328-roc-cc-u-boot.dtsi
+
+#include "rk3328-u-boot.dtsi"
+#include "rk3328-sdram-ddr3-666.dtsi"
+
+/ {
+	smbios {
+		compatible = "u-boot,sysinfo-smbios";
+
+		smbios {
+			system {
+				manufacturer = "makerbase";
+				product = "mkspi";
+			};
+
+			baseboard {
+				manufacturer = "makerbase";
+				product = "mkspi";
+			};
+
+			chassis {
+				manufacturer = "makerbase";
+				product = "mkspi";
+			};
+		};
+	};
+};
+
+&usb20_otg {
+	hnp-srp-disable;
+};
+
+&vcc_sd {
+	bootph-pre-ram;
+};
