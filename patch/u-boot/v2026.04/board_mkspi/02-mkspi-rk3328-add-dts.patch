 dts/upstream/src/arm64/rockchip/rk3328-mkspi.dts | 27 ++++++++++
 1 file changed, 27 insertions(+)

diff --git a/dts/upstream/src/arm64/rockchip/rk3328-mkspi.dts b/dts/upstream/src/arm64/rockchip/rk3328-mkspi.dts
new file mode 100644
index 00000000000..1ea4b2a95a0
--- /dev/null
