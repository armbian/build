Fix RK3308 download/recovery key detection on U-Boot v2025.04.

board/rockchip/evb_rk3308/evb_rk3308.c looks up the SARADC by the exact
name "saradc", but the DM device is named "saradc@ff1e0000" and v2025.04's
uclass_get_device_by_name() requires an exact (length-checked) match, so the
lookup returns -ENODEV ("read board id failed") and the recovery key never
works. Older vendor U-Boot prefix-matched, hence the regression. Use the full
node name so adc_channel_single_shot() finds the device again.

diff --git a/board/rockchip/evb_rk3308/evb_rk3308.c b/board/rockchip/evb_rk3308/evb_rk3308.c
--- a/board/rockchip/evb_rk3308/evb_rk3308.c
+++ b/board/rockchip/evb_rk3308/evb_rk3308.c
@@ -16,7 +16,7 @@ int rockchip_dnl_key_pressed(void)
 	unsigned int key_val, id_val;
 	int key_ch;

-	if (adc_channel_single_shot("saradc", 3, &id_val)) {
+	if (adc_channel_single_shot("saradc@ff1e0000", 3, &id_val)) {
 		printf("%s read board id failed\n", __func__);
 		return false;
 	}
@@ -26,7 +26,7 @@ int rockchip_dnl_key_pressed(void)
 	else
 		key_ch = 1;

-	if (adc_channel_single_shot("saradc", key_ch, &key_val)) {
+	if (adc_channel_single_shot("saradc@ff1e0000", key_ch, &key_val)) {
 		printf("%s read adc key val failed\n", __func__);
 		return false;
 	}
