From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Juergen Herrmann <shadowrom@me.com>
Date: Sun, 8 Dec 2024 13:58:51 +0000
Subject: add U-Boot draft for Qidi-x6 board
---
 dts/upstream/src/arm64/rockchip/rk3328-qidi-x6.dts | 73 +++++++++++++
 1 file changed, 73 insertions(+)

diff --git a/dts/upstream/src/arm64/rockchip/rk3328-qidi-x6.dts b/dts/upstream/src/arm64/rockchip/rk3328-qidi-x6.dts
new file mode 100644
index 0000000000..20ca255664
--- /dev/null
+++ b/dts/upstream/src/arm64/rockchip/rk3328-qidi-x6.dts
@@ -0,0 +1,73 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Based on rk3328-roc-cc.dts
+ *
+ * Copyright (c) 2017 T-Chip Intelligent Technology Co., Ltd
+ */
+
+/dts-v1/;
+
+#include <dt-bindings/input/input.h>
+#include "rk3328-roc.dtsi"
+
+/ {
+	model = "Qidi X-6";
+	compatible = "mks,rk3328-qidi-x6", "rockchip,rk3328";
+};
+
+&rk805 {
+	interrupt-parent = <&gpio2>;
+	interrupts = <6 IRQ_TYPE_LEVEL_LOW>;
+};
+
+&analog_sound {
+	status = "disabled";
+};
+
+&codec {
+	status = "disabled";
+};
+
+&gmac2phy {
+	status = "okay";
+};
+
+&gmac2io {
+	status = "disabled";
+};
+
+&vcc_host1_5v {
+	gpio = <&gpio0 RK_PA2 GPIO_ACTIVE_HIGH>;
+};
+
+&vcc_sdio {
+	gpios = <&gpio2 RK_PC4 GPIO_ACTIVE_HIGH>;
+	pinctrl-0 = <&sdio_vcc_pin>;
+	pinctrl-names = "default";
+	states = <1800000 0x0>, <3300000 0x1>;
+	vin-supply = <&vcc_io>;
+};
+
+&io_domains {
+	vccio4-supply = <&vcc_io>;
+};
+
+&pinctrl {
+	pmic {
+		pmic_int_l: pmic-int-l {
+			rockchip,pins = <2 RK_PA6 RK_FUNC_GPIO &pcfg_pull_up>;
+		};
+	};
+
+	usb2 {
+		usb20_host_drv: usb20-host-drv {
+			rockchip,pins = <0 RK_PA2 RK_FUNC_GPIO &pcfg_pull_none>;
+		};
+	};
+
+	sd {
+		sdio_vcc_pin: sdio-vcc-pin {
+			rockchip,pins = <2 RK_PC4 RK_FUNC_GPIO &pcfg_pull_up>;
+		};
+	};
+};
