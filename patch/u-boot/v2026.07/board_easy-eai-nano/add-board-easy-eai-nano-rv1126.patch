diff --git a/arch/arm/dts/rv1126-easy-eai-nano-u-boot.dtsi b/arch/arm/dts/rv1126-easy-eai-nano-u-boot.dtsi
new file mode 100644
index 00000000000..0b54f0b4ec8
--- /dev/null
+++ b/arch/arm/dts/rv1126-easy-eai-nano-u-boot.dtsi
@@ -0,0 +1,56 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+/*
+ * Copyright (c) 2026 Nicolas Henrique
+ */
+
+#include "rv1126-u-boot.dtsi"
+
+/ {
+	chosen {
+		u-boot,spl-boot-order = "same-as-spl", &sdmmc, &emmc;
+	};
+};
+
+&emmc {
+	bootph-pre-ram;
+};
+
+&emmc_bus8 {
+	bootph-pre-ram;
+};
+
+&emmc_clk {
+	bootph-pre-ram;
+};
+
+&emmc_cmd {
+	bootph-pre-ram;
+};
+
+&emmc_rstnout {
+	bootph-pre-ram;
+};
+
+&sdmmc {
+	bootph-pre-ram;
+};
+
+&sdmmc0_bus4 {
+	bootph-pre-ram;
+};
+
+&sdmmc0_clk {
+	bootph-pre-ram;
+};
+
+&sdmmc0_cmd {
+	bootph-pre-ram;
+};
+
+&sdio {
+	status = "disabled";
+};
+
+&uart2 {
+	bootph-pre-ram;
+};
