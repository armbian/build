Subject: BigTreeTech CB2 serial out

Signed-off-by: JohnTheCoolingFan <ivan8215145640@gmail.com>
---
 arch/arm/dts/rk3566-bigtreetech-cb2.dts | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/arch/arm/dts/rk3566-bigtreetech-cb2.dts b/arch/arm/dts/rk3566-bigtreetech-cb2.dts
index d216e204b35..74e5e73b27f 100644
--- a/arch/arm/dts/rk3566-bigtreetech-cb2.dts
+++ b/arch/arm/dts/rk3566-bigtreetech-cb2.dts
@@ -12,10 +12,18 @@
 
 / {
 	model = "BigTreeTech CB2";
 	compatible = "rockchip,rk3566";
 
+	aliases {
+		serial0 = &uart0;
+	};
+
+	chosen {
+		stdout-path = "serial0:1500000n8";
+	};
+
 	dc_12v: dc-12v {
 		compatible = "regulator-fixed";
 		regulator-name = "dc_12v";
 		regulator-always-on;
 		regulator-boot-on;
