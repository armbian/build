Subject: Patching u-boot rockchip64 files
 arch/arm/dts/rk3566-bigtreetech-cb2.dts

Signed-off-by: JohnTheCoolingFan <ivan8215145640@gmail.com>
---
 arch/arm/dts/rk3566-bigtreetech-cb2.dts | 35 ++++++++++
 1 file changed, 35 insertions(+)

diff --git a/arch/arm/dts/rk3566-bigtreetech-cb2.dts b/arch/arm/dts/rk3566-bigtreetech-cb2.dts
index d7f1afd6244..acb99ef8c9a 100644
--- a/arch/arm/dts/rk3566-bigtreetech-cb2.dts
+++ b/arch/arm/dts/rk3566-bigtreetech-cb2.dts
@@ -91,10 +91,45 @@
 			press-threshold-microvolt = <9>;
 		};
 	};
 };
 
+&sdhci {
+	bus-width = <8>;
+	cap-mmc-highspeed;
+	mmc-hs200-1_8v;
+	no-sd;
+	no-sdio;
+	non-removable;
+	pinctrl-names = "default";
+	pinctrl-0 = <&emmc_bus8 &emmc_clk &emmc_cmd &emmc_datastrobe>;
+	status = "okay";
+};
+
+&sdmmc0 {
+	bus-width = <4>;
+	cap-sd-highspeed;
+	disable-wp;
+	no-mmc;
+	no-sdio;
+	pinctrl-names = "default";
+	pinctrl-0 = <&sdmmc0_bus4 &sdmmc0_clk &sdmmc0_cmd &sdmmc0_det>;
+	status = "okay";
+};
+
+&sfc {
+	#address-cells = <1>;
+	#size-cells = <0>;
+	status = "okay";
+
+	flash@0 {
+		compatible = "jedec,spi-nor";
+		reg = <0>;
+		spi-max-frequency = <24000000>;
+	};
+};
+
