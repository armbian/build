#!/bin/bash
set -ex
new_rootfs_image_uuid=$(sed -e 's/^.*root=UUID=//' -e 's/ .*$//' < /proc/cmdline)
gzip -c /boot/vmlinuz-*-sm8750 > /tmp/Image.gz

cat /tmp/Image.gz /usr/lib/linux-image-*-sm8750/qcom/cq8725s-ayn-odin3.dtb > /tmp/Image.gz-dtb

source /boot/armbianEnv.txt
/usr/bin/mkbootimg \
        --kernel /tmp/Image.gz-dtb \
        --ramdisk /boot/initrd.img-*-sm8750 \
        --base 0x0 \
        --second_offset 0x00f00000 \
        --cmdline "clk_ignore_unused pd_ignore_unused console=tty0 ignore_loglevel rw rootwait root=UUID=${new_rootfs_image_uuid}" \
        --kernel_offset 0x10008000 \
        --ramdisk_offset 0x16000000 \
        --tags_offset 0x10000100 \
        --pagesize 2048 \
        -o /boot/KERNEL
rm -f /tmp/Image.gz /tmp/Image.gz-dtb
