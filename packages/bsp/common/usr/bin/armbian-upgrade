#!/bin/bash
trap "exit" INT TERM
[[ $EUID != 0 ]] && exec sudo "$0" "$@"
# use apt-get, the stable scripting interface: plain `apt` prints
# "WARNING: apt does not have a stable CLI interface" on every non-interactive call
apt-get update
apt-get -y upgrade
apt-get clean
apt-get -y autoremove
exit 0
