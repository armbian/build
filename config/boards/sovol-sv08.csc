# Allwinner H616 quad core 1GB RAM SoC WiFi eMMC (Sovol SV08 printer host)
BOARD_NAME="Sovol SV08"
BOARD_VENDOR="sovol"
BOARDFAMILY="sun50iw9"
BOARD_MAINTAINER="lexfrei"
INTRODUCED="2024"
BOOTCONFIG="bigtreetech_cb1_defconfig"
SERIALCON="ttyS0"
KERNEL_TARGET="current,edge"
KERNEL_TEST_TARGET="current"
FORCE_BOOTSCRIPT_UPDATE="yes"
BOOTFS_TYPE="fat"
BOOT_FS_LABEL="BOOT"
OVERLAY_PREFIX="sun50i-h616"
DEFAULT_OVERLAYS="uart3-pi"
BOOT_FDT_FILE="sun50i-h616-sovol-sv08.dtb"
