# The analog sticks are an ABS-only input device, which udev's heuristics
# classify as an accelerometer (making desktops auto-rotate the screen on
# stick movement). Reclassify as a joystick.
SUBSYSTEM=="input", KERNEL=="event*", ATTRS{name}=="MCU Joypad", \
	ENV{ID_INPUT_ACCELEROMETER}="", ENV{ID_INPUT_JOYSTICK}="1"
